#!/usr/bin/env python3
"""
gemini-curses

A Python ncurses interface for the gemini-cli terminal AI workspace.

This program is intentionally kept dependency-light. It uses only Python's
standard library: curses for the terminal UI, urllib for HTTP, and json for
request/response handling.
"""

from __future__ import annotations

import argparse
import curses
import json
import os
import re
import sys
import textwrap
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from typing import List, Optional, Tuple

VERSION = "0.2.0"
PROGRAM = "gemini-curses"


# ---------------------------------------------------------------------------
# Configuration model
# ---------------------------------------------------------------------------
# The ncurses edition intentionally shares configuration keys with the Bash
# edition. A user should be able to move between the minimal Bash client and
# the curses interface without maintaining separate config files.
# ---------------------------------------------------------------------------


@dataclass
class Config:
    model: str = "gemini-2.5-flash"
    history_limit: int = 12
    api_key: str = ""
    session_dir: Path = field(default_factory=lambda: Path.home() / ".gpt")
    attachment_dir: Optional[Path] = None
    config_file: Path = field(
        default_factory=lambda: Path.home() / ".config" / "gemini-cli" / "config"
    )

    @property
    def effective_attachment_dir(self) -> Path:
        if self.attachment_dir is not None:
            return self.attachment_dir
        return self.session_dir / "attachments"


def expand_path(value: str) -> Path:
    """Expand ~ and environment variables in paths from the config file."""
    return Path(os.path.expandvars(os.path.expanduser(value))).resolve()


def normalize_model_id(value: str) -> str:
    """Accept either 'gemini-x' or 'models/gemini-x' and store 'gemini-x'."""
    value = value.strip()
    if value.startswith("models/"):
        value = value.split("/", 1)[1]
    return value


def load_config() -> Config:
    """Load ~/.config/gemini-cli/config using simple KEY=VALUE parsing."""
    cfg = Config()
    env_api_key = os.environ.get("GEMINI_API_KEY", "")

    if cfg.config_file.exists():
        with cfg.config_file.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()

                # Empty lines and comments are ignored. This keeps the config
                # file friendly without requiring TOML, YAML, or JSON.
                if not line or line.startswith("#"):
                    continue

                if "=" not in line:
                    continue

                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip()

                if key == "MODEL":
                    cfg.model = normalize_model_id(value)
                elif key == "HISTORY_LIMIT":
                    try:
                        cfg.history_limit = max(1, int(value))
                    except ValueError:
                        cfg.history_limit = 12
                elif key == "GEMINI_API_KEY":
                    # Environment variable wins. Config-file keys are
                    # convenient but less secure on shared machines.
                    cfg.api_key = env_api_key or value
                elif key == "SESSION_DIR":
                    cfg.session_dir = expand_path(value)
                elif key == "ATTACHMENT_DIR":
                    cfg.attachment_dir = expand_path(value)

    if env_api_key:
        cfg.api_key = env_api_key

    return cfg


def set_config_value(cfg: Config, key: str, value: str) -> None:
    """Create/update a KEY=VALUE entry in the config file.

    This is used by the ncurses UI for two interactive setup actions:
    saving a pasted API key and saving a selected model.
    """
    cfg.config_file.parent.mkdir(parents=True, exist_ok=True)
    lines: List[str] = []
    replaced = False

    if cfg.config_file.exists():
        lines = cfg.config_file.read_text(encoding="utf-8", errors="replace").splitlines()

    new_lines: List[str] = []
    for line in lines:
        if line.strip().startswith(f"{key}="):
            new_lines.append(f"{key}={value}")
            replaced = True
        else:
            new_lines.append(line)

    if not replaced:
        new_lines.append(f"{key}={value}")

    cfg.config_file.write_text("\n".join(new_lines) + "\n", encoding="utf-8")

    # If users save API keys in config, make the file private where possible.
    try:
        os.chmod(cfg.config_file, 0o600)
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Command-line parsing
# ---------------------------------------------------------------------------
# The interface mirrors the Bash version where it makes sense:
#   gemini-curses
#   gemini-curses name
#   gemini-curses --resume name
#   gemini-curses --list
#   gemini-curses --models
#   gemini-curses --version
# ---------------------------------------------------------------------------


def parse_args() -> argparse.Namespace:
    if len(sys.argv) == 2 and sys.argv[1] == "help":
        sys.argv[1] = "--help"

    parser = argparse.ArgumentParser(
        prog=PROGRAM,
        description="ncurses Gemini terminal interface",
    )
    parser.add_argument(
        "session_name",
        nargs="?",
        help="named session to create or open",
    )
    parser.add_argument(
        "--resume",
        metavar="NAME",
        help="resume an existing named session",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="list saved sessions",
    )
    parser.add_argument(
        "--models",
        action="store_true",
        help="list available Gemini generation models and exit",
    )
    parser.add_argument(
        "--version",
        action="store_true",
        help="show version information",
    )
    return parser.parse_args()


def sanitize_session_name(name: str) -> str:
    """Convert a human session name into a safe filename stem."""
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "_", name.strip())
    cleaned = cleaned.strip("._-")
    return cleaned or "session"


def default_session_name() -> str:
    return "session-" + datetime.now().strftime("%Y-%m-%d-%H-%M-%S")


def list_sessions(session_dir: Path) -> None:
    session_dir.mkdir(parents=True, exist_ok=True)
    for path in sorted(session_dir.glob("*.log")):
        print(path.stem)


# ---------------------------------------------------------------------------
# Gemini API transport and model discovery
# ---------------------------------------------------------------------------
# The models list endpoint is useful because model names change over time.
# Users can discover valid model IDs and put one in the config as MODEL=...
# ---------------------------------------------------------------------------


@dataclass
class GeminiModel:
    model_id: str
    display_name: str
    methods: List[str]
    description: str = ""


def gemini_models_url(api_key: str, page_token: str = "") -> str:
    query = {"key": api_key, "pageSize": "100"}
    if page_token:
        query["pageToken"] = page_token
    return "https://generativelanguage.googleapis.com/v1beta/models?" + urllib.parse.urlencode(query)


def fetch_gemini_models(cfg: Config) -> Tuple[List[GeminiModel], str]:
    """Fetch available models that support generateContent."""
    if not cfg.api_key:
        return [], "GEMINI_API_KEY is not set"

    models: List[GeminiModel] = []
    page_token = ""

    while True:
        request = urllib.request.Request(gemini_models_url(cfg.api_key, page_token), method="GET")

        try:
            with urllib.request.urlopen(request, timeout=60) as response:
                body = response.read().decode("utf-8", errors="replace")
        except urllib.error.HTTPError as exc:
            body = exc.read().decode("utf-8", errors="replace")
            return [], f"HTTP error {exc.code}: {body[:1000]}"
        except urllib.error.URLError as exc:
            return [], f"network error: {exc}"
        except Exception as exc:
            return [], f"request error: {exc}"

        try:
            parsed = json.loads(body)
        except json.JSONDecodeError as exc:
            return [], f"JSON parse error: {exc}"

        for item in parsed.get("models", []):
            name = item.get("name", "")
            model_id = normalize_model_id(name)
            methods = item.get("supportedGenerationMethods", []) or []

            # The chat interface needs models that can generate content.
            if "generateContent" not in methods:
                continue

            models.append(
                GeminiModel(
                    model_id=model_id,
                    display_name=item.get("displayName") or model_id,
                    methods=methods,
                    description=item.get("description", ""),
                )
            )

        page_token = parsed.get("nextPageToken", "")
        if not page_token:
            break

    models.sort(key=lambda m: m.model_id)
    return models, ""


def call_gemini(cfg: Config, prompt_text: str) -> str:
    url = (
        "https://generativelanguage.googleapis.com/v1beta/models/"
        f"{normalize_model_id(cfg.model)}:generateContent?key={urllib.parse.quote(cfg.api_key)}"
    )

    payload = {
        "contents": [
            {
                "parts": [
                    {
                        "text": prompt_text,
                    }
                ]
            }
        ]
    }

    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=120) as response:
            body = response.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        return f"(Gemini HTTP error {exc.code}: {body[:1000]})"
    except urllib.error.URLError as exc:
        return f"(Gemini network error: {exc})"
    except Exception as exc:
        return f"(Gemini request error: {exc})"

    try:
        parsed = json.loads(body)
        return parsed["candidates"][0]["content"]["parts"][0]["text"]
    except Exception as exc:
        return f"(Gemini response parse error: {exc}; raw response: {body[:1000]})"


# ---------------------------------------------------------------------------
# Session log parsing and writing
# ---------------------------------------------------------------------------
# Logs remain plain text. Resuming a session rebuilds recent memory from the
# log instead of requiring a separate state database.
# ---------------------------------------------------------------------------


ENTRY_RE = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] ([^:]+): (.*)$")


@dataclass
class LogEntry:
    speaker: str
    text: str


def append_log(path: Path, speaker: str, text: str, timestamp: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(f"[{timestamp}] {speaker}: {text}\n")


def load_log_entries(path: Path) -> List[LogEntry]:
    if not path.exists():
        return []

    entries: List[LogEntry] = []
    current_speaker: Optional[str] = None
    current_lines: List[str] = []

    with path.open("r", encoding="utf-8", errors="replace") as fh:
        for line in fh:
            line = line.rstrip("\n")
            match = ENTRY_RE.match(line)
            if match:
                if current_speaker is not None:
                    entries.append(LogEntry(current_speaker, "\n".join(current_lines)))
                current_speaker = match.group(2)
                current_lines = [match.group(3)]
            else:
                if current_speaker is not None:
                    current_lines.append(line)

    if current_speaker is not None:
        entries.append(LogEntry(current_speaker, "\n".join(current_lines)))

    return entries


# ---------------------------------------------------------------------------
# Attachment extraction
# ---------------------------------------------------------------------------
# Fenced markdown code blocks are saved to files and replaced in transcript
# display with attachment notices. Raw Gemini output is still written to the
# log before extraction, so logs preserve the complete response.
# ---------------------------------------------------------------------------


EXT_MAP = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "py": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "c": ".c",
    "cpp": ".cpp",
    "c++": ".cpp",
    "text": ".txt",
}

FENCE_RE = re.compile(r"```([A-Za-z0-9_+.#-]*)[ \t]*\n(.*?)```", re.DOTALL)


def safe_attachment_tag(lang: str) -> str:
    lang = lang.strip().lower() or "text"
    lang = lang.replace("+", "p").replace("#", "sharp")
    lang = re.sub(r"[^A-Za-z0-9._-]+", "_", lang)
    return lang or "text"


def next_attachment_number(attachment_dir: Path, session_name: str, lang: str, ext: str) -> int:
    pattern = re.compile(
        rf"^{re.escape(session_name)}-{re.escape(lang)}-(\d{{2,}}){re.escape(ext)}$"
    )
    highest = 0
    for path in attachment_dir.glob(f"{session_name}-{lang}-*{ext}"):
        match = pattern.match(path.name)
        if match:
            highest = max(highest, int(match.group(1)))
    return highest + 1


def extract_attachments(text: str, attachment_dir: Path, session_name: str) -> str:
    attachment_dir.mkdir(parents=True, exist_ok=True)

    def replacement(match: re.Match[str]) -> str:
        raw_lang = match.group(1).strip().lower() or "text"
        lang = safe_attachment_tag(raw_lang)
        content = match.group(2)
        ext = EXT_MAP.get(raw_lang, EXT_MAP.get(lang, ".txt"))
        number = next_attachment_number(attachment_dir, session_name, lang, ext)
        filename = f"{session_name}-{lang}-{number:02d}{ext}"
        path = attachment_dir / filename

        with path.open("w", encoding="utf-8") as fh:
            fh.write(content)

        return (
            "\n"
            "[attachment saved]\n"
            f"file: {filename}\n"
            f"location: {attachment_dir}\n"
        )

    return FENCE_RE.sub(replacement, text)


# ---------------------------------------------------------------------------
# Text wrapping helpers
# ---------------------------------------------------------------------------
# Curses does not automatically handle safe wrapping and bounds checking in a
# way that is appropriate for a custom interface. These helpers centralize the
# wrapping logic.
# ---------------------------------------------------------------------------


def wrap_for_width(text: str, width: int) -> List[str]:
    width = max(1, width)
    result: List[str] = []
    for paragraph in text.splitlines() or [""]:
        if paragraph == "":
            result.append("")
        else:
            result.extend(
                textwrap.wrap(
                    paragraph,
                    width=width,
                    replace_whitespace=False,
                    drop_whitespace=False,
                    break_long_words=True,
                    break_on_hyphens=False,
                )
            )
    return result or [""]


def now_time() -> str:
    return datetime.now().strftime("%H:%M:%S")


# ---------------------------------------------------------------------------
# Curses application
# ---------------------------------------------------------------------------
# This TUI focuses on solving the Bash version's known input problems:
# cursor movement, screen redraw, multiline text, wrapped text, and safe JSON
# request construction.
# ---------------------------------------------------------------------------


@dataclass
class TranscriptItem:
    speaker: str
    text: str
    timestamp: str = field(default_factory=now_time)


class GeminiCursesApp:
    INPUT_HEIGHT = 6

    def __init__(self, cfg: Config, session_name: str, session_path: Path):
        self.cfg = cfg
        self.session_name = session_name
        self.session_path = session_path
        self.attachment_dir = cfg.effective_attachment_dir
        self.username = os.environ.get("USER") or os.environ.get("LOGNAME") or "user"

        self.history: List[str] = []
        self.transcript: List[TranscriptItem] = []
        self.transcript_scroll = 0

        self.input_lines: List[str] = [""]
        self.cursor_row = 0
        self.cursor_col = 0
        self.input_visual_scroll = 0

        self.status = "Enter=newline | Ctrl+G/F5=send | F2=models | F3=API key | F10/Ctrl+Q=quit"
        self.should_quit = False

    # ------------------------------------------------------------------
    # Memory model
    # ------------------------------------------------------------------

    def load_memory_from_session(self) -> None:
        entries = load_log_entries(self.session_path)
        if not entries:
            return

        for entry in entries[-self.cfg.history_limit :]:
            if entry.speaker == "Gemini":
                self.history.append("Assistant: " + entry.text)
            else:
                self.history.append("User: " + entry.text)

        self.trim_history()
        self.transcript.append(
            TranscriptItem("system", f"Loaded memory from session: {self.session_name}")
        )

    def trim_history(self) -> None:
        if len(self.history) > self.cfg.history_limit:
            self.history = self.history[-self.cfg.history_limit :]

    def build_context(self) -> str:
        return "\n".join(self.history)

    # ------------------------------------------------------------------
    # Safe drawing primitives
    # ------------------------------------------------------------------

    def safe_addstr(self, y: int, x: int, text: str, max_width: Optional[int] = None, attr: int = 0) -> None:
        height, width = self.stdscr.getmaxyx()
        if y < 0 or y >= height or x < 0 or x >= width:
            return
        limit = width - x
        if max_width is not None:
            limit = min(limit, max_width)
        if limit <= 0:
            return
        try:
            self.stdscr.addstr(y, x, text[: max(0, limit - 1)], attr)
        except curses.error:
            pass

    def draw_box(self, top: int, left: int, height: int, width: int, title: str = "") -> None:
        if height < 3 or width < 10:
            return
        horizontal = "-" * max(0, width - 2)
        self.safe_addstr(top, left, "+" + horizontal + "+")
        for row in range(1, height - 1):
            self.safe_addstr(top + row, left, "|")
            self.safe_addstr(top + row, left + width - 1, "|")
        self.safe_addstr(top + height - 1, left, "+" + horizontal + "+")
        if title:
            self.safe_addstr(top, left + 2, f" {title} ", width - 4, curses.A_REVERSE)

    # ------------------------------------------------------------------
    # General modal helpers
    # ------------------------------------------------------------------

    def modal_geometry(self, desired_h: int = 14, desired_w: int = 72) -> Tuple[int, int, int, int]:
        screen_h, screen_w = self.stdscr.getmaxyx()
        h = min(desired_h, max(5, screen_h - 2))
        w = min(desired_w, max(30, screen_w - 2))
        top = max(0, (screen_h - h) // 2)
        left = max(0, (screen_w - w) // 2)
        return top, left, h, w

    def message_modal(self, title: str, message: str) -> None:
        top, left, h, w = self.modal_geometry(12, 76)
        self.draw()
        self.draw_box(top, left, h, w, title)
        lines = wrap_for_width(message, w - 4)
        for idx, line in enumerate(lines[: h - 4]):
            self.safe_addstr(top + 2 + idx, left + 2, line, w - 4)
        self.safe_addstr(top + h - 2, left + 2, "Press any key to continue", w - 4, curses.A_REVERSE)
        self.stdscr.refresh()
        self.stdscr.getch()

    def yes_no_modal(self, title: str, message: str, default: bool = False) -> bool:
        top, left, h, w = self.modal_geometry(10, 72)
        while True:
            self.draw()
            self.draw_box(top, left, h, w, title)
            lines = wrap_for_width(message, w - 4)
            for idx, line in enumerate(lines[: h - 4]):
                self.safe_addstr(top + 2 + idx, left + 2, line, w - 4)
            prompt = "Y/N? " + ("[default: yes]" if default else "[default: no]")
            self.safe_addstr(top + h - 2, left + 2, prompt, w - 4, curses.A_REVERSE)
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if ch in (ord("y"), ord("Y")):
                return True
            if ch in (ord("n"), ord("N"), 27):
                return False
            if ch in (10, 13, curses.KEY_ENTER):
                return default

    def text_input_modal(self, title: str, prompt: str, secret: bool = False) -> Optional[str]:
        top, left, h, w = self.modal_geometry(11, 76)
        value = ""
        cursor = 0

        while True:
            self.draw()
            self.draw_box(top, left, h, w, title)
            for idx, line in enumerate(wrap_for_width(prompt, w - 4)[:3]):
                self.safe_addstr(top + 2 + idx, left + 2, line, w - 4)

            visible_value = "*" * len(value) if secret else value
            field_w = w - 6
            left_cut = max(0, len(visible_value) - field_w + 1)
            shown = visible_value[left_cut : left_cut + field_w]
            field_y = top + h - 4
            self.safe_addstr(field_y, left + 2, " " * (w - 4), w - 4, curses.A_REVERSE)
            self.safe_addstr(field_y, left + 2, shown, field_w, curses.A_REVERSE)
            self.safe_addstr(top + h - 2, left + 2, "Enter=accept | Esc=cancel | Backspace=edit", w - 4)

            try:
                self.stdscr.move(field_y, left + 2 + min(cursor - left_cut, field_w - 1))
            except curses.error:
                pass
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch in (10, 13, curses.KEY_ENTER):
                return value.strip()
            if ch == 27:
                return None
            if ch in (curses.KEY_BACKSPACE, 127, 8):
                if cursor > 0:
                    value = value[: cursor - 1] + value[cursor:]
                    cursor -= 1
            elif ch == curses.KEY_DC:
                if cursor < len(value):
                    value = value[:cursor] + value[cursor + 1 :]
            elif ch == curses.KEY_LEFT:
                cursor = max(0, cursor - 1)
            elif ch == curses.KEY_RIGHT:
                cursor = min(len(value), cursor + 1)
            elif 32 <= ch <= 126:
                value = value[:cursor] + chr(ch) + value[cursor:]
                cursor += 1

    # ------------------------------------------------------------------
    # API key setup and model selector
    # ------------------------------------------------------------------

    def prompt_api_key(self, required: bool = False) -> bool:
        title = "API Key Required" if required else "Set API Key"
        prompt = (
            "Paste your Gemini API key. It will be used for this session. "
            "You can optionally save it to ~/.config/gemini-cli/config."
        )
        key = self.text_input_modal(title, prompt, secret=True)
        if not key:
            self.status = "API key not set"
            return False

        self.cfg.api_key = key
        if self.yes_no_modal(
            "Save API Key",
            "Save GEMINI_API_KEY to the config file? This is convenient but stores the key in plaintext.",
            default=False,
        ):
            set_config_value(self.cfg, "GEMINI_API_KEY", key)
            self.status = "API key saved to config"
        else:
            self.status = "API key active for this run only"
        return True

    def ensure_api_key(self) -> bool:
        if self.cfg.api_key:
            return True
        return self.prompt_api_key(required=True)

    def model_selector(self) -> None:
        if not self.ensure_api_key():
            return

        self.status = "Fetching model list..."
        self.draw()
        models, error = fetch_gemini_models(self.cfg)
        if error:
            self.message_modal("Model List Error", error)
            self.status = "model list failed"
            return
        if not models:
            self.message_modal("Model List", "No generateContent-compatible models were returned.")
            self.status = "no models returned"
            return

        selected = self.model_menu(models)
        if selected is None:
            self.status = "model selection cancelled"
            return

        old_model = self.cfg.model
        self.cfg.model = selected.model_id
        self.transcript.append(
            TranscriptItem("system", f"Model changed: {old_model} -> {self.cfg.model}")
        )
        self.status = f"model activated: {self.cfg.model}"

        if self.yes_no_modal(
            "Save Model",
            f"Save MODEL={self.cfg.model} to the config file?",
            default=True,
        ):
            set_config_value(self.cfg, "MODEL", self.cfg.model)
            self.status = f"model activated and saved: {self.cfg.model}"

    def model_menu(self, models: List[GeminiModel]) -> Optional[GeminiModel]:
        index = 0
        scroll = 0

        while True:
            self.draw()
            top, left, h, w = self.modal_geometry(20, 86)
            self.draw_box(top, left, h, w, "Model Selector")
            self.safe_addstr(top + 1, left + 2, "Up/Down=move | Enter=activate | Esc=cancel", w - 4)

            list_h = h - 5
            if index < scroll:
                scroll = index
            elif index >= scroll + list_h:
                scroll = index - list_h + 1

            visible = models[scroll : scroll + list_h]
            for offset, model in enumerate(visible):
                row = top + 3 + offset
                marker = "*" if model.model_id == self.cfg.model else " "
                line = f"{marker} {model.model_id}"
                attr = curses.A_REVERSE if scroll + offset == index else 0
                self.safe_addstr(row, left + 2, line, w - 4, attr)

            footer = f"{index + 1}/{len(models)}"
            self.safe_addstr(top + h - 2, left + 2, footer, w - 4)
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch in (27, ord("q"), ord("Q")):
                return None
            if ch in (10, 13, curses.KEY_ENTER):
                return models[index]
            if ch == curses.KEY_UP:
                index = max(0, index - 1)
            elif ch == curses.KEY_DOWN:
                index = min(len(models) - 1, index + 1)
            elif ch == curses.KEY_PPAGE:
                index = max(0, index - list_h)
            elif ch == curses.KEY_NPAGE:
                index = min(len(models) - 1, index + list_h)
            elif ch == curses.KEY_HOME:
                index = 0
            elif ch == curses.KEY_END:
                index = len(models) - 1

    # ------------------------------------------------------------------
    # Curses drawing
    # ------------------------------------------------------------------

    def transcript_display_lines(self, width: int) -> List[str]:
        lines: List[str] = []
        for item in self.transcript:
            prefix = f"[{item.timestamp}] {item.speaker}: "
            wrapped = wrap_for_width(prefix + item.text, width)
            lines.extend(wrapped)
            lines.append("")
        return lines

    def draw_header(self, width: int) -> None:
        header = f"{PROGRAM} | session: {self.session_name} | model: {self.cfg.model}"
        self.safe_addstr(0, 0, header, width)
        self.safe_addstr(1, 0, "_" * width, width)

    def draw_transcript(self, start_y: int, height: int, width: int) -> None:
        lines = self.transcript_display_lines(width)
        max_scroll = max(0, len(lines) - height)
        self.transcript_scroll = min(self.transcript_scroll, max_scroll)
        start = max(0, len(lines) - height - self.transcript_scroll)
        visible = lines[start : start + height]

        for offset in range(height):
            y = start_y + offset
            if offset < len(visible):
                self.safe_addstr(y, 0, visible[offset], width)

    def input_segments(self, width: int) -> Tuple[List[Tuple[int, int, str]], int]:
        # Visual wrapping is handled by curses, not by the terminal emulator.
        # This avoids the old Bash problem where the cursor appeared stuck at
        # the left edge of a wrapped line.
        available = max(1, width - 2)
        segments: List[Tuple[int, int, str]] = []
        cursor_segment = 0

        for logical_row, line in enumerate(self.input_lines):
            if not line:
                start_index = len(segments)
                segments.append((logical_row, 0, ""))
                if logical_row == self.cursor_row:
                    cursor_segment = start_index
                continue

            starts = list(range(0, len(line), available))
            if logical_row == self.cursor_row and self.cursor_col == len(line) and len(line) % available == 0:
                starts.append(len(line))

            for start in starts:
                chunk = line[start : start + available]
                segment_index = len(segments)
                segments.append((logical_row, start, chunk))
                if logical_row == self.cursor_row:
                    if start <= self.cursor_col <= start + len(chunk):
                        cursor_segment = segment_index

        return segments, cursor_segment

    def draw_input(self, label_y: int, input_y: int, width: int) -> None:
        label = "INPUT: Enter=newline | Ctrl+G/F5=send | F2=models | F3=API key | F10/Ctrl+Q=quit"
        self.safe_addstr(label_y, 0, "_" * width, width)
        self.safe_addstr(label_y, 0, label, width)

        segments, cursor_segment = self.input_segments(width)
        if cursor_segment < self.input_visual_scroll:
            self.input_visual_scroll = cursor_segment
        elif cursor_segment >= self.input_visual_scroll + self.INPUT_HEIGHT:
            self.input_visual_scroll = cursor_segment - self.INPUT_HEIGHT + 1

        self.input_visual_scroll = max(0, min(self.input_visual_scroll, max(0, len(segments) - self.INPUT_HEIGHT)))
        visible = segments[self.input_visual_scroll : self.input_visual_scroll + self.INPUT_HEIGHT]

        cursor_y = 0
        cursor_x = 2

        for offset in range(self.INPUT_HEIGHT):
            y = input_y + offset
            if offset >= len(visible):
                continue
            logical_row, start, chunk = visible[offset]
            marker = "> " if logical_row == 0 and start == 0 else "  "
            self.safe_addstr(y, 0, marker + chunk, width)
            absolute_index = self.input_visual_scroll + offset
            if absolute_index == cursor_segment:
                cursor_y = offset
                cursor_x = 2 + max(0, self.cursor_col - start)

        try:
            curses.curs_set(1)
            self.stdscr.move(input_y + cursor_y, min(cursor_x, width - 2))
        except curses.error:
            pass

    def draw_status(self, y: int, width: int) -> None:
        self.safe_addstr(y, 0, "_" * width, width)
        self.safe_addstr(y, 0, self.status, width)

    def draw(self) -> None:
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()

        min_height = self.INPUT_HEIGHT + 6
        if height < min_height or width < 40:
            self.safe_addstr(0, 0, "terminal too small", width)
            self.stdscr.refresh()
            return

        header_h = 2
        status_h = 1
        input_label_h = 1
        transcript_h = height - header_h - input_label_h - self.INPUT_HEIGHT - status_h
        transcript_y = header_h
        input_label_y = transcript_y + transcript_h
        input_y = input_label_y + input_label_h
        status_y = height - 1

        self.draw_header(width)
        self.draw_transcript(transcript_y, transcript_h, width)
        self.draw_input(input_label_y, input_y, width)
        self.draw_status(status_y, width)
        self.stdscr.refresh()

    # ------------------------------------------------------------------
    # Input editing
    # ------------------------------------------------------------------

    def insert_text(self, text: str) -> None:
        line = self.input_lines[self.cursor_row]
        self.input_lines[self.cursor_row] = line[: self.cursor_col] + text + line[self.cursor_col :]
        self.cursor_col += len(text)

    def insert_newline(self) -> None:
        line = self.input_lines[self.cursor_row]
        before = line[: self.cursor_col]
        after = line[self.cursor_col :]
        self.input_lines[self.cursor_row] = before
        self.input_lines.insert(self.cursor_row + 1, after)
        self.cursor_row += 1
        self.cursor_col = 0

    def backspace(self) -> None:
        if self.cursor_col > 0:
            line = self.input_lines[self.cursor_row]
            self.input_lines[self.cursor_row] = line[: self.cursor_col - 1] + line[self.cursor_col :]
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            previous_len = len(self.input_lines[self.cursor_row - 1])
            self.input_lines[self.cursor_row - 1] += self.input_lines[self.cursor_row]
            del self.input_lines[self.cursor_row]
            self.cursor_row -= 1
            self.cursor_col = previous_len

    def delete_forward(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.input_lines[self.cursor_row] = line[: self.cursor_col] + line[self.cursor_col + 1 :]
        elif self.cursor_row < len(self.input_lines) - 1:
            self.input_lines[self.cursor_row] += self.input_lines[self.cursor_row + 1]
            del self.input_lines[self.cursor_row + 1]

    def move_left(self) -> None:
        if self.cursor_col > 0:
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = len(self.input_lines[self.cursor_row])

    def move_right(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.cursor_col += 1
        elif self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = 0

    def move_up(self) -> None:
        if self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def move_down(self) -> None:
        if self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def clear_input(self) -> None:
        self.input_lines = [""]
        self.cursor_row = 0
        self.cursor_col = 0
        self.input_visual_scroll = 0

    def current_input(self) -> str:
        return "\n".join(self.input_lines).strip("\n")

    # ------------------------------------------------------------------
    # Sending messages
    # ------------------------------------------------------------------

    def send_current_message(self) -> None:
        if not self.ensure_api_key():
            return

        message = self.current_input()
        if not message.strip():
            self.status = "empty message ignored"
            self.clear_input()
            return

        user_time = now_time()
        self.transcript.append(TranscriptItem(self.username, message, user_time))
        append_log(self.session_path, self.username, message, user_time)
        self.clear_input()
        self.transcript_scroll = 0

        self.status = "Generating response..."
        self.draw()

        context = self.build_context()
        prompt_text = (context + "\n" if context else "") + "User: " + message
        raw_output = call_gemini(self.cfg, prompt_text)

        gemini_time = now_time()
        append_log(self.session_path, "Gemini", raw_output, gemini_time)
        cleaned_output = extract_attachments(raw_output, self.attachment_dir, self.session_name)

        self.history.append("User: " + message)
        self.history.append("Assistant: " + cleaned_output)
        self.trim_history()

        self.transcript.append(TranscriptItem("Gemini", cleaned_output, gemini_time))
        self.status = "response complete"
        self.transcript_scroll = 0

    # ------------------------------------------------------------------
    # Main event loop
    # ------------------------------------------------------------------

    def handle_key(self, ch: int) -> None:
        if ch in (curses.KEY_F10, 17):  # F10 or Ctrl+Q
            self.should_quit = True
            return

        if ch == curses.KEY_F2:
            self.model_selector()
            return

        if ch == curses.KEY_F3:
            self.prompt_api_key(required=False)
            return

        if ch in (curses.KEY_F5, 7):  # F5 or Ctrl+G
            self.send_current_message()
            return

        if ch in (10, 13, curses.KEY_ENTER):
            self.insert_newline()
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            self.backspace()
        elif ch == curses.KEY_DC:
            self.delete_forward()
        elif ch == curses.KEY_LEFT:
            self.move_left()
        elif ch == curses.KEY_RIGHT:
            self.move_right()
        elif ch == curses.KEY_UP:
            self.move_up()
        elif ch == curses.KEY_DOWN:
            self.move_down()
        elif ch == curses.KEY_HOME:
            self.cursor_col = 0
        elif ch == curses.KEY_END:
            self.cursor_col = len(self.input_lines[self.cursor_row])
        elif ch == curses.KEY_PPAGE:
            self.transcript_scroll += 10
        elif ch == curses.KEY_NPAGE:
            self.transcript_scroll = max(0, self.transcript_scroll - 10)
        elif ch == 21:  # Ctrl+U clears current input
            self.clear_input()
        elif ch == 12:  # Ctrl+L redraws on next loop
            pass
        elif ch == 9:  # Tab inserts four spaces
            self.insert_text("    ")
        elif 32 <= ch <= 126:
            self.insert_text(chr(ch))

    def run(self, stdscr: curses.window) -> None:
        self.stdscr = stdscr
        curses.noecho()
        curses.cbreak()
        stdscr.keypad(True)

        self.load_memory_from_session()

        if not self.cfg.api_key:
            self.draw()
            if not self.prompt_api_key(required=True):
                self.should_quit = True

        while not self.should_quit:
            self.draw()
            try:
                ch = stdscr.getch()
            except KeyboardInterrupt:
                break
            self.handle_key(ch)


# ---------------------------------------------------------------------------
# Program entry point
# ---------------------------------------------------------------------------


def main() -> int:
    args = parse_args()

    if args.version:
        print(f"{PROGRAM} version {VERSION}")
        return 0

    cfg = load_config()
    session_dir = cfg.session_dir
    attachment_dir = cfg.effective_attachment_dir
    session_dir.mkdir(parents=True, exist_ok=True)
    attachment_dir.mkdir(parents=True, exist_ok=True)

    if args.list:
        list_sessions(session_dir)
        return 0

    if args.models:
        if not cfg.api_key:
            print("ERROR: GEMINI_API_KEY not set", file=sys.stderr)
            print("Set it in the environment or ~/.config/gemini-cli/config", file=sys.stderr)
            return 1
        models, error = fetch_gemini_models(cfg)
        if error:
            print(f"ERROR: {error}", file=sys.stderr)
            return 1
        for model in models:
            print(model.model_id)
        return 0

    if args.resume and args.session_name:
        print("error: use either a session name or --resume, not both", file=sys.stderr)
        return 2

    if args.resume:
        session_name = sanitize_session_name(args.resume)
        session_path = session_dir / f"{session_name}.log"
        if not session_path.exists():
            print(f"error: session not found: {session_name}", file=sys.stderr)
            return 1
    elif args.session_name:
        session_name = sanitize_session_name(args.session_name)
        session_path = session_dir / f"{session_name}.log"
    else:
        session_name = default_session_name()
        session_path = session_dir / f"{session_name}.log"

    app = GeminiCursesApp(cfg, session_name, session_path)

    try:
        curses.wrapper(app.run)
    except KeyboardInterrupt:
        return 0

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
