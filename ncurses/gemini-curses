    def open_api_key_manager(self) -> None:
        choices = [
            "Paste API key for this session only",
            "Paste API key and save to config",
            "Forget runtime API key",
            "Remove GEMINI_API_KEY from config",
        ]
        idx = self.select_menu("API KEY", choices)
        if idx is None:
            return
        if idx in (0, 1):
            key = self.text_input_modal("API KEY INPUT", "Paste Gemini API key.", secret=True)
            if not key:
                self.status = "API key entry cancelled"
                return
            self.cfg.api_key = key
            if idx == 1:
                set_config_value(self.cfg, "GEMINI_API_KEY", key)
                self.status = "API key saved to config"
            else:
                self.status = "API key active for this session only"
        elif idx == 2:
            self.cfg.api_key = ""
            self.status = "runtime API key forgotten"
        elif idx == 3:
            delete_config_value(self.cfg, "GEMINI_API_KEY")
            self.status = "GEMINI_API_KEY removed from config"

