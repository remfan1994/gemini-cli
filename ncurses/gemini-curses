# ---------------------------------------------------------------------------
# Configuration model
# ---------------------------------------------------------------------------
# The ncurses edition intentionally uses the same config file as the Bash
# edition. A user can keep one ~/.config/gemini-cli/config file and use either
# interface.
#
# Model discovery note:
#   Users can list available Gemini models with the Gemini API models endpoint:
#     curl "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_API_KEY"
#   This program also exposes that through --models and the in-app F2 selector.
#
# Model testing note:
#   Autoscan has been removed. The safer workflow is user-operated testing:
#   select one model, send one clearly documented test request, read the raw
#   response, then activate/save the model only if the user accepts it.
#
# Memory terminology note:
#   CONTEXT_TURNS is the preferred config key. It means recent user/assistant
#   exchanges sent back to Gemini for conversational continuity. HISTORY_LIMIT
#   is still accepted as a legacy alias so older configs do not break.
# ---------------------------------------------------------------------------


@dataclass
class Config:
    model: str = ""
    context_turns: int = 12
    api_key: str = ""
    session_dir: Path = field(default_factory=lambda: Path.home() / ".gpt")
    attachment_dir: Optional[Path] = None
    editor: str = ""
    model_test_prompt: str = DEFAULT_MODEL_TEST_PROMPT
    max_attachment_bytes: int = DEFAULT_MAX_ATTACHMENT_BYTES
    config_file: Path = field(
        default_factory=lambda: Path.home() / ".config" / "gemini-cli" / "config"
    )

    @property
    def effective_model(self) -> str:
        return self.model or FALLBACK_MODEL

    @property
    def effective_attachment_dir(self) -> Path:
        if self.attachment_dir is not None:
            return self.attachment_dir
        return self.session_dir / "attachments"

    @property
    def effective_editor(self) -> str:
        if self.editor:
            return self.editor
        return os.environ.get("VISUAL") or os.environ.get("EDITOR") or ""


def expand_path(value: str) -> Path:
    return Path(os.path.expandvars(os.path.expanduser(value))).resolve()


def normalize_model_id(model: str) -> str:
    model = model.strip()
    if model.startswith("models/"):
        return model.split("/", 1)[1]
    return model


def parse_positive_int(value: str, fallback: int) -> int:
    try:
        parsed = int(value)
    except ValueError:
        return fallback
    return max(1, parsed)


def load_config() -> Config:
    cfg = Config()
    env_api_key = os.environ.get("GEMINI_API_KEY", "")
    context_turns_explicit = False

    if cfg.config_file.exists():
        with cfg.config_file.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()
                if not line or line.startswith("#"):
                    continue
                if "=" not in line:
                    continue

                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip()

                if key == "MODEL":
                    cfg.model = normalize_model_id(value)
                elif key == "CONTEXT_TURNS":
                    cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                    context_turns_explicit = True
                elif key == "HISTORY_LIMIT":
                    if not context_turns_explicit:
                        cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                elif key == "GEMINI_API_KEY":
                    cfg.api_key = env_api_key or value
                elif key == "SESSION_DIR":
                    cfg.session_dir = expand_path(value)
                elif key == "ATTACHMENT_DIR":
                    cfg.attachment_dir = expand_path(value)
                elif key == "EDITOR":
                    cfg.editor = value
                elif key == "MODEL_TEST_PROMPT":
                    if value:
                        cfg.model_test_prompt = value
                elif key == "MAX_ATTACHMENT_BYTES":
                    cfg.max_attachment_bytes = parse_positive_int(value, cfg.max_attachment_bytes)

    if env_api_key:
        cfg.api_key = env_api_key

    return cfg


def set_config_value(cfg: Config, key: str, value: str) -> None:
    cfg.config_file.parent.mkdir(parents=True, exist_ok=True)
    lines: List[str] = []
    replaced = False

    if cfg.config_file.exists():
        lines = cfg.config_file.read_text(encoding="utf-8", errors="replace").splitlines()

    new_lines: List[str] = []
    for line in lines:
        if line.strip().startswith(f"{key}="):
            new_lines.append(f"{key}={value}")
            replaced = True
        else:
            new_lines.append(line)

    if not replaced:
        new_lines.append(f"{key}={value}")

    cfg.config_file.write_text("\n".join(new_lines) + "\n", encoding="utf-8")
    try:
        os.chmod(cfg.config_file, 0o600)
    except OSError:
        pass


def delete_config_value(cfg: Config, key: str) -> None:
    if not cfg.config_file.exists():
        return

    lines = cfg.config_file.read_text(encoding="utf-8", errors="replace").splitlines()
    new_lines = [line for line in lines if not line.strip().startswith(f"{key}=")]
    cfg.config_file.write_text("\n".join(new_lines) + ("\n" if new_lines else ""), encoding="utf-8")
    try:
        os.chmod(cfg.config_file, 0o600)
    except OSError:
        pass


