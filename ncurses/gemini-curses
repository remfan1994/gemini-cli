    def open_model_selector(self) -> None:
        if not self.cfg.api_key:
            self.show_message("MODEL SELECTOR", ["No API key is loaded. Press F3 to paste an API key."])
            self.status = "model selector cancelled: no API key"
            return

        self.status = "loading model list..."
        self.draw()
        models, error = fetch_models(self.cfg)
        if error:
            self.show_message("MODEL LIST ERROR", wrap_for_width(error, 70))
            self.status = "model list failed"
            return
        if not models:
            self.show_message("MODEL SELECTOR", ["No generateContent models returned by the API."])
            return

        selected = 0
        current = normalize_model_id(self.cfg.effective_model)
        for idx, model in enumerate(models):
            if model.model_id == current:
                selected = idx
                break
        top_index = 0

        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 7)

            self.safe_addstr(0, 0, "MODEL SELECTOR", width, curses.A_REVERSE)
            self.safe_addstr(1, 0, f"Current model: {self.model_label()}", width, curses.A_DIM)
            self.safe_addstr(2, 0, "Enter=activate | t=test | s=save | i=info | q/Esc=cancel | click/dbl-click", width, curses.A_DIM)
            self.safe_addstr(3, 0, "_" * width, width, curses.A_DIM)

            if selected < top_index:
                top_index = selected
            elif selected >= top_index + visible_h:
                top_index = selected - visible_h + 1

            for row in range(visible_h):
                model_index = top_index + row
                if model_index >= len(models):
                    break
                model = models[model_index]
                limits = ""
                if model.input_token_limit or model.output_token_limit:
                    limits = f" in:{model.input_token_limit or '?'} out:{model.output_token_limit or '?'}"
                current_marker = "* " if model.model_id == current else "  "
                line = f"{current_marker}{model.model_id} - {model.display_name}{limits}"
                attr = curses.A_REVERSE if model_index == selected else 0
                self.safe_addstr(4 + row, 0, line, width, attr)

            self.safe_addstr(height - 2, 0, "_" * width, width, curses.A_DIM)
            self.safe_addstr(height - 1, 0, f"{selected + 1}/{len(models)}", width, curses.A_DIM)
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch == curses.KEY_MOUSE:
                try:
                    _mouse_id, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - MOUSE_SCROLL_LINES)
                    continue
                if delta < 0:
                    selected = min(len(models) - 1, selected + MOUSE_SCROLL_LINES)
                    continue
                if self.mouse_button1(state) and 4 <= y < 4 + visible_h:
                    idx = top_index + (y - 4)
                    if 0 <= idx < len(models):
                        selected = idx
                        if self.mouse_button1_double(state):
                            chosen = models[selected]
                            self.cfg.model = chosen.model_id
                            self.status = f"activated model: {chosen.model_id}"
                            self.transcript.append(TranscriptItem("system", f"Model activated: {chosen.model_id}"))
                            self.maybe_save_model_to_config()
                            return
                continue

            if ch in (27, ord("q"), ord("Q")):
                self.status = "model selection cancelled"
                return
            if ch in (ord("i"), ord("I")):
                self.show_model_info(models[selected])
                continue
            if ch in (ord("t"), ord("T")):
                self.test_model_dialog(models[selected])
                continue
            if ch in (ord("s"), ord("S")):
                set_config_value(self.cfg, "MODEL", models[selected].model_id)
                self.cfg.model = models[selected].model_id
                self.status = f"saved model: {self.cfg.model}"
                return
            if ch in (10, 13, curses.KEY_ENTER):
                chosen = models[selected]
                self.cfg.model = chosen.model_id
                self.status = f"activated model: {chosen.model_id}"
                self.transcript.append(TranscriptItem("system", f"Model activated: {chosen.model_id}"))
                self.maybe_save_model_to_config()
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN:
                selected = min(len(models) - 1, selected + 1)
            elif ch == curses.KEY_PPAGE:
                selected = max(0, selected - visible_h)
            elif ch == curses.KEY_NPAGE:
                selected = min(len(models) - 1, selected + visible_h)
            elif ch == curses.KEY_HOME:
                selected = 0
            elif ch == curses.KEY_END:
                selected = len(models) - 1

    def maybe_save_model_to_config(self) -> None:
        if self.cfg.model and self.ask_yes_no("SAVE MODEL", f"Save MODEL={self.cfg.model} to config?", default=True):
            set_config_value(self.cfg, "MODEL", self.cfg.model)
            self.status = f"model saved: {self.cfg.model}"

    def open_sessions_menu(self) -> None:
        while True:
            rows = ["Rename current session", "New timestamped session"]
            logs = sorted(self.cfg.session_dir.glob("*.log"))
            rows.extend([f"Open: {path.stem}" for path in logs])
            idx = self.select_menu("SESSIONS", rows, "Enter=select | q/Esc=cancel")
            if idx is None:
                return
            if idx == 0:
                self.rename_current_session()
                return
            if idx == 1:
                self.session_name = default_session_name()
                self.session_path = self.cfg.session_dir / f"{self.session_name}.log"
                self.transcript = []
                self.context_buffer = []
                self.status = f"new session: {self.session_name}"
                return
            path = logs[idx - 2]
            self.session_name = path.stem
            self.session_path = path
            self.load_session_into_ui()
            return

    def rename_current_session(self) -> None:
        new_name = self.text_input_modal("RENAME SESSION", "Enter new session name:", self.session_name)
        if not new_name:
            return
        new_name = sanitize_session_name(new_name)
        new_path = self.cfg.session_dir / f"{new_name}.log"
        if new_path.exists() and new_path != self.session_path:
            self.show_message("RENAME FAILED", [f"Target session already exists: {new_name}"])
            return
        if self.session_path.exists():
            self.session_path.rename(new_path)
        self.session_name = new_name
        self.session_path = new_path
        self.status = f"renamed session: {new_name}"

    def open_options_menu(self) -> None:
        while True:
            rows = [
                f"MODEL = {self.cfg.model or '(unset; fallback used)'}",
                f"CONTEXT_TURNS = {self.cfg.context_turns}",
                f"SESSION_DIR = {self.cfg.session_dir}",
                f"ATTACHMENT_DIR = {self.cfg.effective_attachment_dir}",
                f"EDITOR = {self.cfg.editor or '(VISUAL/EDITOR/default)'}",
                f"MODEL_TEST_PROMPT = {self.cfg.model_test_prompt}",
                f"MAX_ATTACHMENT_BYTES = {self.cfg.max_attachment_bytes}",
            ]
            idx = self.select_menu("OPTIONS", rows, "Enter=edit | q/Esc=cancel")
            if idx is None:
                return
            keys = ["MODEL", "CONTEXT_TURNS", "SESSION_DIR", "ATTACHMENT_DIR", "EDITOR", "MODEL_TEST_PROMPT", "MAX_ATTACHMENT_BYTES"]
            key = keys[idx]
            current = ""
            if key == "MODEL":
                current = self.cfg.model
            elif key == "CONTEXT_TURNS":
                current = str(self.cfg.context_turns)
            elif key == "SESSION_DIR":
                current = str(self.cfg.session_dir)
            elif key == "ATTACHMENT_DIR":
                current = str(self.cfg.effective_attachment_dir)
            elif key == "EDITOR":
                current = self.cfg.editor
            elif key == "MODEL_TEST_PROMPT":
                current = self.cfg.model_test_prompt
            elif key == "MAX_ATTACHMENT_BYTES":
                current = str(self.cfg.max_attachment_bytes)
            value = self.text_input_modal("EDIT OPTION", f"Set {key}:", current)
            if value is None:
                continue
            set_config_value(self.cfg, key, value)
            if key == "MODEL":
                self.cfg.model = normalize_model_id(value)
            elif key == "CONTEXT_TURNS":
                self.cfg.context_turns = parse_positive_int(value, self.cfg.context_turns)
            elif key == "SESSION_DIR":
                self.cfg.session_dir = expand_path(value)
            elif key == "ATTACHMENT_DIR":
                self.cfg.attachment_dir = expand_path(value)
                self.attachment_dir = self.cfg.effective_attachment_dir
            elif key == "EDITOR":
                self.cfg.editor = value
            elif key == "MODEL_TEST_PROMPT":
                self.cfg.model_test_prompt = value
            elif key == "MAX_ATTACHMENT_BYTES":
                self.cfg.max_attachment_bytes = parse_positive_int(value, self.cfg.max_attachment_bytes)
            self.status = f"option saved: {key}"

    def open_memory_menu(self) -> None:
        while True:
            rows = [
                "View current memory",
                "Edit current memory in external editor",
                "Clear current memory",
                "Rebuild memory from session log",
            ]
            idx = self.select_menu("MEMORY", rows)
            if idx is None:
                return
            if idx == 0:
                self.show_message("CURRENT MEMORY", self.context_buffer or ["(memory empty)"])
            elif idx == 1:
                self.edit_memory_external()
            elif idx == 2:
                if self.ask_yes_no("CLEAR MEMORY", "Clear current in-memory context?", default=False):
                    self.context_buffer = []
                    self.save_context_snapshot()
                    self.status = "memory cleared"
                    return
            elif idx == 3:
                self.load_session_into_ui()
                self.status = "memory rebuilt from log"
                return

    def edit_memory_external(self) -> None:
        text = "\n".join(self.context_buffer)
        edited = self.edit_text_external(text, suffix=".memory.txt")
        if edited is None:
            return
        self.context_buffer = [line for line in edited.splitlines() if line.strip()]
        self.trim_context_buffer()
        self.save_context_snapshot()
        self.status = "memory edited"

    def open_file_menu(self) -> None:
        while True:
            rows = [
                f"Attach file for next message ({len(self.pending_attachments)} pending)",
                "List pending attachments",
                "Clear pending attachments",
                "Browse saved generated/code attachments",
            ]
            idx = self.select_menu("FILES", rows)
            if idx is None:
                return
            if idx == 0:
                self.attach_file_browser(Path.cwd())
            elif idx == 1:
                if not self.pending_attachments:
                    self.show_message("PENDING ATTACHMENTS", ["No pending attachments."])
                else:
                    self.show_message(
                        "PENDING ATTACHMENTS",
                        [f"{att.path} ({att.mime_type}, {att.size} bytes, {att.mode})" for att in self.pending_attachments],
                    )
            elif idx == 2:
                self.pending_attachments = []
                self.status = "pending attachments cleared"
                return
            elif idx == 3:
                self.browse_attachment_dir()

    def file_rows(self, directory: Path) -> Tuple[List[str], List[Path]]:
        entries = []
        paths = []
        if directory.parent != directory:
            entries.append("../")
            paths.append(directory.parent)
        for path in sorted(directory.iterdir(), key=lambda p: (not p.is_dir(), p.name.lower())):
            suffix = "/" if path.is_dir() else ""
            entries.append(path.name + suffix)
            paths.append(path)
        return entries, paths

    def attach_file_browser(self, start: Path) -> None:
        current = start
        while True:
            try:
                rows, paths = self.file_rows(current)
            except Exception as exc:
                self.show_message("FILE BROWSER ERROR", [str(exc)])
                return
            idx = self.select_menu(f"ATTACH FILE: {current}", rows, "Enter=open/attach | q/Esc=cancel")
            if idx is None:
                return
            selected = paths[idx]
            if selected.is_dir():
                current = selected
                continue
            self.add_pending_attachment(selected)
            return

    def add_pending_attachment(self, path: Path) -> None:
        try:
            size = path.stat().st_size
        except OSError as exc:
            self.show_message("ATTACH FAILED", [str(exc)])
            return
        if size > self.cfg.max_attachment_bytes:
            self.show_message("ATTACH FAILED", [f"File too large: {size} bytes", f"Limit: {self.cfg.max_attachment_bytes} bytes"])
            return
        mime, _encoding = mimetypes.guess_type(str(path))
        mime = mime or "application/octet-stream"
        mode = "text" if mime.startswith("text/") or mime in ("application/json", "application/xml") else "inlineData"
        self.pending_attachments.append(PendingAttachment(path, mime, mode, size))
        self.status = f"attached for next message: {path.name}"

    def browse_attachment_dir(self) -> None:
        rows = []
        paths = []
        for path in sorted(self.attachment_dir.glob("*")):
            if path.is_file():
                rows.append(path.name)
                paths.append(path)
        idx = self.select_menu("SAVED ATTACHMENTS", rows, "Enter=view text-ish file | q/Esc=cancel")
        if idx is None:
            return
        path = paths[idx]
        try:
            if path.stat().st_size > 200000:
                self.show_message("ATTACHMENT", [f"File: {path}", "Too large to preview in dialog."])
                return
            text = path.read_text(encoding="utf-8", errors="replace")
            self.show_message(path.name, text.splitlines() or [""])
        except Exception as exc:
            self.show_message("ATTACHMENT", [f"File: {path}", str(exc)])

    def edit_text_external(self, initial_text: str, suffix: str = ".txt") -> Optional[str]:
        editor = self.cfg.effective_editor or shutil.which("nano") or shutil.which("vi")
        if not editor:
            self.show_message("EDITOR", ["No editor found. Set EDITOR in config or VISUAL/EDITOR in environment."])
            return None
        with tempfile.NamedTemporaryFile("w+", suffix=suffix, delete=False, encoding="utf-8") as tmp:
            tmp.write(initial_text)
            tmp_path = tmp.name
        try:
            curses.def_prog_mode()
            curses.endwin()
            subprocess.run([editor, tmp_path])
            curses.reset_prog_mode()
            self.stdscr.keypad(True)
            with open(tmp_path, "r", encoding="utf-8", errors="replace") as fh:
                return fh.read()
        finally:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass

    def open_external_editor_for_input(self) -> None:
        edited = self.edit_text_external(self.current_input(), suffix=".prompt.txt")
        if edited is None:
            return
        self.input_lines = edited.rstrip("\n").split("\n") or [""]
        self.cursor_row = len(self.input_lines) - 1
        self.cursor_col = len(self.input_lines[self.cursor_row])
        self.status = "input loaded from editor"

    # ---------------------------------------------------------------------
    # Input editing
    # ---------------------------------------------------------------------

    def insert_text(self, text: str) -> None:
        line = self.input_lines[self.cursor_row]
        self.input_lines[self.cursor_row] = line[: self.cursor_col] + text + line[self.cursor_col :]
        self.cursor_col += len(text)

    def insert_newline(self) -> None:
        line = self.input_lines[self.cursor_row]
        before = line[: self.cursor_col]
        after = line[self.cursor_col :]
        self.input_lines[self.cursor_row] = before
        self.input_lines.insert(self.cursor_row + 1, after)
        self.cursor_row += 1
        self.cursor_col = 0

    def backspace(self) -> None:
        if self.cursor_col > 0:
            line = self.input_lines[self.cursor_row]
            self.input_lines[self.cursor_row] = line[: self.cursor_col - 1] + line[self.cursor_col :]
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            previous_len = len(self.input_lines[self.cursor_row - 1])
            self.input_lines[self.cursor_row - 1] += self.input_lines[self.cursor_row]
            del self.input_lines[self.cursor_row]
            self.cursor_row -= 1
            self.cursor_col = previous_len

    def delete_forward(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.input_lines[self.cursor_row] = line[: self.cursor_col] + line[self.cursor_col + 1 :]
        elif self.cursor_row < len(self.input_lines) - 1:
            self.input_lines[self.cursor_row] += self.input_lines[self.cursor_row + 1]
            del self.input_lines[self.cursor_row + 1]

    def move_left(self) -> None:
        if self.cursor_col > 0:
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = len(self.input_lines[self.cursor_row])

    def move_right(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.cursor_col += 1
        elif self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = 0

    def move_up(self) -> None:
        if self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def move_down(self) -> None:
        if self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def clear_input(self) -> None:
        self.input_lines = [""]
        self.cursor_row = 0
        self.cursor_col = 0
        self.input_scroll = 0

    def current_input(self) -> str:
        return "\n".join(self.input_lines).strip("\n")

    # ---------------------------------------------------------------------
    # Sending messages
    # ---------------------------------------------------------------------

    def send_current_message(self) -> None:
        message = self.current_input()
        if not message.strip() and not self.pending_attachments:
            self.status = "empty message ignored"
            self.clear_input()
            return

        user_time = now_time()
        attachment_note = ""
        if self.pending_attachments:
            attachment_note = "\n" + "\n".join(f"[attached] {att.path} ({att.mime_type}, {att.size} bytes)" for att in self.pending_attachments)
        self.transcript.append(TranscriptItem(self.username, message + attachment_note, user_time))
        append_log(self.session_path, self.username, message + attachment_note, user_time)
        self.clear_input()
        self.transcript_scroll = 0

        self.status = "Generating response..."
        self.draw()

        context = self.build_context()
        prompt_text = (context + "\n" if context else "") + "User: " + message
        raw_output = call_gemini(self.cfg, prompt_text, self.pending_attachments, self.attachment_dir, self.session_name)
        self.pending_attachments = []

        gemini_time = now_time()
        append_log(self.session_path, "Gemini", raw_output, gemini_time)
        cleaned_output = extract_attachments(raw_output, self.attachment_dir, self.session_name)

        self.context_buffer.append("User: " + message + attachment_note)
        self.context_buffer.append("Assistant: " + cleaned_output)
        self.trim_context_buffer()
        self.save_context_snapshot()

        self.transcript.append(TranscriptItem("Gemini", cleaned_output, gemini_time))
        self.status = "response complete"
        self.transcript_scroll = 0

    # ---------------------------------------------------------------------
    # Main event loop
    # ---------------------------------------------------------------------

    def handle_key(self, ch: int) -> None:
        if ch == curses.KEY_MOUSE:
            self.handle_mouse()
            return
        if ch in (curses.KEY_F10, 17):
            self.should_quit = True
            return
        if ch == curses.KEY_F1:
            self.show_help()
            return
        if ch == curses.KEY_F2:
            self.open_model_selector()
            return
        if ch == curses.KEY_F3:
            self.open_api_key_manager()
            return
        if ch == curses.KEY_F4:
            self.open_sessions_menu()
            return
        if ch == curses.KEY_F5:
            self.open_options_menu()
            return
        if ch == curses.KEY_F6:
            self.open_memory_menu()
            return
        if ch == curses.KEY_F7:
            self.open_file_menu()
            return
        if ch == curses.KEY_F8:
            self.open_external_editor_for_input()
            return
        if ch == curses.KEY_F9:
            self.show_credits()
            return
        if ch == 7:
            self.send_current_message()
            return
        if ch in (10, 13, curses.KEY_ENTER):
            self.insert_newline()
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            self.backspace()
        elif ch == curses.KEY_DC:
            self.delete_forward()
        elif ch == curses.KEY_LEFT:
            self.move_left()
        elif ch == curses.KEY_RIGHT:
            self.move_right()
        elif ch == curses.KEY_UP:
            self.move_up()
        elif ch == curses.KEY_DOWN:
            self.move_down()
        elif ch == curses.KEY_HOME:
            self.cursor_col = 0
        elif ch == curses.KEY_END:
            self.cursor_col = len(self.input_lines[self.cursor_row])
        elif ch == curses.KEY_PPAGE:
            self.transcript_scroll += 10
        elif ch == curses.KEY_NPAGE:
            self.transcript_scroll = max(0, self.transcript_scroll - 10)
        elif ch == 21:
            self.clear_input()
        elif ch == 12:
            pass
        elif ch == 9:
            self.insert_text("    ")
        elif 32 <= ch <= 126:
            self.insert_text(chr(ch))

    def run(self, stdscr: curses.window) -> None:
        self.stdscr = stdscr
        curses.noecho()
        curses.cbreak()
        stdscr.keypad(True)
        try:
            curses.mousemask(curses.ALL_MOUSE_EVENTS | getattr(curses, "REPORT_MOUSE_POSITION", 0))
        except curses.error:
            pass

        self.load_session_into_ui()
        if not self.cfg.api_key:
            self.status = "No API key loaded. Press F3."
        elif not self.cfg.model:
            self.status = "No MODEL configured. Press F2 to choose/test a model."

        while not self.should_quit:
            self.draw()
            try:
                ch = stdscr.getch()
            except KeyboardInterrupt:
                break
            self.handle_key(ch)


# ---------------------------------------------------------------------------
# Program entry point
# ---------------------------------------------------------------------------


def main() -> int:
    args = parse_args()

    if args.version:
        print(f"{PROGRAM} version {VERSION}")
        return 0

    cfg = load_config()
    session_dir = cfg.session_dir
    attachment_dir = cfg.effective_attachment_dir
    session_dir.mkdir(parents=True, exist_ok=True)
    attachment_dir.mkdir(parents=True, exist_ok=True)

    if args.list:
        list_sessions(session_dir)
        return 0
    if args.models:
        return print_models(cfg)
    if args.test_model:
        return print_test_model(cfg, args.test_model)
    if args.resume and args.session_name:
        print("error: use either a session name or --resume, not both", file=sys.stderr)
        return 2

    if args.resume:
        session_name = sanitize_session_name(args.resume)
        session_path = session_dir / f"{session_name}.log"
        if not session_path.exists():
            print(f"error: session not found: {session_name}", file=sys.stderr)
            return 1
    elif args.session_name:
        session_name = sanitize_session_name(args.session_name)
        session_path = session_dir / f"{session_name}.log"
    else:
        session_name = default_session_name()
        session_path = session_dir / f"{session_name}.log"

    app = GeminiCursesApp(cfg, session_name, session_path)

    try:
        curses.wrapper(app.run)
    except KeyboardInterrupt:
        return 0

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
