#!/usr/bin/env python3
"""
gemini-curses

Ncurses-based Gemini terminal interface.

This version is the full-screen terminal companion to the Bash gemini-cli
implementation. It keeps the same config-file philosophy while fixing the
interactive input problems that are difficult to solve cleanly in shell.
"""

from __future__ import annotations

import argparse
import curses
import json
import os
import re
import sys
import textwrap
import urllib.error
import urllib.parse
import urllib.request
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path
from typing import List, Optional, Tuple

VERSION = "0.5.0"
PROGRAM = "gemini-curses"
FALLBACK_MODEL = "gemini-2.5-flash"
DEFAULT_AUTOSCAN_PROMPT = "What is the capital of Texas?"
DEFAULT_AUTOSCAN_EXPECTED = "austin"
MOUSE_SCROLL_LINES = 3


# ---------------------------------------------------------------------------
# Configuration model
# ---------------------------------------------------------------------------
# The ncurses edition intentionally uses the same config file as the Bash
# edition. A user can keep one ~/.config/gemini-cli/config file and use either
# interface.
#
# Model discovery note:
#   Users can list available Gemini models with the Gemini API models endpoint:
#     curl "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_API_KEY"
#   This program also exposes that through --models and the in-app F2 selector.
#
# Model autoscan note:
#   Because Google's model list can change, gemini-curses does not try to know
#   the permanent "best" model. The F4/--autoscan-model feature fetches the live
#   model list, tests generateContent-compatible models with a small factual
#   challenge, and activates the first model that returns the expected answer.
#
# Memory terminology note:
#   CONTEXT_TURNS is the preferred config key. It means recent user/assistant
#   exchanges sent back to Gemini for conversational continuity. HISTORY_LIMIT
#   is still accepted as a legacy alias so older configs do not break.
# ---------------------------------------------------------------------------


@dataclass
class Config:
    # Empty string means no explicit MODEL was configured. In that case the
    # program can still use FALLBACK_MODEL, but the UI labels it as a fallback,
    # not as a permanent recommendation.
    model: str = ""
    context_turns: int = 12
    api_key: str = ""
    session_dir: Path = field(default_factory=lambda: Path.home() / ".gpt")
    attachment_dir: Optional[Path] = None
    autoscan_prompt: str = DEFAULT_AUTOSCAN_PROMPT
    autoscan_expected: str = DEFAULT_AUTOSCAN_EXPECTED
    config_file: Path = field(
        default_factory=lambda: Path.home() / ".config" / "gemini-cli" / "config"
    )

    @property
    def effective_model(self) -> str:
        return self.model or FALLBACK_MODEL

    @property
    def effective_attachment_dir(self) -> Path:
        if self.attachment_dir is not None:
            return self.attachment_dir
        return self.session_dir / "attachments"


def expand_path(value: str) -> Path:
    """Expand ~ and environment variables in a user-supplied path."""
    return Path(os.path.expandvars(os.path.expanduser(value))).resolve()


def normalize_model_id(model: str) -> str:
    """Accept either 'gemini-x' or 'models/gemini-x' and return 'gemini-x'."""
    model = model.strip()
    if model.startswith("models/"):
        return model.split("/", 1)[1]
    return model


def parse_positive_int(value: str, fallback: int) -> int:
    try:
        parsed = int(value)
    except ValueError:
        return fallback
    return max(1, parsed)


def load_config() -> Config:
    """Load ~/.config/gemini-cli/config using simple KEY=VALUE parsing."""
    cfg = Config()
    env_api_key = os.environ.get("GEMINI_API_KEY", "")
    context_turns_explicit = False

    if cfg.config_file.exists():
        with cfg.config_file.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()

                # Empty lines and comments are ignored. This keeps the config
                # file human-readable without introducing a TOML/YAML parser.
                if not line or line.startswith("#"):
                    continue

                if "=" not in line:
                    continue

                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip()

                if key == "MODEL":
                    cfg.model = normalize_model_id(value)
                elif key == "CONTEXT_TURNS":
                    cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                    context_turns_explicit = True
                elif key == "HISTORY_LIMIT":
                    # Legacy compatibility. CONTEXT_TURNS is clearer because
                    # this setting controls how many conversation exchanges are
                    # sent back as context, not shell command history.
                    if not context_turns_explicit:
                        cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                elif key == "GEMINI_API_KEY":
                    # Environment variable wins. Config-file storage is a
                    # convenience path, not the preferred security model.
                    cfg.api_key = env_api_key or value
                elif key == "SESSION_DIR":
                    cfg.session_dir = expand_path(value)
                elif key == "ATTACHMENT_DIR":
                    cfg.attachment_dir = expand_path(value)
                elif key == "AUTOSCAN_PROMPT":
                    if value:
                        cfg.autoscan_prompt = value
                elif key == "AUTOSCAN_EXPECTED":
                    if value:
                        cfg.autoscan_expected = value.lower()

    if env_api_key:
        cfg.api_key = env_api_key

    return cfg


def set_config_value(cfg: Config, key: str, value: str) -> None:
    """Create or update KEY=VALUE inside the config file.

    This is used only for explicit save actions, such as saving a selected or
    autoscanned model. The API-key input dialog remains session-only in this
    release so users do not accidentally write secrets to disk.
    """
    cfg.config_file.parent.mkdir(parents=True, exist_ok=True)
    lines: List[str] = []
    replaced = False

    if cfg.config_file.exists():
        lines = cfg.config_file.read_text(encoding="utf-8", errors="replace").splitlines()

    new_lines: List[str] = []
    for line in lines:
        if line.strip().startswith(f"{key}="):
            new_lines.append(f"{key}={value}")
            replaced = True
        else:
            new_lines.append(line)

    if not replaced:
        new_lines.append(f"{key}={value}")

    cfg.config_file.write_text("\n".join(new_lines) + "\n", encoding="utf-8")

    # If the config file ever contains sensitive data, private permissions are
    # preferable. This is harmless for MODEL-only config files too.
    try:
        os.chmod(cfg.config_file, 0o600)
    except OSError:
        pass


# ---------------------------------------------------------------------------
# Command-line parsing
# ---------------------------------------------------------------------------
# The interface mirrors the Bash version, with ncurses-specific additions:
# --models lists available Gemini models, and --autoscan-model tests models
# until one actually answers a small challenge correctly.
# ---------------------------------------------------------------------------


def parse_args() -> argparse.Namespace:
    if len(sys.argv) == 2 and sys.argv[1] == "help":
        sys.argv[1] = "--help"

    parser = argparse.ArgumentParser(
        prog=PROGRAM,
        description="ncurses Gemini terminal interface",
    )
    parser.add_argument(
        "session_name",
        nargs="?",
        help="named session to create or open",
    )
    parser.add_argument(
        "--resume",
        metavar="NAME",
        help="resume an existing named session",
    )
    parser.add_argument(
        "--list",
        action="store_true",
        help="list saved sessions",
    )
    parser.add_argument(
        "--models",
        action="store_true",
        help="list available Gemini generateContent models and exit",
    )
    parser.add_argument(
        "--autoscan-model",
        action="store_true",
        help="test available models and print the first working model",
    )
    parser.add_argument(
        "--version",
        action="store_true",
        help="show version information",
    )
    return parser.parse_args()


def sanitize_session_name(name: str) -> str:
    """Convert a human session name into a safe filename stem."""
    cleaned = re.sub(r"[^A-Za-z0-9._-]+", "_", name.strip())
    cleaned = cleaned.strip("._-")
    return cleaned or "session"


def default_session_name() -> str:
    return "session-" + datetime.now().strftime("%Y-%m-%d-%H-%M-%S")


def list_sessions(session_dir: Path) -> None:
    session_dir.mkdir(parents=True, exist_ok=True)
    for path in sorted(session_dir.glob("*.log")):
        print(path.stem)


# ---------------------------------------------------------------------------
# Gemini API transport
# ---------------------------------------------------------------------------
# urllib is used instead of requests to keep the ncurses edition standard-
# library only. JSON request construction uses json.dumps, which fixes the
# quoting, slash, and newline problems that appeared in the Bash implementation.
# ---------------------------------------------------------------------------


@dataclass
class ModelInfo:
    model_id: str
    api_name: str
    display_name: str
    description: str
    input_token_limit: Optional[int] = None
    output_token_limit: Optional[int] = None
    methods: List[str] = field(default_factory=list)


def model_endpoint(cfg: Config, model_id: str) -> str:
    clean_id = normalize_model_id(model_id)
    return (
        "https://generativelanguage.googleapis.com/v1beta/models/"
        f"{urllib.parse.quote(clean_id, safe='')}:generateContent?"
        + urllib.parse.urlencode({"key": cfg.api_key})
    )


def gemini_url_for_model(cfg: Config) -> str:
    return model_endpoint(cfg, cfg.effective_model)


def parse_generated_text(body: str) -> str:
    parsed = json.loads(body)
    return parsed["candidates"][0]["content"]["parts"][0]["text"]


def generate_with_model(cfg: Config, model_id: str, prompt_text: str, timeout: int = 120) -> Tuple[bool, str]:
    if not cfg.api_key:
        return False, "No Gemini API key loaded. Press F3 to paste an API key."

    payload = {
        "contents": [
            {
                "parts": [
                    {
                        "text": prompt_text,
                    }
                ]
            }
        ]
    }

    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        model_endpoint(cfg, model_id),
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        return False, f"Gemini HTTP error {exc.code}: {body[:1000]}"
    except urllib.error.URLError as exc:
        return False, f"Gemini network error: {exc}"
    except Exception as exc:
        return False, f"Gemini request error: {exc}"

    try:
        text = parse_generated_text(body)
    except Exception as exc:
        return False, f"Gemini response parse error: {exc}; raw response: {body[:1000]}"

    if not text.strip():
        return False, "Gemini returned an empty text response"

    return True, text


def call_gemini(cfg: Config, prompt_text: str) -> str:
    ok, text = generate_with_model(cfg, cfg.effective_model, prompt_text, timeout=120)
    if ok:
        return text
    return f"({text})"


def fetch_models(cfg: Config) -> Tuple[List[ModelInfo], Optional[str]]:
    """Fetch available models that support generateContent.

    The returned order follows Google's API order as much as possible. Autoscan
    tests in that order rather than using a hardcoded guess about future names.
    """
    if not cfg.api_key:
        return [], "No Gemini API key loaded. Press F3 to paste an API key."

    models: List[ModelInfo] = []
    page_token = ""

    while True:
        query = {"key": cfg.api_key}
        if page_token:
            query["pageToken"] = page_token

        url = "https://generativelanguage.googleapis.com/v1beta/models?" + urllib.parse.urlencode(query)

        try:
            with urllib.request.urlopen(url, timeout=60) as response:
                body = response.read().decode("utf-8", errors="replace")
        except urllib.error.HTTPError as exc:
            body = exc.read().decode("utf-8", errors="replace")
            return [], f"Gemini model-list HTTP error {exc.code}: {body[:1000]}"
        except urllib.error.URLError as exc:
            return [], f"Gemini model-list network error: {exc}"
        except Exception as exc:
            return [], f"Gemini model-list request error: {exc}"

        try:
            parsed = json.loads(body)
        except Exception as exc:
            return [], f"Gemini model-list parse error: {exc}; raw response: {body[:1000]}"

        for raw in parsed.get("models", []):
            methods = list(raw.get("supportedGenerationMethods", []))
            if "generateContent" not in methods:
                continue

            api_name = raw.get("name", "")
            model_id = normalize_model_id(api_name)
            if not model_id:
                continue

            models.append(
                ModelInfo(
                    model_id=model_id,
                    api_name=api_name,
                    display_name=raw.get("displayName", model_id),
                    description=raw.get("description", ""),
                    input_token_limit=raw.get("inputTokenLimit"),
                    output_token_limit=raw.get("outputTokenLimit"),
                    methods=methods,
                )
            )

        page_token = parsed.get("nextPageToken", "")
        if not page_token:
            break

    unique: dict[str, ModelInfo] = {}
    for model in models:
        if model.model_id not in unique:
            unique[model.model_id] = model

    return list(unique.values()), None


def print_models(cfg: Config) -> int:
    models, error = fetch_models(cfg)
    if error:
        print(f"ERROR: {error}", file=sys.stderr)
        return 1

    for model in models:
        name = model.display_name or model.model_id
        print(f"{model.model_id}\t{name}")
    return 0


def autoscan_response_is_valid(cfg: Config, text: str) -> bool:
    expected = cfg.autoscan_expected.strip().lower()
    if not expected:
        expected = DEFAULT_AUTOSCAN_EXPECTED
    return expected in text.lower()


def autoscan_model(cfg: Config, progress=None) -> Tuple[Optional[ModelInfo], str]:
    """Find the first model that answers the autoscan challenge correctly.

    This is intentionally empirical. Instead of guessing what Google's future
    model names mean, autoscan fetches the current model list and tests each
    generateContent-compatible candidate with a factual prompt. The model must
    return text containing the expected answer substring.
    """
    models, error = fetch_models(cfg)
    if error:
        return None, error

    if not models:
        return None, "No generateContent-compatible models were returned by the API."

    failures: List[str] = []
    total = len(models)

    for index, model in enumerate(models, start=1):
        if progress is not None:
            progress(index, total, model)

        ok, text = generate_with_model(cfg, model.model_id, cfg.autoscan_prompt, timeout=45)
        if ok and autoscan_response_is_valid(cfg, text):
            return model, text.strip()

        if ok:
            expected = cfg.autoscan_expected.strip().lower() or DEFAULT_AUTOSCAN_EXPECTED
            snippet = text.strip().replace("\n", " ")[:200]
            failures.append(
                f"{model.model_id}: response did not contain expected substring '{expected}'; response: {snippet}"
            )
        else:
            failures.append(f"{model.model_id}: {text}")

    summary = "No tested model answered the autoscan challenge correctly."
    if failures:
        summary += " Last failure: " + failures[-1]
    return None, summary


def print_autoscan_model(cfg: Config) -> int:
    def progress(index: int, total: int, model: ModelInfo) -> None:
        print(f"testing {index}/{total}: {model.model_id}", file=sys.stderr)

    model, error_or_text = autoscan_model(cfg, progress=progress)
    if model is None:
        print(f"ERROR: {error_or_text}", file=sys.stderr)
        return 1

    print(model.model_id)
    return 0


# ---------------------------------------------------------------------------
# Session log parsing and writing
# ---------------------------------------------------------------------------
# Logs remain plain text. Resuming a session rebuilds recent memory from the
# existing log and also shows recent log entries in the transcript window.
# ---------------------------------------------------------------------------


ENTRY_RE = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] ([^:]+): (.*)$")


@dataclass
class LogEntry:
    timestamp: str
    speaker: str
    text: str


def append_log(path: Path, speaker: str, text: str, timestamp: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as fh:
        fh.write(f"[{timestamp}] {speaker}: {text}\n")


def load_log_entries(path: Path) -> List[LogEntry]:
    if not path.exists():
        return []

    entries: List[LogEntry] = []
    current_timestamp: Optional[str] = None
    current_speaker: Optional[str] = None
    current_lines: List[str] = []

    with path.open("r", encoding="utf-8", errors="replace") as fh:
        for line in fh:
            line = line.rstrip("\n")
            match = ENTRY_RE.match(line)
            if match:
                if current_speaker is not None and current_timestamp is not None:
                    entries.append(LogEntry(current_timestamp, current_speaker, "\n".join(current_lines)))
                current_timestamp = match.group(1)
                current_speaker = match.group(2)
                current_lines = [match.group(3)]
            else:
                if current_speaker is not None:
                    current_lines.append(line)

    if current_speaker is not None and current_timestamp is not None:
        entries.append(LogEntry(current_timestamp, current_speaker, "\n".join(current_lines)))

    return entries


# ---------------------------------------------------------------------------
# Attachment extraction
# ---------------------------------------------------------------------------
# Fenced markdown code blocks are saved to files and replaced in the transcript
# display with attachment notices. The raw Gemini response is still written to
# the log before extraction, so logs remain authoritative.
# ---------------------------------------------------------------------------


EXT_MAP = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "py": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "c": ".c",
    "cpp": ".cpp",
    "c++": ".cpp",
    "text": ".txt",
}

FENCE_RE = re.compile(r"```([A-Za-z0-9_+.#-]*)[ \t]*\n(.*?)```", re.DOTALL)


def safe_attachment_tag(lang: str) -> str:
    lang = lang.strip().lower() or "text"
    lang = lang.replace("+", "p").replace("#", "sharp")
    lang = re.sub(r"[^A-Za-z0-9._-]+", "_", lang)
    return lang or "text"


def next_attachment_number(attachment_dir: Path, session_name: str, lang: str, ext: str) -> int:
    pattern = re.compile(
        rf"^{re.escape(session_name)}-{re.escape(lang)}-(\d{{2,}}){re.escape(ext)}$"
    )
    highest = 0
    for path in attachment_dir.glob(f"{session_name}-{lang}-*{ext}"):
        match = pattern.match(path.name)
        if match:
            highest = max(highest, int(match.group(1)))
    return highest + 1


def extract_attachments(text: str, attachment_dir: Path, session_name: str) -> str:
    attachment_dir.mkdir(parents=True, exist_ok=True)

    def replacement(match: re.Match[str]) -> str:
        raw_lang = match.group(1).strip().lower() or "text"
        lang = safe_attachment_tag(raw_lang)
        content = match.group(2)
        ext = EXT_MAP.get(raw_lang, EXT_MAP.get(lang, ".txt"))
        number = next_attachment_number(attachment_dir, session_name, lang, ext)
        filename = f"{session_name}-{lang}-{number:02d}{ext}"
        path = attachment_dir / filename

        with path.open("w", encoding="utf-8") as fh:
            fh.write(content)

        return (
            "\n"
            "[attachment saved]\n"
            f"file: {filename}\n"
            f"location: {attachment_dir}\n"
        )

    return FENCE_RE.sub(replacement, text)


# ---------------------------------------------------------------------------
# Text wrapping helpers
# ---------------------------------------------------------------------------
# These helpers prevent addstr calls from writing past the terminal edge and
# provide soft-wrapped rendering for transcript and input areas.
# ---------------------------------------------------------------------------


def wrap_for_width(text: str, width: int) -> List[str]:
    width = max(1, width)
    result: List[str] = []
    for paragraph in text.splitlines() or [""]:
        if paragraph == "":
            result.append("")
        else:
            result.extend(
                textwrap.wrap(
                    paragraph,
                    width=width,
                    replace_whitespace=False,
                    drop_whitespace=False,
                    break_long_words=True,
                    break_on_hyphens=False,
                )
            )
    return result or [""]


def now_time() -> str:
    return datetime.now().strftime("%H:%M:%S")


@dataclass
class TranscriptItem:
    speaker: str
    text: str
    timestamp: str = field(default_factory=now_time)


@dataclass
class InputSegment:
    display: str
    logical_row: int
    start: int
    available: int


# ---------------------------------------------------------------------------
# Curses application
# ---------------------------------------------------------------------------
# The TUI fixes the core shell problems:
#   - cursor redraws
#   - multiline editing
#   - wrapped input display
#   - scrollable transcript
#   - model selection without editing config
#   - API-key entry without editing config
#   - autoscan model selection without guessing future model names
#   - mousewheel scrolling and mouse-assisted navigation
# ---------------------------------------------------------------------------


class GeminiCursesApp:
    INPUT_HEIGHT = 6
    TRANSCRIPT_REPLAY_LIMIT = 60

    def __init__(self, cfg: Config, session_name: str, session_path: Path):
        self.cfg = cfg
        self.session_name = session_name
        self.session_path = session_path
        self.attachment_dir = cfg.effective_attachment_dir
        self.username = os.environ.get("USER") or os.environ.get("LOGNAME") or "user"

        self.context_buffer: List[str] = []
        self.transcript: List[TranscriptItem] = []
        self.transcript_scroll = 0

        self.input_lines: List[str] = [""]
        self.cursor_row = 0
        self.cursor_col = 0
        self.input_scroll = 0

        # Layout coordinates are refreshed on every draw. Mouse handling uses
        # these values to determine whether a click belongs to the transcript,
        # input box, status bar, or function-key label area.
        self.layout: dict[str, int] = {}
        self.last_input_segments: List[InputSegment] = []

        self.status = self.default_status()
        self.should_quit = False

    def default_status(self) -> str:
        if not self.cfg.model:
            return "No MODEL configured. F4=autoscan | F2=models | F3=API key | Ctrl+G=send"
        return "Enter=newline | Ctrl+G/F5=send | F2=models | F3=API key | F4=autoscan | F10/Ctrl+Q=quit"

    # ---------------------------------------------------------------------
    # Memory and resume model
    # ---------------------------------------------------------------------

    def load_session_into_ui(self) -> None:
        entries = load_log_entries(self.session_path)
        if not entries:
            return

        for entry in entries[-self.TRANSCRIPT_REPLAY_LIMIT :]:
            self.transcript.append(TranscriptItem(entry.speaker, entry.text, entry.timestamp))

        # CONTEXT_TURNS counts user/assistant exchanges. Since the internal
        # buffer stores individual speaker entries, we keep up to twice that
        # number of entries when rebuilding memory from logs.
        max_entries = self.cfg.context_turns * 2
        for entry in entries[-max_entries:]:
            if entry.speaker == "Gemini":
                self.context_buffer.append("Assistant: " + entry.text)
            else:
                self.context_buffer.append("User: " + entry.text)

        self.trim_context_buffer()
        self.status = f"loaded session: {self.session_name}"

    def trim_context_buffer(self) -> None:
        max_entries = self.cfg.context_turns * 2
        if len(self.context_buffer) > max_entries:
            self.context_buffer = self.context_buffer[-max_entries:]

    def build_context(self) -> str:
        return "\n".join(self.context_buffer)

    # ---------------------------------------------------------------------
    # Safe curses drawing
    # ---------------------------------------------------------------------

    def safe_addstr(self, y: int, x: int, text: str, max_width: Optional[int] = None, attr: int = 0) -> None:
        height, width = self.stdscr.getmaxyx()
        if y < 0 or y >= height or x < 0 or x >= width:
            return
        limit = width - x
        if max_width is not None:
            limit = min(limit, max_width)
        if limit <= 0:
            return
        try:
            self.stdscr.addstr(y, x, text[: max(0, limit - 1)], attr)
        except curses.error:
            pass

    def transcript_display_lines(self, width: int) -> List[str]:
        lines: List[str] = []
        for item in self.transcript:
            prefix = f"[{item.timestamp}] {item.speaker}: "
            wrapped = wrap_for_width(prefix + item.text, width)
            lines.extend(wrapped)
            lines.append("")
        return lines

    def model_label(self) -> str:
        if self.cfg.model:
            return self.cfg.model
        return f"{FALLBACK_MODEL} (fallback)"

    def draw_header(self, width: int) -> None:
        key_state = "key:loaded" if self.cfg.api_key else "key:missing"
        header = f"{PROGRAM} | session: {self.session_name} | model: {self.model_label()} | {key_state}"
        self.safe_addstr(0, 0, header, width)
        self.safe_addstr(1, 0, "_" * width, width)

    def draw_transcript(self, start_y: int, height: int, width: int) -> None:
        lines = self.transcript_display_lines(width)
        max_scroll = max(0, len(lines) - height)
        self.transcript_scroll = min(self.transcript_scroll, max_scroll)
        start = max(0, len(lines) - height - self.transcript_scroll)
        visible = lines[start : start + height]

        for offset in range(height):
            y = start_y + offset
            if offset < len(visible):
                self.safe_addstr(y, 0, visible[offset], width)

    def input_segments(self, width: int) -> Tuple[List[InputSegment], int, int]:
        marker_width = 2
        available = max(1, width - marker_width)
        segments: List[InputSegment] = []
        cursor_visual_index = 0
        cursor_x = marker_width

        for logical_row, line in enumerate(self.input_lines):
            cursor_segment = 0
            if logical_row == self.cursor_row:
                cursor_segment = self.cursor_col // available

            segment_count = max(1, (len(line) + available - 1) // available)
            if logical_row == self.cursor_row:
                segment_count = max(segment_count, cursor_segment + 1)

            for segment in range(segment_count):
                start = segment * available
                end = start + available
                marker = "> " if logical_row == 0 and segment == 0 else "  "
                chunk = line[start:end]
                segments.append(InputSegment(marker + chunk, logical_row, start, available))

                if logical_row == self.cursor_row and segment == cursor_segment:
                    cursor_visual_index = len(segments) - 1
                    cursor_x = marker_width + (self.cursor_col % available)

        return segments or [InputSegment("> ", 0, 0, max(1, width - 2))], cursor_visual_index, cursor_x

    def draw_input(self, label_y: int, input_y: int, width: int) -> None:
        label = "INPUT: Enter=newline | Ctrl+G/F5=send | F2=models | F3=API key | F4=autoscan"
        self.safe_addstr(label_y, 0, "_" * width, width)
        self.safe_addstr(label_y, 0, label, width)

        segments, cursor_visual_index, cursor_x = self.input_segments(width)
        self.last_input_segments = segments

        if cursor_visual_index < self.input_scroll:
            self.input_scroll = cursor_visual_index
        elif cursor_visual_index >= self.input_scroll + self.INPUT_HEIGHT:
            self.input_scroll = cursor_visual_index - self.INPUT_HEIGHT + 1

        max_scroll = max(0, len(segments) - self.INPUT_HEIGHT)
        self.input_scroll = max(0, min(self.input_scroll, max_scroll))

        visible = segments[self.input_scroll : self.input_scroll + self.INPUT_HEIGHT]
        for offset in range(self.INPUT_HEIGHT):
            y = input_y + offset
            text = visible[offset].display if offset < len(visible) else ""
            self.safe_addstr(y, 0, text, width)

        cursor_screen_y = input_y + cursor_visual_index - self.input_scroll
        try:
            curses.curs_set(1)
            self.stdscr.move(cursor_screen_y, min(cursor_x, width - 2))
        except curses.error:
            pass

    def draw_status(self, y: int, width: int) -> None:
        self.safe_addstr(y, 0, "_" * width, width)
        self.safe_addstr(y, 0, self.status, width)

    def draw(self) -> None:
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()

        min_height = self.INPUT_HEIGHT + 6
        if height < min_height or width < 40:
            self.layout = {}
            self.safe_addstr(0, 0, "terminal too small", width)
            self.stdscr.refresh()
            return

        header_h = 2
        status_h = 1
        input_label_h = 1
        transcript_h = height - header_h - input_label_h - self.INPUT_HEIGHT - status_h
        transcript_y = header_h
        input_label_y = transcript_y + transcript_h
        input_y = input_label_y + input_label_h
        status_y = height - 1

        self.layout = {
            "width": width,
            "height": height,
            "transcript_y": transcript_y,
            "transcript_h": transcript_h,
            "input_label_y": input_label_y,
            "input_y": input_y,
            "input_h": self.INPUT_HEIGHT,
            "status_y": status_y,
        }

        self.draw_header(width)
        self.draw_transcript(transcript_y, transcript_h, width)
        self.draw_input(input_label_y, input_y, width)
        self.draw_status(status_y, width)
        self.stdscr.refresh()

    # ---------------------------------------------------------------------
    # Mouse handling
    # ---------------------------------------------------------------------
    # Mouse support is deliberately practical:
    #   - wheel scrolls the transcript in the main view
    #   - left click in the input area places the input cursor
    #   - wheel scrolls modal lists where implemented
    #   - model selector rows can be clicked and double-clicked
    #
    # Native terminal text selection and drag-copy are left to the terminal
    # emulator. Ncurses applications should not try to replace the user's
    # terminal selection model.
    # ---------------------------------------------------------------------

    def mouse_wheel_delta(self, state: int) -> int:
        if state & getattr(curses, "BUTTON4_PRESSED", 0):
            return 1
        if state & getattr(curses, "BUTTON5_PRESSED", 0):
            return -1
        return 0

    def mouse_button1(self, state: int) -> bool:
        masks = [
            getattr(curses, "BUTTON1_PRESSED", 0),
            getattr(curses, "BUTTON1_CLICKED", 0),
            getattr(curses, "BUTTON1_DOUBLE_CLICKED", 0),
            getattr(curses, "BUTTON1_TRIPLE_CLICKED", 0),
        ]
        return any(state & mask for mask in masks)

    def mouse_button1_double(self, state: int) -> bool:
        return bool(state & getattr(curses, "BUTTON1_DOUBLE_CLICKED", 0))

    def handle_mouse(self) -> None:
        try:
            _mouse_id, x, y, _z, state = curses.getmouse()
        except curses.error:
            return

        delta = self.mouse_wheel_delta(state)
        if delta:
            # Wheel up means move older in transcript, which is represented by
            # increasing transcript_scroll. Wheel down reduces the scroll offset.
            if delta > 0:
                self.transcript_scroll += MOUSE_SCROLL_LINES
            else:
                self.transcript_scroll = max(0, self.transcript_scroll - MOUSE_SCROLL_LINES)
            self.status = "mousewheel: transcript scroll"
            return

        if not self.layout:
            return

        if self.mouse_button1(state):
            input_y = self.layout.get("input_y", -1)
            input_h = self.layout.get("input_h", 0)
            if input_y <= y < input_y + input_h:
                self.place_cursor_from_mouse(x, y - input_y)
                self.status = "mouse: input cursor placed"
                return

            transcript_y = self.layout.get("transcript_y", -1)
            transcript_h = self.layout.get("transcript_h", 0)
            if transcript_y <= y < transcript_y + transcript_h:
                self.status = "mouse: transcript area"
                return

    def place_cursor_from_mouse(self, x: int, visible_row: int) -> None:
        index = self.input_scroll + visible_row
        if index < 0 or index >= len(self.last_input_segments):
            return

        segment = self.last_input_segments[index]
        line = self.input_lines[segment.logical_row]
        clicked_col = max(0, x - 2)
        logical_col = min(len(line), segment.start + clicked_col)

        self.cursor_row = segment.logical_row
        self.cursor_col = logical_col

    # ---------------------------------------------------------------------
    # Modal helpers
    # ---------------------------------------------------------------------

    def show_message(self, title: str, lines: List[str]) -> None:
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            box_w = min(width - 4, 76)
            box_h = min(height - 4, max(8, len(lines) + 5))
            top = max(0, (height - box_h) // 2)
            left = max(0, (width - box_w) // 2)

            self.safe_addstr(top, left, "+" + "-" * (box_w - 2) + "+")
            self.safe_addstr(top + 1, left, "|" + title.center(box_w - 2) + "|")
            self.safe_addstr(top + 2, left, "+" + "-" * (box_w - 2) + "+")

            y = top + 3
            for raw in lines[: box_h - 5]:
                for wrapped in wrap_for_width(raw, box_w - 4):
                    if y >= top + box_h - 2:
                        break
                    self.safe_addstr(y, left + 2, wrapped, box_w - 4)
                    y += 1

            self.safe_addstr(top + box_h - 2, left + 2, "Press any key or click to continue", box_w - 4)
            self.safe_addstr(top + box_h - 1, left, "+" + "-" * (box_w - 2) + "+")
            self.stdscr.refresh()
            self.stdscr.getch()
            return

    def ask_yes_no(self, title: str, message: str, default: bool = False) -> bool:
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            box_w = min(width - 4, 76)
            box_h = 10
            top = max(0, (height - box_h) // 2)
            left = max(0, (width - box_w) // 2)

            self.safe_addstr(top, left, "+" + "-" * (box_w - 2) + "+")
            self.safe_addstr(top + 1, left, "|" + title.center(box_w - 2) + "|")
            self.safe_addstr(top + 2, left, "+" + "-" * (box_w - 2) + "+")

            y = top + 3
            for line in wrap_for_width(message, box_w - 4)[:3]:
                self.safe_addstr(y, left + 2, line, box_w - 4)
                y += 1

            default_label = "yes" if default else "no"
            prompt = f"Y/N? Enter={default_label} | Esc=no | click left half=yes, right half=no"
            self.safe_addstr(top + box_h - 2, left + 2, prompt, box_w - 4)
            self.safe_addstr(top + box_h - 1, left, "+" + "-" * (box_w - 2) + "+")
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch == curses.KEY_MOUSE:
                try:
                    _mouse_id, x, y_mouse, _z, state = curses.getmouse()
                except curses.error:
                    continue
                if self.mouse_button1(state) and top <= y_mouse <= top + box_h:
                    return x < left + (box_w // 2)
                continue
            if ch in (ord("y"), ord("Y")):
                return True
            if ch in (ord("n"), ord("N"), 27):
                return False
            if ch in (10, 13, curses.KEY_ENTER):
                return default

    def maybe_save_model_to_config(self) -> None:
        if not self.cfg.model:
            return
        if self.ask_yes_no(
            "SAVE MODEL",
            f"Save MODEL={self.cfg.model} to {self.cfg.config_file}?",
            default=True,
        ):
            set_config_value(self.cfg, "MODEL", self.cfg.model)
            self.status = f"model saved: {self.cfg.model}"

    def open_api_key_input(self) -> None:
        key = ""
        cursor = 0
        prompt_status = "Paste API key. Enter=activate for this session. Esc=cancel."

        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            box_w = min(width - 4, 82)
            box_h = 10
            top = max(0, (height - box_h) // 2)
            left = max(0, (width - box_w) // 2)

            masked = "*" * max(0, len(key) - 4) + key[-4:]
            available = max(1, box_w - 6)
            shown = masked[-available:]

            self.safe_addstr(top, left, "+" + "-" * (box_w - 2) + "+")
            self.safe_addstr(top + 1, left, "|" + "API KEY INPUT".center(box_w - 2) + "|")
            self.safe_addstr(top + 2, left, "+" + "-" * (box_w - 2) + "+")
            self.safe_addstr(top + 3, left + 2, prompt_status, box_w - 4)
            self.safe_addstr(top + 4, left + 2, "This does not write the key to the config file.", box_w - 4)
            self.safe_addstr(top + 6, left + 2, "Key: " + shown, box_w - 4)
            self.safe_addstr(top + 8, left + 2, f"Characters entered: {len(key)}", box_w - 4)
            self.safe_addstr(top + 9, left, "+" + "-" * (box_w - 2) + "+")
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch == curses.KEY_MOUSE:
                try:
                    _mouse_id, x, _y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                if self.mouse_button1(state):
                    # Clicking inside the key field places the editing cursor
                    # approximately where the user clicked.
                    field_start = left + 7
                    if x >= field_start:
                        cursor = min(len(key), max(0, len(key) - len(shown) + (x - field_start)))
                continue
            if ch in (10, 13, curses.KEY_ENTER):
                if key.strip():
                    self.cfg.api_key = key.strip()
                    self.status = "API key activated for this session"
                else:
                    self.status = "API key entry cancelled: empty key"
                return
            if ch in (27,):
                self.status = "API key entry cancelled"
                return
            if ch in (curses.KEY_BACKSPACE, 127, 8):
                if cursor > 0:
                    key = key[: cursor - 1] + key[cursor:]
                    cursor -= 1
                continue
            if ch == curses.KEY_LEFT:
                cursor = max(0, cursor - 1)
                continue
            if ch == curses.KEY_RIGHT:
                cursor = min(len(key), cursor + 1)
                continue
            if ch == curses.KEY_HOME:
                cursor = 0
                continue
            if ch == curses.KEY_END:
                cursor = len(key)
                continue
            if 32 <= ch <= 126:
                key = key[:cursor] + chr(ch) + key[cursor:]
                cursor += 1

    def show_model_info(self, model: ModelInfo) -> None:
        lines = [
            f"Model ID: {model.model_id}",
            f"API name: {model.api_name}",
            f"Display name: {model.display_name}",
            f"Input token limit: {model.input_token_limit}",
            f"Output token limit: {model.output_token_limit}",
            f"Methods: {', '.join(model.methods)}",
            "",
            model.description or "No description returned by API.",
        ]
        self.show_message("MODEL INFO", lines)

    def open_model_selector(self) -> None:
        if not self.cfg.api_key:
            self.show_message(
                "MODEL SELECTOR",
                [
                    "No API key is loaded.",
                    "Press F3 in the main interface to paste an API key, then try F2 again.",
                ],
            )
            self.status = "model selector cancelled: no API key"
            return

        self.status = "loading model list..."
        self.draw()
        models, error = fetch_models(self.cfg)
        if error:
            self.show_message("MODEL LIST ERROR", wrap_for_width(error, 70))
            self.status = "model list failed"
            return
        if not models:
            self.show_message("MODEL SELECTOR", ["No generateContent models returned by the API."])
            self.status = "model list empty"
            return

        selected = 0
        current = normalize_model_id(self.cfg.effective_model)
        for idx, model in enumerate(models):
            if model.model_id == current:
                selected = idx
                break
        top_index = 0

        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 7)

            self.safe_addstr(0, 0, "MODEL SELECTOR", width)
            self.safe_addstr(1, 0, f"Current model: {self.model_label()}", width)
            self.safe_addstr(2, 0, "Enter=activate | i=info | click=select | dbl-click=activate | wheel=scroll", width)
            self.safe_addstr(3, 0, "_" * width, width)

            if selected < top_index:
                top_index = selected
            elif selected >= top_index + visible_h:
                top_index = selected - visible_h + 1

            for row in range(visible_h):
                model_index = top_index + row
                if model_index >= len(models):
                    break
                model = models[model_index]
                limits = ""
                if model.input_token_limit or model.output_token_limit:
                    limits = f" in:{model.input_token_limit or '?'} out:{model.output_token_limit or '?'}"
                current_marker = "* " if model.model_id == current else "  "
                line = f"{current_marker}{model.model_id} - {model.display_name}{limits}"
                attr = curses.A_REVERSE if model_index == selected else 0
                self.safe_addstr(4 + row, 0, line, width, attr)

            footer = f"{selected + 1}/{len(models)}"
            self.safe_addstr(height - 2, 0, "_" * width, width)
            self.safe_addstr(height - 1, 0, footer, width)
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch == curses.KEY_MOUSE:
                try:
                    _mouse_id, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue

                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - MOUSE_SCROLL_LINES)
                    continue
                if delta < 0:
                    selected = min(len(models) - 1, selected + MOUSE_SCROLL_LINES)
                    continue

                if self.mouse_button1(state) and 4 <= y < 4 + visible_h:
                    idx = top_index + (y - 4)
                    if 0 <= idx < len(models):
                        selected = idx
                        if self.mouse_button1_double(state):
                            chosen = models[selected]
                            self.cfg.model = chosen.model_id
                            self.status = f"activated model: {chosen.model_id}"
                            self.transcript.append(TranscriptItem("system", f"Model activated: {chosen.model_id}"))
                            self.maybe_save_model_to_config()
                            return
                    continue

                continue

            if ch in (27, ord("q"), ord("Q")):
                self.status = "model selection cancelled"
                return
            if ch in (ord("i"), ord("I")):
                self.show_model_info(models[selected])
                continue
            if ch in (10, 13, curses.KEY_ENTER):
                chosen = models[selected]
                self.cfg.model = chosen.model_id
                self.status = f"activated model: {chosen.model_id}"
                self.transcript.append(TranscriptItem("system", f"Model activated: {chosen.model_id}"))
                self.maybe_save_model_to_config()
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN:
                selected = min(len(models) - 1, selected + 1)
            elif ch == curses.KEY_PPAGE:
                selected = max(0, selected - visible_h)
            elif ch == curses.KEY_NPAGE:
                selected = min(len(models) - 1, selected + visible_h)
            elif ch == curses.KEY_HOME:
                selected = 0
            elif ch == curses.KEY_END:
                selected = len(models) - 1

    def run_autoscan(self) -> None:
        if not self.cfg.api_key:
            self.show_message(
                "AUTOSCAN MODEL",
                [
                    "No API key is loaded.",
                    "Press F3 to paste an API key, then try F4 again.",
                ],
            )
            self.status = "autoscan cancelled: no API key"
            return

        def progress(index: int, total: int, model: ModelInfo) -> None:
            self.status = f"autoscan testing {index}/{total}: {model.model_id}"
            self.draw()

        self.status = "autoscan fetching model list..."
        self.draw()
        model, result = autoscan_model(self.cfg, progress=progress)
        if model is None:
            self.show_message("AUTOSCAN FAILED", wrap_for_width(result, 70))
            self.status = "autoscan failed"
            return

        self.cfg.model = model.model_id
        self.status = f"autoscan activated: {model.model_id}"
        self.transcript.append(TranscriptItem("system", f"Autoscan activated model: {model.model_id}"))
        self.maybe_save_model_to_config()

    # ---------------------------------------------------------------------
    # Input editing
    # ---------------------------------------------------------------------

    def insert_text(self, text: str) -> None:
        line = self.input_lines[self.cursor_row]
        self.input_lines[self.cursor_row] = line[: self.cursor_col] + text + line[self.cursor_col :]
        self.cursor_col += len(text)

    def insert_newline(self) -> None:
        line = self.input_lines[self.cursor_row]
        before = line[: self.cursor_col]
        after = line[self.cursor_col :]
        self.input_lines[self.cursor_row] = before
        self.input_lines.insert(self.cursor_row + 1, after)
        self.cursor_row += 1
        self.cursor_col = 0

    def backspace(self) -> None:
        if self.cursor_col > 0:
            line = self.input_lines[self.cursor_row]
            self.input_lines[self.cursor_row] = line[: self.cursor_col - 1] + line[self.cursor_col :]
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            previous_len = len(self.input_lines[self.cursor_row - 1])
            self.input_lines[self.cursor_row - 1] += self.input_lines[self.cursor_row]
            del self.input_lines[self.cursor_row]
            self.cursor_row -= 1
            self.cursor_col = previous_len

    def delete_forward(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.input_lines[self.cursor_row] = line[: self.cursor_col] + line[self.cursor_col + 1 :]
        elif self.cursor_row < len(self.input_lines) - 1:
            self.input_lines[self.cursor_row] += self.input_lines[self.cursor_row + 1]
            del self.input_lines[self.cursor_row + 1]

    def move_left(self) -> None:
        if self.cursor_col > 0:
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = len(self.input_lines[self.cursor_row])

    def move_right(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.cursor_col += 1
        elif self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = 0

    def move_up(self) -> None:
        if self.cursor_row > 0:
            self.cursor_row -= 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def move_down(self) -> None:
        if self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1
            self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    def clear_input(self) -> None:
        self.input_lines = [""]
        self.cursor_row = 0
        self.cursor_col = 0
        self.input_scroll = 0

    def current_input(self) -> str:
        return "\n".join(self.input_lines).strip("\n")

    # ---------------------------------------------------------------------
    # Sending messages
    # ---------------------------------------------------------------------

    def send_current_message(self) -> None:
        message = self.current_input()
        if not message.strip():
            self.status = "empty message ignored"
            self.clear_input()
            return

        user_time = now_time()
        self.transcript.append(TranscriptItem(self.username, message, user_time))
        append_log(self.session_path, self.username, message, user_time)
        self.clear_input()
        self.transcript_scroll = 0

        self.status = "Generating response..."
        self.draw()

        context = self.build_context()
        prompt_text = (context + "\n" if context else "") + "User: " + message
        raw_output = call_gemini(self.cfg, prompt_text)

        gemini_time = now_time()
        append_log(self.session_path, "Gemini", raw_output, gemini_time)
        cleaned_output = extract_attachments(raw_output, self.attachment_dir, self.session_name)

        self.context_buffer.append("User: " + message)
        self.context_buffer.append("Assistant: " + cleaned_output)
        self.trim_context_buffer()

        self.transcript.append(TranscriptItem("Gemini", cleaned_output, gemini_time))
        self.status = "response complete"
        self.transcript_scroll = 0

    # ---------------------------------------------------------------------
    # Main event loop
    # ---------------------------------------------------------------------

    def handle_key(self, ch: int) -> None:
        if ch == curses.KEY_MOUSE:
            self.handle_mouse()
            return

        if ch in (curses.KEY_F10, 17):  # F10 or Ctrl+Q
            self.should_quit = True
            return

        if ch == curses.KEY_F2:
            self.open_model_selector()
            return

        if ch == curses.KEY_F3:
            self.open_api_key_input()
            return

        if ch == curses.KEY_F4:
            self.run_autoscan()
            return

        if ch in (curses.KEY_F5, 7):  # F5 or Ctrl+G
            self.send_current_message()
            return

        if ch in (10, 13, curses.KEY_ENTER):
            self.insert_newline()
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            self.backspace()
        elif ch == curses.KEY_DC:
            self.delete_forward()
        elif ch == curses.KEY_LEFT:
            self.move_left()
        elif ch == curses.KEY_RIGHT:
            self.move_right()
        elif ch == curses.KEY_UP:
            self.move_up()
        elif ch == curses.KEY_DOWN:
            self.move_down()
        elif ch == curses.KEY_HOME:
            self.cursor_col = 0
        elif ch == curses.KEY_END:
            self.cursor_col = len(self.input_lines[self.cursor_row])
        elif ch == curses.KEY_PPAGE:
            self.transcript_scroll += 10
        elif ch == curses.KEY_NPAGE:
            self.transcript_scroll = max(0, self.transcript_scroll - 10)
        elif ch == 21:  # Ctrl+U clears current input
            self.clear_input()
        elif ch == 12:  # Ctrl+L redraw
            pass
        elif ch == 9:  # tab inserts indentation
            self.insert_text("    ")
        elif 32 <= ch <= 126:
            self.insert_text(chr(ch))

    def run(self, stdscr: curses.window) -> None:
        self.stdscr = stdscr
        curses.noecho()
        curses.cbreak()
        stdscr.keypad(True)

        # Enable mouse events. BUTTON4/BUTTON5 are commonly used by terminals
        # for mousewheel up/down. REPORT_MOUSE_POSITION is requested where the
        # curses implementation supports it, but drag tracking is not required.
        mouse_mask = curses.ALL_MOUSE_EVENTS
        mouse_mask |= getattr(curses, "REPORT_MOUSE_POSITION", 0)
        try:
            curses.mousemask(mouse_mask)
        except curses.error:
            pass

        self.load_session_into_ui()
        if not self.cfg.api_key:
            self.status = "No API key loaded. Press F3 to paste one."
        elif not self.cfg.model:
            self.status = "No MODEL configured. Press F4 to autoscan or F2 to choose."

        while not self.should_quit:
            self.draw()
            try:
                ch = stdscr.getch()
            except KeyboardInterrupt:
                break
            self.handle_key(ch)


# ---------------------------------------------------------------------------
# Program entry point
# ---------------------------------------------------------------------------


def main() -> int:
    args = parse_args()

    if args.version:
        print(f"{PROGRAM} version {VERSION}")
        return 0

    cfg = load_config()
    session_dir = cfg.session_dir
    attachment_dir = cfg.effective_attachment_dir
    session_dir.mkdir(parents=True, exist_ok=True)
    attachment_dir.mkdir(parents=True, exist_ok=True)

    if args.list:
        list_sessions(session_dir)
        return 0

    if args.models:
        return print_models(cfg)

    if args.autoscan_model:
        return print_autoscan_model(cfg)

    if args.resume and args.session_name:
        print("error: use either a session name or --resume, not both", file=sys.stderr)
        return 2

    if args.resume:
        session_name = sanitize_session_name(args.resume)
        session_path = session_dir / f"{session_name}.log"
        if not session_path.exists():
            print(f"error: session not found: {session_name}", file=sys.stderr)
            return 1
    elif args.session_name:
        session_name = sanitize_session_name(args.session_name)
        session_path = session_dir / f"{session_name}.log"
    else:
        session_name = default_session_name()
        session_path = session_dir / f"{session_name}.log"

    app = GeminiCursesApp(cfg, session_name, session_path)

    try:
        curses.wrapper(app.run)
    except KeyboardInterrupt:
        return 0

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
