    def test_model_dialog(self, model: ModelInfo) -> None:
        self.status = f"testing model: {model.model_id}"
        self.draw()
        ok, text = generate_with_model(self.cfg, model.model_id, self.cfg.model_test_prompt, timeout=60)
        title = "MODEL TEST OK" if ok else "MODEL TEST FAILED"
        self.show_message(
            title,
            [
                f"Model: {model.model_id}",
                f"Prompt: {self.cfg.model_test_prompt}",
