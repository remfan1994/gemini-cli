# ttychatter Gemini config example
# Copy to ~/.config/ttychatter/gemini/config and edit.
# The file is parsed as simple KEY=VALUE lines.

# GEMINI_API_KEY can also be supplied through the environment. Environment wins.
GEMINI_API_KEY=

# Default model if no model has been selected in F2.
MODEL=gemini-2.5-flash

# Number of previous user/assistant turns to keep in request context.
CONTEXT_TURNS=12

# XDG-style defaults are used if these are omitted.
# SESSION_DIR=~/.local/share/ttychatter/gemini/sessions
# ATTACHMENT_DIR=~/.local/share/ttychatter/gemini/attachments
# MODEL_CACHE_FILE=~/.cache/ttychatter/gemini/models.json

# Editor used by F8. If empty, VISUAL, EDITOR, then vi are tried.
EDITOR=

# UI and startup behavior.
MONOCHROME=0
STARTUP_NOTICE=1
INPUT_PLACEHOLDER=Type your chat message here. Ctrl+G sends.

# Model selector behavior.
MODEL_FILTER_GENERATE_CONTENT=1
MODEL_FILTER_REQUIRE_TOKENS=1
MODEL_FILTER_HIDE_PREVIEW=0
MODEL_MIN_INPUT_TOKENS=1
MODEL_MIN_OUTPUT_TOKENS=1
MODEL_SORT_ORDER=api

# Attachment limit for inline Gemini request parts.
MAX_ATTACHMENT_BYTES=20971520
