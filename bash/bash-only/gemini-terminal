# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def is_snapshot_entry
# Maintainer note for is_snapshot_entry: this routine is part of the long-term public behavior
# of the program. When changing it, check callers, documentation, config compatibility, session-
# log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def is_snapshot_entry(entry: LogEntry) -> bool:
    return entry.speaker == "system" and entry.text.startswith(SNAPSHOT_PREFIX)


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def load_log_entries
# Parses the human-readable session log. The log format is part of the project contract; change
# it cautiously and preserve backward compatibility.
# ------------------------------------------------------------
def load_log_entries(path: Path) -> List[LogEntry]:
    if not path.exists():
        return []

    entries: List[LogEntry] = []
    current_timestamp: Optional[str] = None
    current_speaker: Optional[str] = None
    current_lines: List[str] = []

    with path.open("r", encoding="utf-8", errors="replace") as fh:
        for line in fh:
            line = line.rstrip("\n")
            match = ENTRY_RE.match(line)
            if match:
                if current_speaker is not None and current_timestamp is not None:
                    entries.append(LogEntry(current_timestamp, current_speaker, "\n".join(current_lines)))
                current_timestamp = match.group(1)
                current_speaker = match.group(2)
                current_lines = [match.group(3)]
            else:
                if current_speaker is not None:
                    current_lines.append(line)

    if current_speaker is not None and current_timestamp is not None:
        entries.append(LogEntry(current_timestamp, current_speaker, "\n".join(current_lines)))

    return entries


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def latest_context_snapshot
# Finds saved memory snapshots. This lets resumed sessions restore context without replaying
# every line in a long log.
# ------------------------------------------------------------
def latest_context_snapshot(entries: List[LogEntry]) -> Optional[List[str]]:
    for entry in reversed(entries):
        if not is_snapshot_entry(entry):
            continue
        raw = entry.text[len(SNAPSHOT_PREFIX):]
        try:
            value = json.loads(raw)
        except Exception:
            continue
        if isinstance(value, list) and all(isinstance(item, str) for item in value):
            return value
    return None


