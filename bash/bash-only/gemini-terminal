    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def move_left(self) -> None:
        if self.cursor_col > 0: self.cursor_col -= 1
        elif self.cursor_row > 0: self.cursor_row -= 1; self.cursor_col = len(self.input_lines[self.cursor_row])

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def move_right
