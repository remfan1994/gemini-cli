    # MAINTAINER COMMENTARY: def open_model_selector
    # F2 model workflow. It should separate local cached viewing from explicit network refreshes
    # and keep testing user-operated.
    # ------------------------------------------------------------
    def open_model_selector(self) -> None:
        """Open a local model-management menu without network access.

        Earlier releases immediately fetched Google's model list when F2 was
        pressed. That was surprising, especially offline or on limited quota.
        F2 now opens a local menu first. The user explicitly chooses whether
        to use the cached list or update the list from Google.
        """
        selected = 0
        while True:
            models_cached, cache_error, updated_at = load_model_cache(self.cfg)
            cached_label = f"cached model list ({len(models_cached)} models, updated {updated_at})" if models_cached else "cached model list unavailable"
            filter_label = model_filter_summary(self.cfg, len(models_cached), len(filter_model_list(self.cfg, models_cached))) if models_cached else model_filter_summary(self.cfg, 0, 0)
            actions = [
                ("u", "Load/update model list from Google", "update"),
                ("c", f"Open {cached_label}", "cached"),
                ("f", f"Model filters: {filter_label}", "filters"),
                ("t", f"Test current model: {self.model_label()}", "test-current"),
                ("e", "Enter model ID manually", "enter"),
                ("s", f"Save current model: {self.model_label()}", "save-current"),
                ("q", "Return to chat", "return"),
            ]

            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 6)
            self.safe_addstr(0, 0, "MODEL MENU", width, self.reverse_attr())
            self.safe_addstr(1, 0, "No network request is made until you choose Load/update.", width, self.dim_attr())
            self.safe_addstr(2, 0, f"Current model: {self.model_label()}", width)
            self.safe_addstr(3, 0, "Enter/click=choose | f=filters | F-keys jump screens | Esc/q=return", width, self.dim_attr())
            self.safe_addstr(4, 0, "_" * width, width, self.dim_attr())

            selected = max(0, min(selected, len(actions) - 1))
            for row, (key, label, _action) in enumerate(actions[:visible_h]):
                attr = self.reverse_attr() if row == selected else 0
                self.safe_addstr(5 + row, 0, f"{key}  {label}", width, attr)

            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch, current_action="models"):
                return
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - 1)
                    continue
                if delta < 0:
                    selected = min(len(actions) - 1, selected + 1)
                    continue
                if self.mouse_button1(state) and 5 <= y < 5 + len(actions):
                    selected = y - 5
                    ch = 10
                else:
                    continue
            if ch in (27, ord("q"), ord("Q")):
                self.status = "model menu closed"
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
                continue
            if ch == curses.KEY_DOWN:
                selected = min(len(actions) - 1, selected + 1)
                continue
            if ch not in (10, 13, curses.KEY_ENTER):
                for idx, (key, _label, _action) in enumerate(actions):
                    if ch in (ord(key), ord(key.upper())):
                        selected = idx
                        ch = 10
                        break
            if ch not in (10, 13, curses.KEY_ENTER):
                continue

            action = actions[selected][2]
            if action == "return":
                self.status = "model menu closed"
                return
            if action == "update":
                if not self.cfg.api_key:
                    self.show_message("MODEL LIST", ["No API key loaded. Press F3 to paste one."])
                    continue
                self.status = "loading model list from Google..."
                self.draw()
                models, error = fetch_models(self.cfg)
                if error:
                    self.show_message("MODEL LIST ERROR", [
                        error,
                        "",
                        "If this is a DNS/network error, verify that the Linux container is online and can resolve generativelanguage.googleapis.com.",
                    ])
                    self.status = "model list failed"
                    continue
                save_model_cache(self.cfg, models)
                self.status = f"model list updated: {len(models)} models"
                self.open_model_list_selector(models, source_label="Google live list")
                return
            if action == "cached":
                if cache_error:
                    self.show_message("MODEL CACHE", [cache_error])
                    continue
                self.open_model_list_selector(models_cached, source_label=f"cached list updated {updated_at}")
                return
            if action == "filters":
                self.open_model_filter_menu()
                continue
            if action == "test-current":
                model = ModelInfo(
                    model_id=normalize_model_id(self.cfg.effective_model),
                    api_name="",
                    display_name=normalize_model_id(self.cfg.effective_model),
                    description="Current configured/fallback model.",
                )
                self.test_model_interactive(model)
                continue
            if action == "enter":
                new_model = self.text_input_modal("ENTER MODEL ID", "Enter exact Gemini model ID:", self.cfg.model or self.cfg.effective_model)
                if new_model:
                    self.cfg.model = normalize_model_id(new_model)
                    self.transcript.append(TranscriptItem("system", f"Model entered manually: {self.cfg.model}"))
                    self.status = f"model activated: {self.cfg.model}"
                    if self.ask_yes_no("SAVE MODEL", f"Save MODEL={self.cfg.model} to config?", default=True):
                        set_config_value(self.cfg, "MODEL", self.cfg.model)
                        self.status = f"model saved: {self.cfg.model}"
                continue
            if action == "save-current":
                set_config_value(self.cfg, "MODEL", normalize_model_id(self.cfg.effective_model))
                self.status = f"model saved: {normalize_model_id(self.cfg.effective_model)}"
                continue

