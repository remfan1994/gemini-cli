    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def insert_text
    # Maintainer note for insert_text: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def insert_text(self, text: str) -> None:
        line = self.input_lines[self.cursor_row]
        self.input_lines[self.cursor_row] = line[: self.cursor_col] + text + line[self.cursor_col:]
        self.cursor_col += len(text)

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def insert_newline
    # Maintainer note for insert_newline: this routine is part of the long-term public behavior
    # of the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def insert_newline(self) -> None:
        line = self.input_lines[self.cursor_row]
        self.input_lines[self.cursor_row] = line[: self.cursor_col]
        self.input_lines.insert(self.cursor_row + 1, line[self.cursor_col:])
        self.cursor_row += 1
        self.cursor_col = 0

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def backspace
    # Maintainer note for backspace: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def backspace(self) -> None:
        if self.cursor_col > 0:
            line = self.input_lines[self.cursor_row]
            self.input_lines[self.cursor_row] = line[: self.cursor_col - 1] + line[self.cursor_col:]
            self.cursor_col -= 1
        elif self.cursor_row > 0:
            previous_len = len(self.input_lines[self.cursor_row - 1])
            self.input_lines[self.cursor_row - 1] += self.input_lines[self.cursor_row]
            del self.input_lines[self.cursor_row]
            self.cursor_row -= 1
            self.cursor_col = previous_len

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def delete_forward
    # Maintainer note for delete_forward: this routine is part of the long-term public behavior
    # of the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def delete_forward(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line):
            self.input_lines[self.cursor_row] = line[: self.cursor_col] + line[self.cursor_col + 1:]
        elif self.cursor_row < len(self.input_lines) - 1:
            self.input_lines[self.cursor_row] += self.input_lines[self.cursor_row + 1]
            del self.input_lines[self.cursor_row + 1]

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def move_left
    # Maintainer note for move_left: this routine is part of the long-term public behavior of
