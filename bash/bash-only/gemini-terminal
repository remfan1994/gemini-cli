# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def load_config
# Reads the shared KEY=VALUE config file. This is deliberately not TOML/YAML/JSON because Bash-
# only and future C implementations must be able to follow the same rules.
# ------------------------------------------------------------
def load_config() -> Config:
    cfg = Config()
    env_api_key = os.environ.get("GEMINI_API_KEY", "")
    context_turns_explicit = False

    if cfg.config_file.exists():
        with cfg.config_file.open("r", encoding="utf-8") as fh:
            for raw_line in fh:
                line = raw_line.strip()
                if not line or line.startswith("#"):
                    continue
                if "=" not in line:
                    continue
                key, value = line.split("=", 1)
                key = key.strip()
                value = value.strip()

                if key == "MODEL":
                    cfg.model = normalize_model_id(value)
                elif key == "CONTEXT_TURNS":
                    cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                    context_turns_explicit = True
                elif key == "HISTORY_LIMIT":
                    if not context_turns_explicit:
                        cfg.context_turns = parse_positive_int(value, cfg.context_turns)
                elif key == "GEMINI_API_KEY":
                    cfg.api_key = env_api_key or value
                elif key == "SESSION_DIR":
                    cfg.session_dir = expand_path(value)
                elif key == "ATTACHMENT_DIR":
                    cfg.attachment_dir = expand_path(value)
                elif key == "EDITOR":
                    cfg.editor = value
                elif key == "GITHUB_URL":
                    cfg.github_url = value or DEFAULT_GITHUB_URL
                elif key == "MODEL_TEST_PROMPT":
                    if value:
                        cfg.model_test_prompt = value
                elif key == "MONOCHROME":
                    cfg.monochrome = parse_bool(value, cfg.monochrome)
                elif key == "INPUT_PLACEHOLDER":
                    if value:
                        cfg.input_placeholder = value
                elif key == "STARTUP_NOTICE":
                    cfg.startup_notice = parse_bool(value, cfg.startup_notice)
                elif key == "MODEL_CACHE_FILE":
                    cfg.model_cache_file = expand_path(value)
                elif key == "MODEL_FILTER_GENERATE_CONTENT":
                    cfg.model_filter_generate_content = parse_bool(value, cfg.model_filter_generate_content)
                elif key == "MODEL_FILTER_REQUIRE_TOKENS":
                    cfg.model_filter_require_tokens = parse_bool(value, cfg.model_filter_require_tokens)
                elif key == "MODEL_FILTER_HIDE_PREVIEW":
                    cfg.model_filter_hide_preview = parse_bool(value, cfg.model_filter_hide_preview)
                elif key == "MODEL_MIN_INPUT_TOKENS":
                    cfg.model_min_input_tokens = parse_nonnegative_int(value, cfg.model_min_input_tokens)
                elif key == "MODEL_MIN_OUTPUT_TOKENS":
                    cfg.model_min_output_tokens = parse_nonnegative_int(value, cfg.model_min_output_tokens)
                elif key == "MODEL_SORT_ORDER":
                    if value in {"api", "name", "display", "input-desc", "output-desc"}:
                        cfg.model_sort_order = value

    if env_api_key:
        cfg.api_key = env_api_key

    return cfg


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def set_config_value
# Writes one config key while preserving unrelated lines. This helper is used only after
# explicit user action; it should never silently save secrets or behavioral choices.
# ------------------------------------------------------------
def set_config_value(cfg: Config, key: str, value: str) -> None:
    cfg.config_file.parent.mkdir(parents=True, exist_ok=True)
    lines: List[str] = []
    replaced = False

    if cfg.config_file.exists():
        lines = cfg.config_file.read_text(encoding="utf-8", errors="replace").splitlines()

    new_lines: List[str] = []
    for line in lines:
        if line.strip().startswith(f"{key}="):
            new_lines.append(f"{key}={value}")
            replaced = True
        else:
            new_lines.append(line)

    if not replaced:
        new_lines.append(f"{key}={value}")

    cfg.config_file.write_text("\n".join(new_lines) + "\n", encoding="utf-8")
    try:
        os.chmod(cfg.config_file, 0o600)
    except OSError:
        pass


