# MAINTAINER COMMENTARY: def load_model_cache
# Reads cached model metadata. If the cache is stale or missing, present that fact clearly
# rather than quietly forcing a network call.
# ------------------------------------------------------------
def load_model_cache(cfg: Config) -> Tuple[List[ModelInfo], Optional[str], str]:
    if not cfg.model_cache_file.exists():
        return [], "No cached model list found. Use 'Load/update model list from Google' first.", ""
    try:
        raw = json.loads(cfg.model_cache_file.read_text(encoding="utf-8", errors="replace"))
        models = [model_from_dict(item) for item in raw.get("models", [])]
        models = [model for model in models if model.model_id]
        updated_at = str(raw.get("updated_at", "unknown time"))
    except Exception as exc:
        return [], f"Could not read model cache: {exc}", ""
    if not models:
        return [], "Cached model list is empty. Use 'Load/update model list from Google'.", updated_at
    return models, None, updated_at


