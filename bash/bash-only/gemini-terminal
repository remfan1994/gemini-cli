}

# ==========================================================
# Model cache and parsing
# ==========================================================

fetch_models_live() {
  require_api_key || return 1
  mkdir -p "$(dirname "$MODEL_CACHE_FILE")"
  curl -sS --max-time 60 "https://generativelanguage.googleapis.com/v1beta/models?$(urlencode_key_query)&pageSize=100" -o "$MODEL_CACHE_FILE"
}

models_source() {
  if [ -f "$MODEL_CACHE_FILE" ]; then cat "$MODEL_CACHE_FILE"; else fetch_models_live >/dev/null && cat "$MODEL_CACHE_FILE"; fi
}

models_table() {
  # Output TSV: model_id display input output methods
  if have jq; then
    jq -r '.models[]? | [(.name|sub("^models/";"")), (.displayName // (.name|sub("^models/";""))), (.inputTokenLimit // 0), (.outputTokenLimit // 0), ((.supportedGenerationMethods // [])|join(","))] | @tsv'
    return
  fi
  # Best-effort no-jq fallback: extract model names, but not all metadata.
  grep -o '"name"[[:space:]]*:[[:space:]]*"models/[^"]*"' | sed 's/.*"models\///; s/"$//' | awk '{ print $0 "\t" $0 "\t0\t0\tunknown" }'
}

filtered_models_table() {
  models_source | models_table | awk -F '\t' \
    -v gen="$MODEL_FILTER_GENERATE_CONTENT" \
    -v req="$MODEL_FILTER_REQUIRE_TOKENS" \
    -v hide="$MODEL_FILTER_HIDE_PREVIEW" \
    -v minin="$MODEL_MIN_INPUT_TOKENS" \
    -v minout="$MODEL_MIN_OUTPUT_TOKENS" '
      function truthy(v){ return v=="1" || v=="yes" || v=="true" || v=="on" }
      {
        model=$1; display=$2; input=$3+0; output=$4+0; methods=$5
        if (truthy(gen) && methods != "unknown" && index(methods, "generateContent") == 0) next
        if (truthy(req) && (input <= 0 || output <= 0)) next
        if (truthy(hide) && (index(tolower(model), "preview") || index(tolower(model), "experimental") || index(tolower(model), "exp"))) next
        if (input < minin) next
        if (output < minout) next
        print
      }
    ' | case "$MODEL_SORT_ORDER" in
          model) sort -t $'\t' -k1,1 ;;
          input-desc) sort -t $'\t' -k3,3nr ;;
          output-desc) sort -t $'\t' -k4,4nr ;;
          *) cat ;;
        esac
}

print_models() { filtered_models_table | awk -F '\t' '{ printf "%s\t%s\tinput:%s\toutput:%s\t%s\n", $1, $2, $3, $4, $5 }'; }

# ==========================================================
# Gemini request/response
# ==========================================================

mime_for_file() {
  case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
    *.txt|*.md|*.log|*.csv|*.json|*.xml|*.html|*.css|*.js|*.sh|*.c|*.h|*.py) printf 'text/plain' ;;
    *.png) printf 'image/png' ;;
    *.jpg|*.jpeg) printf 'image/jpeg' ;;
    *.gif) printf 'image/gif' ;;
    *.webp) printf 'image/webp' ;;
    *.pdf) printf 'application/pdf' ;;
    *.mp3) printf 'audio/mpeg' ;;
    *.wav) printf 'audio/wav' ;;
    *.mp4) printf 'video/mp4' ;;
    *) printf 'application/octet-stream' ;;
  esac
}

base64_one_line() { if base64 --help 2>&1 | grep -q -- '-w'; then base64 -w 0 "$1"; else base64 "$1" | tr -d '\n'; fi; }

build_parts_json() {
  local prompt="$1" file mime escaped_prompt b64 size
  escaped_prompt="$(printf '%s' "$prompt" | json_escape_stream)"
  printf '[{"text":"%s"}' "$escaped_prompt"
  for file in "${PENDING_ATTACHMENTS[@]}"; do
    [ -f "$file" ] || continue
    size=$(wc -c < "$file" | tr -d ' ')
    if [ "$size" -gt "$MAX_ATTACHMENT_BYTES" ]; then
      printf ',{"text":"[attachment skipped: %s exceeds MAX_ATTACHMENT_BYTES]"}' "$(json_escape_value "$file")"
      continue
    fi
    mime="$(mime_for_file "$file")"
    if printf '%s' "$mime" | grep -q '^text/'; then
      printf ',{"text":"Attached file: %s\n%s"}' "$(json_escape_value "$file")" "$(cat "$file" | json_escape_stream)"
    else
      b64="$(base64_one_line "$file")"
      printf ',{"inlineData":{"mimeType":"%s","data":"%s"}}' "$mime" "$b64"
    fi
  done
  printf ']'
}

call_model() {
  local model="$1" prompt="$2" parts payload url response status
  require_api_key || return 1
  parts="$(build_parts_json "$prompt")"
  payload="{\"contents\":[{\"parts\":$parts}]}"
  url="https://generativelanguage.googleapis.com/v1beta/models/$(normalize_model_id "$model"):generateContent?$(urlencode_key_query)"
  response="$(printf '%s' "$payload" | curl -sS --max-time 120 -H 'Content-Type: application/json' -d @- "$url" 2>&1)"
  status=$?
  if [ "$status" -ne 0 ]; then printf 'curl error: %s\n' "$response"; return 1; fi
  extract_response_text "$response"
}

extract_response_text() {
  if have jq; then
    printf '%s' "$1" | jq -r '[.candidates[0].content.parts[]? | .text? // empty] | join("\n")'
    return
  fi
  printf '%s' "$1" | sed -n 's/.*"text"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | sed 's/\\n/\
/g; s/\\"/"/g; s/\\\\/\\/g' | head -1
}

# ==========================================================
# Sessions and memory
# ==========================================================

resolve_session_path() { printf '%s/%s.log\n' "$SESSION_DIR" "$1"; }
list_sessions() { for p in "$SESSION_DIR"/*.log; do [ -e "$p" ] && basename "$p" .log; done; }
add_context() { CONTEXT_BUFFER+=("$1"); trim_context; }
trim_context() { local max=$((CONTEXT_TURNS * 2)); while [ "${#CONTEXT_BUFFER[@]}" -gt "$max" ]; do CONTEXT_BUFFER=("${CONTEXT_BUFFER[@]:1}"); done; }
build_context() { local out="" item; for item in "${CONTEXT_BUFFER[@]}"; do [ -n "$out" ] && out="$out
"; out="$out$item"; done; printf '%s' "$out"; }
write_snapshot() { local ts item; ts="$(timestamp)"; printf '[%s] system: CONTEXT_BEGIN\n' "$ts" >> "$SESSION"; for item in "${CONTEXT_BUFFER[@]}"; do printf '%s\n' "$item" >> "$SESSION"; done; printf '[%s] system: CONTEXT_END\n' "$ts" >> "$SESSION"; }
load_context() { [ -f "$SESSION" ] || return 0; mapfile -t CONTEXT_BUFFER < <(grep -E '^\[[0-9:]+\] (Gemini|[^:]+): ' "$SESSION" | tail -n $((CONTEXT_TURNS * 2)) | sed -E 's/^\[[0-9:]+\] Gemini: /Assistant: /; s/^\[[0-9:]+\] [^:]+: /User: /'); }

# ==========================================================
# Commands
# ==========================================================

set_api_key() { printf 'Paste Gemini API key: '; IFS= read -r -s key; printf '\n'; [ -n "$key" ] && set_config_value GEMINI_API_KEY "$key"; }
config_summary() { cat "$CONFIG_FILE" 2>/dev/null || true; }
test_model() { local model="$1"; [ -z "$model" ] && { printf 'ERROR: model id required\n' >&2; return 2; }; call_model "$model" "$MODEL_TEST_PROMPT"; }
select_model() {
  local lines choice selected model ans line display input output methods i
  mapfile -t lines < <(filtered_models_table)
  [ "${#lines[@]}" -eq 0 ] && { printf 'No models available. Try --update-models.\n'; return 1; }
  i=1
  for line in "${lines[@]}"; do IFS=$'\t' read -r model display input output methods <<< "$line"; printf '%3d) %s - %s (input:%s output:%s)\n' "$i" "$model" "$display" "$input" "$output"; i=$((i+1)); done
  printf 'Select model number: '; IFS= read -r choice
  case "$choice" in ''|*[!0-9]*) printf 'Invalid selection.\n'; return 1 ;; esac
  [ "$choice" -lt 1 ] || [ "$choice" -gt "${#lines[@]}" ] && { printf 'Out of range.\n'; return 1; }
  selected="${lines[$((choice-1))]}"; IFS=$'\t' read -r model _ <<< "$selected"
  printf 'Test model now? [Y/n] '; IFS= read -r ans; case "$ans" in n|N|no|NO) ;; *) test_model "$model" ;; esac
  printf 'Save MODEL=%s? [y/N] ' "$model"; IFS= read -r ans; case "$ans" in y|Y|yes|YES) set_config_value MODEL "$model"; printf 'Saved.\n' ;; esac
}

# ==========================================================
# Argument parsing
# ==========================================================

ACTION=chat; SESSION_NAME=""; RESUME=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help|help) ACTION=help ;;
    --version) ACTION=version ;;
    --credits) ACTION=credits ;;
    --config) ACTION=config ;;
    --set) ACTION=set; SET_KEY="${2:-}"; SET_VALUE="${3:-}"; shift 2 ;;
    --unset) ACTION=unset; UNSET_KEY="${2:-}"; shift ;;
    --set-api-key) ACTION=set-api-key ;;
    --forget-api-key) ACTION=forget-api-key ;;
    --list) ACTION=list ;;
    --models) ACTION=models ;;
    --update-models) ACTION=update-models ;;
    --select-model) ACTION=select-model ;;
    --test-model) ACTION=test-model; TEST_MODEL="${2:-}"; shift ;;
    --attach) shift; [ -n "${1:-}" ] && PENDING_ATTACHMENTS+=("$1") ;;
    --resume) RESUME=1; shift; SESSION_NAME="${1:-}" ;;
    --) shift; break ;;
    -*) printf 'ERROR: unknown option %s\n' "$1" >&2; exit 2 ;;
    *) [ -z "$SESSION_NAME" ] && SESSION_NAME="$1" || { printf 'ERROR: unexpected argument %s\n' "$1" >&2; exit 2; } ;;
  esac
  shift
done

need_basic_tools
load_config

case "$ACTION" in
  help) help_menu; exit 0 ;;
  version) version; exit 0 ;;
  credits) credits; exit 0 ;;
  config) config_summary; exit 0 ;;
  set) [ -n "$SET_KEY" ] || exit 2; set_config_value "$SET_KEY" "$SET_VALUE"; exit 0 ;;
  unset) [ -n "$UNSET_KEY" ] || exit 2; unset_config_value "$UNSET_KEY"; exit 0 ;;
  set-api-key) set_api_key; exit $? ;;
  forget-api-key) unset_config_value GEMINI_API_KEY; exit 0 ;;
  list) list_sessions; exit 0 ;;
  update-models) fetch_models_live && printf 'Updated model cache: %s\n' "$MODEL_CACHE_FILE"; exit $? ;;
  models) print_models; exit $? ;;
  select-model) select_model; exit $? ;;
  test-model) test_model "$TEST_MODEL"; exit $? ;;
esac

require_api_key || exit 1
[ -z "$SESSION_NAME" ] && SESSION_NAME="session-$(date +%Y-%m-%d-%H-%M-%S)" || SESSION_NAME="$(sanitize_session_name "$SESSION_NAME")"
SESSION="$(resolve_session_path "$SESSION_NAME")"
[ "$RESUME" -eq 1 ] && [ ! -f "$SESSION" ] && { printf 'ERROR: session not found\n' >&2; exit 1; }
load_context
ACTIVE_MODEL="$(effective_model)"
SESSION_EMPTY=1; [ -s "$SESSION" ] && SESSION_EMPTY=0

printf '%s (%s)\n' "$PROGRAM" "$EDITION"
printf 'session: %s\n' "$SESSION"
printf 'model: %s\n' "$(model_label)"
printf 'Ctrl+D to send, Ctrl+C to exit\n\n'
if truthy "$STARTUP_NOTICE" && [ "$SESSION_EMPTY" -eq 1 ]; then
  printf '[%s] %s: %s\n\n' "$(timestamp)" "$PROJECT_LEAD_NAME" "$PROJECT_LEAD_NOTICE"
  printf '[%s] system: This is the message list window. The notice above will disappear when you start chatting, and messages to and from Gemini will appear here.\n\n' "$(timestamp)"
fi

while true; do
  TS="$(timestamp)"
  printf '[%s] %s> ' "$TS" "$USER_NAME"
  buffer="$(cat)"
  [ -z "$buffer" ] && continue
  printf '[%s] %s: %s\n' "$TS" "$USER_NAME" "$buffer" >> "$SESSION"
  add_context "User: $buffer"
  prompt="$(build_context)"
  printf '\n________________________________________\nEND INPUT\n________________________________________\n'
  printf '[%s] Generating response...\n' "$(timestamp)"
  printf '________________________________________\nBEGIN OUTPUT\n________________________________________\n\n'
  output="$(call_model "$ACTIVE_MODEL" "$prompt")" || output="(response error: $output)"
  [ -z "$output" ] && output="(empty response or API error)"
  printf '[%s] Gemini: %s\n' "$(timestamp)" "$output" >> "$SESSION"
  add_context "Assistant: $output"
  write_snapshot
  printf '%s\n\n' "$output"
  PENDING_ATTACHMENTS=()
done
