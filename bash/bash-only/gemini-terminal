# session-log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def describe_model_filter(model_filter: ModelFilter) -> str:
    parts = []
    if model_filter.require_token_limits:
        parts.append("token limits required")
    if model_filter.hide_preview_or_experimental:
        parts.append("preview/experimental hidden")
    if model_filter.min_input_tokens > 1:
        parts.append(f"min input {model_filter.min_input_tokens}")
    if model_filter.min_output_tokens > 1:
        parts.append(f"min output {model_filter.min_output_tokens}")
    if model_filter.sort_mode != "api":
        parts.append(f"sort {model_filter.sort_mode}")
    return ", ".join(parts) if parts else "no extra filters"


