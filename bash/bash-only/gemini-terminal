# MAINTAINER COMMENTARY: def apply_model_filters
# Filters model metadata for usability. This is the preferred alternative to autoscan/probing;
# use capabilities and token limits before testing a selected model.
# ------------------------------------------------------------
def apply_model_filters(models: List[ModelInfo], model_filter: ModelFilter) -> List[ModelInfo]:
    filtered: List[ModelInfo] = []

    for model in models:
        input_limit = model.input_token_limit or 0
        output_limit = model.output_token_limit or 0

        if model_filter.require_token_limits and (input_limit <= 0 or output_limit <= 0):
            continue
        if input_limit < model_filter.min_input_tokens:
            continue
        if output_limit < model_filter.min_output_tokens:
            continue
        if model_filter.hide_preview_or_experimental and model_has_preview_marker(model):
            continue

        filtered.append(model)

    if model_filter.sort_mode == "model":
        filtered.sort(key=lambda item: item.model_id)
    elif model_filter.sort_mode == "input-desc":
        filtered.sort(key=lambda item: (item.input_token_limit or 0, item.model_id), reverse=True)
    elif model_filter.sort_mode == "output-desc":
        filtered.sort(key=lambda item: (item.output_token_limit or 0, item.model_id), reverse=True)

    return filtered


