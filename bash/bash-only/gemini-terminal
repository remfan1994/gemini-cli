    def open_model_filter_menu(self) -> None:
        """Edit model-list metadata filters.

        These settings use only the model-list metadata returned by Google:
        supportedGenerationMethods, token limits, names, and descriptions. No
        model generation requests are sent from this screen.
        """
        selected = 0
        sort_orders = ["api", "name", "display", "input-desc", "output-desc"]

        while True:
            rows = [
                ("MODEL_FILTER_GENERATE_CONTENT", "bool", "Require generateContent support", self.cfg.model_filter_generate_content),
                ("MODEL_FILTER_REQUIRE_TOKENS", "bool", "Require input/output token limits > 0", self.cfg.model_filter_require_tokens),
                ("MODEL_FILTER_HIDE_PREVIEW", "bool", "Hide preview/experimental/beta models", self.cfg.model_filter_hide_preview),
                ("MODEL_MIN_INPUT_TOKENS", "int", "Minimum input tokens", str(self.cfg.model_min_input_tokens)),
                ("MODEL_MIN_OUTPUT_TOKENS", "int", "Minimum output tokens", str(self.cfg.model_min_output_tokens)),
                ("MODEL_SORT_ORDER", "choice", "Sort order", self.cfg.model_sort_order),
            ]
            selected = max(0, min(selected, len(rows) - 1))
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 6)
            self.safe_addstr(0, 0, "MODEL FILTERS", width, self.reverse_attr())
            self.safe_addstr(1, 0, "Space/Enter=toggle/cycle/edit | Esc/q=back | F-keys jump", width, self.dim_attr())
            self.safe_addstr(2, 0, "Uses listModels metadata; does not test/probe models.", width, self.dim_attr())
            self.safe_addstr(3, 0, "_" * width, width, self.dim_attr())

            for row in range(visible_h):
                idx = row
                if idx >= len(rows):
                    break
                _key, kind, label, value = rows[idx]
                attr = self.reverse_attr() if idx == selected else 0
                if kind == "bool":
                    mark = "[x]" if value else "[ ]"
                    line = f"{mark} {label}"
                else:
                    line = f"{label:<42} [{value}]"
                self.safe_addstr(4 + row, 0, line, width, attr)
            self.safe_addstr(height - 1, 0, "Model tests remain user-operated with t on one highlighted model.", width, self.dim_attr())
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch, current_action="models"):
                return
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - 1)
                    continue
                if delta < 0:
                    selected = min(len(rows) - 1, selected + 1)
                    continue
                if self.mouse_button1(state) and 4 <= y < 4 + len(rows):
                    selected = y - 4
                    ch = 10
                else:
                    continue
            if ch in (27, ord("q"), ord("Q")):
                self.status = "model filters closed"
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
                continue
            if ch == curses.KEY_DOWN:
                selected = min(len(rows) - 1, selected + 1)
                continue
            if ch not in (10, 13, curses.KEY_ENTER, ord(" ")):
                continue

            key, kind, _label, value = rows[selected]
            if kind == "bool":
                new_value = not bool(value)
                if key == "MODEL_FILTER_GENERATE_CONTENT":
                    self.cfg.model_filter_generate_content = new_value
                elif key == "MODEL_FILTER_REQUIRE_TOKENS":
                    self.cfg.model_filter_require_tokens = new_value
                elif key == "MODEL_FILTER_HIDE_PREVIEW":
                    self.cfg.model_filter_hide_preview = new_value
                set_config_value(self.cfg, key, "1" if new_value else "0")
                self.status = f"saved {key}"
            elif kind == "choice":
                current_idx = sort_orders.index(self.cfg.model_sort_order) if self.cfg.model_sort_order in sort_orders else 0
                self.cfg.model_sort_order = sort_orders[(current_idx + 1) % len(sort_orders)]
                set_config_value(self.cfg, key, self.cfg.model_sort_order)
                self.status = f"saved {key}={self.cfg.model_sort_order}"
            else:
                new_text = self.text_input_modal("MODEL FILTER", f"Edit {key}:", str(value))
                if new_text is not None:
                    if key == "MODEL_MIN_INPUT_TOKENS":
                        self.cfg.model_min_input_tokens = parse_positive_int(new_text, self.cfg.model_min_input_tokens)
                        set_config_value(self.cfg, key, str(self.cfg.model_min_input_tokens))
                    elif key == "MODEL_MIN_OUTPUT_TOKENS":
                        self.cfg.model_min_output_tokens = parse_positive_int(new_text, self.cfg.model_min_output_tokens)
                        set_config_value(self.cfg, key, str(self.cfg.model_min_output_tokens))
                    self.status = f"saved {key}"

