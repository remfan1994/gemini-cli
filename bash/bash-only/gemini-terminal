    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def show_message
    # Maintainer note for show_message: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def show_message(self, title: str, lines: List[str]) -> None:
        """Show a resolution-safe full-screen scrollable page.

        The earlier modal version could clip long text on small terminals.
        This page owns the whole screen, wraps all lines, and supports
        PgUp/PgDn, mousewheel, q/Esc, and any key to leave when content fits.
        """
        scroll = 0
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            body_h = max(1, height - 4)
            wrapped: List[str] = []
            for line in lines:
                if line == "":
                    wrapped.append("")
                else:
                    wrapped.extend(wrap_for_width(line, max(10, width)))

            max_scroll = max(0, len(wrapped) - body_h)
            scroll = max(0, min(scroll, max_scroll))

            self.safe_addstr(0, 0, title, width, self.reverse_attr())
            self.safe_addstr(1, 0, "_" * width, width, self.dim_attr())

            visible = wrapped[scroll:scroll + body_h]
            for idx, line in enumerate(visible):
                self.safe_addstr(2 + idx, 0, line, width)

            footer = "q/Esc=return | PgUp/PgDn/wheel=scroll"
            if max_scroll == 0:
                footer = "q/Esc/any key=return"
            self.safe_addstr(height - 1, 0, footer, width, self.reverse_attr())
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch):
                return
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, _x, _y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    scroll = max(0, scroll - MOUSE_SCROLL_LINES)
                    continue
                if delta < 0:
                    scroll = min(max_scroll, scroll + MOUSE_SCROLL_LINES)
                    continue
                return
            if ch in (27, ord("q"), ord("Q")):
                return
            if ch == curses.KEY_PPAGE:
                scroll = max(0, scroll - body_h)
                continue
            if ch == curses.KEY_NPAGE:
                scroll = min(max_scroll, scroll + body_h)
                continue
            if max_scroll == 0:
                return

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def ask_yes_no
    # Maintainer note for ask_yes_no: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def ask_yes_no(self, title: str, message: str, default: bool = False) -> bool:
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            box_w = min(width - 4, 76)
            box_h = 10
            top = max(0, (height - box_h) // 2)
            left = max(0, (width - box_w) // 2)
            self.safe_addstr(top, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            self.safe_addstr(top + 1, left, "|" + title.center(box_w - 2) + "|", attr=self.reverse_attr())
            self.safe_addstr(top + 2, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            y = top + 3
            for line in wrap_for_width(message, box_w - 4)[:3]:
                self.safe_addstr(y, left + 2, line, box_w - 4)
                y += 1
            default_label = "yes" if default else "no"
            self.safe_addstr(top + box_h - 2, left + 2, f"Y/N? Enter={default_label} | Esc=no", box_w - 4, self.dim_attr())
            self.safe_addstr(top + box_h - 1, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            # Function keys remain global even inside confirmation dialogs.
            # If the user opens the wrong screen, pressing another function
            # key should jump there immediately instead of trapping them here.
            if self.handle_global_hotkey(ch):
                return default
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, x, y_mouse, _z, state = curses.getmouse()
                except curses.error:
                    continue
                if self.mouse_button1(state) and top <= y_mouse <= top + box_h:
                    return x < left + (box_w // 2)
            if ch in (ord("y"), ord("Y")):
                return True
            if ch in (ord("n"), ord("N"), 27):
                return False
            if ch in (10, 13, curses.KEY_ENTER):
                return default

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def text_input_modal
    # Maintainer note for text_input_modal: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def text_input_modal(self, title: str, prompt: str, initial: str = "", secret: bool = False) -> Optional[str]:
        value = initial
        cursor = len(value)
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            box_w = min(width - 4, 84)
            box_h = 11
            top = max(0, (height - box_h) // 2)
            left = max(0, (width - box_w) // 2)
            shown_value = ("*" * max(0, len(value) - 4) + value[-4:]) if secret else value
            field_w = box_w - 6
            shown = shown_value[max(0, cursor - field_w + 1):][:field_w]
            self.safe_addstr(top, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            self.safe_addstr(top + 1, left, "|" + title.center(box_w - 2) + "|", attr=self.reverse_attr())
            self.safe_addstr(top + 2, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            for idx, line in enumerate(wrap_for_width(prompt, box_w - 4)[:3]):
                self.safe_addstr(top + 3 + idx, left + 2, line, box_w - 4)
            self.safe_addstr(top + 7, left + 2, " " * field_w, field_w, self.reverse_attr())
            self.safe_addstr(top + 7, left + 2, shown, field_w, self.reverse_attr())
            self.safe_addstr(top + 9, left + 2, "Enter=accept | Esc=cancel | Backspace=edit", box_w - 4, self.dim_attr())
            self.safe_addstr(top + 10, left, "+" + "-" * (box_w - 2) + "+", attr=self.reverse_attr())
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            # Function keys remain global even inside text entry dialogs.
            # This keeps F2/F3/F4/etc. as navigation tools everywhere in the UI.
            if self.handle_global_hotkey(ch):
                return None
            if ch in (10, 13, curses.KEY_ENTER):
                return value.strip()
            if ch == 27:
                return None
            if ch in (curses.KEY_BACKSPACE, 127, 8):
                if cursor > 0:
                    value = value[: cursor - 1] + value[cursor:]
                    cursor -= 1
            elif ch == curses.KEY_DC:
                if cursor < len(value):
                    value = value[:cursor] + value[cursor + 1:]
            elif ch == curses.KEY_LEFT:
                cursor = max(0, cursor - 1)
            elif ch == curses.KEY_RIGHT:
                cursor = min(len(value), cursor + 1)
            elif ch == curses.KEY_HOME:
                cursor = 0
            elif ch == curses.KEY_END:
                cursor = len(value)
            elif 32 <= ch <= 126:
                value = value[:cursor] + chr(ch) + value[cursor:]
                cursor += 1

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def run_external_editor
    # Maintainer note for run_external_editor: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def run_external_editor(self, initial_text: str, suffix: str = ".txt") -> Optional[str]:
        editor = self.cfg.effective_editor
        fd, path_str = tempfile.mkstemp(prefix="gemini-ncurses-python-", suffix=suffix)
        path = Path(path_str)
        try:
            with os.fdopen(fd, "w", encoding="utf-8") as fh:
                fh.write(initial_text)
            curses.def_prog_mode()
            curses.endwin()
            try:
                subprocess.call(shlex.split(editor) + [str(path)])
            finally:
                curses.reset_prog_mode()
                self.stdscr.keypad(True)
            return path.read_text(encoding="utf-8", errors="replace")
        except Exception as exc:
            self.status = f"editor error: {exc}"
            return None
        finally:
            try:
                path.unlink()
            except OSError:
                pass

