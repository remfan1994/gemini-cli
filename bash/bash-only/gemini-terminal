#!/usr/bin/env bash

# ==========================================================
# gemini-cli bash-only edition
# ----------------------------------------------------------
# Dependency-light Bash client for gemini-terminal-tools.
#
# VERSION
#   0.1.0
#
# PURPOSE
#   This edition is for systems that can run curl over HTTPS but should not
#   need Python. It is not a developer example and it is not intended to be a
#   toy curl wrapper. It is an end-user terminal chat client with sessions,
#   config, model discovery, model testing, context memory, logs, and basic
#   attachment support.
#
# REQUIRED TOOLS
#   bash, curl, awk, sed, grep, tr, mktemp, base64
#
# OPTIONAL TOOL
#   jq
#
# WHY JQ IS OPTIONAL
#   Gemini speaks JSON. Bash can assemble simple JSON, but JSON parsing is a
#   poor fit for shell. If jq is installed, this edition uses it for safer
#   model parsing and response extraction. If jq is missing, the script falls
#   back to best-effort sed/awk parsing so older or smaller machines can still
#   use the client.
#
# PROJECT POSTURE
#   The goal is not to reduce features to a one-shot curl command. The goal is
#   to keep dependencies light while preserving a usable terminal chat client.
# ==========================================================

set -o pipefail

PROGRAM="gemini-cli"
VERSION="0.1.0"
EDITION="bash-only"

CONFIG_DIR="${HOME}/.config/gemini-cli"
CONFIG_FILE="${CONFIG_DIR}/config"
CACHE_DIR="${HOME}/.cache/gemini-cli"
MODEL_CACHE_FILE="${CACHE_DIR}/models.json"

SESSION_DIR="${HOME}/.gpt"
ATTACHMENT_DIR=""
ATTACHMENT_DIR_CONFIGURED=0

FALLBACK_MODEL="gemini-2.5-flash"
MODEL=""
CONTEXT_TURNS=12
CONTEXT_TURNS_EXPLICIT=0
MODEL_TEST_PROMPT="Please reply with a short sentence confirming this model is available for text generation."
STARTUP_NOTICE=1
PROJECT_LEAD_NAME="remfan1994"
PROJECT_LEAD_NOTICE="I strongly encourage everyone to get cruetly-free VEGETARIAN food and remember the 'bloodguilt' curse from the Bible.  -Project Lead, remfan1994"
MAX_ATTACHMENT_BYTES=1048576

MODEL_FILTER_GENERATE_CONTENT=1
MODEL_FILTER_REQUIRE_TOKENS=0
MODEL_FILTER_HIDE_PREVIEW=0
MODEL_MIN_INPUT_TOKENS=0
MODEL_MIN_OUTPUT_TOKENS=0
MODEL_SORT_ORDER="api"

USER_NAME="$(whoami 2>/dev/null || printf '%s' user)"
CONTEXT_BUFFER=()
PENDING_ATTACHMENTS=()

# ==========================================================
# Basic helpers
# ==========================================================

timestamp() { date +"%H:%M:%S"; }

trim() { printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'; }

truthy() {
  case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
    1|yes|y|true|on) return 0 ;;
    *) return 1 ;;
  esac
}

have() { command -v "$1" >/dev/null 2>&1; }

need_basic_tools() {
  local missing=""
  for tool in curl awk sed grep tr mktemp base64; do
    if ! have "$tool"; then missing="$missing $tool"; fi
  done
  if [ -n "$missing" ]; then
    printf 'ERROR: missing required tools:%s\n' "$missing" >&2
    exit 1
  fi
}

normalize_model_id() {
  case "$1" in
    models/*) printf '%s\n' "${1#models/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

effective_model() { if [ -n "$MODEL" ]; then normalize_model_id "$MODEL"; else printf '%s\n' "$FALLBACK_MODEL"; fi; }
model_label() { if [ -n "$MODEL" ]; then normalize_model_id "$MODEL"; else printf '%s (fallback; no MODEL configured)\n' "$FALLBACK_MODEL"; fi; }

sanitize_session_name() {
  printf '%s' "$1" | sed 's/[^A-Za-z0-9._-]/_/g; s/^[._-]*//; s/[._-]*$//' | awk '{ if ($0 == "") print "session"; else print }'
}

urlencode_key_query() { printf 'key=%s' "$GEMINI_API_KEY"; }

json_escape_stream() {
  # Escape JSON string syntax without Python or jq. This is suitable for text
  # prompts and human-readable logs. The full bash/python3 edition is more
  # robust for arbitrary Unicode and deeply nested JSON handling.
  awk '
    BEGIN { first = 1 }
    {
      gsub(/\\/, "\\\\")
      gsub(/\"/, "\\\"")
      gsub(/\r/, "")
      gsub(/\t/, "\\t")
      if (!first) printf "\\n"
      printf "%s", $0
      first = 0
    }
  '
}

json_escape_value() { printf '%s' "$1" | json_escape_stream; }

positive_int_or_default() {
  case "$1" in ''|*[!0-9]*) printf '%s\n' "$2" ;; *) if [ "$1" -lt 1 ]; then printf '%s\n' "$2"; else printf '%s\n' "$1"; fi ;; esac
}

# ==========================================================
# Config loading/writing
# ==========================================================

load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      line="$(trim "$line")"
      case "$line" in ''|\#*) continue ;; esac
      case "$line" in *=*) key="$(trim "${line%%=*}")"; value="$(trim "${line#*=}")" ;; *) continue ;; esac
      case "$key" in
        MODEL) MODEL="$(normalize_model_id "$value")" ;;
        CONTEXT_TURNS) CONTEXT_TURNS="$value"; CONTEXT_TURNS_EXPLICIT=1 ;;
        HISTORY_LIMIT) [ "$CONTEXT_TURNS_EXPLICIT" -eq 0 ] && CONTEXT_TURNS="$value" ;;
        GEMINI_API_KEY) GEMINI_API_KEY="${GEMINI_API_KEY:-$value}" ;;
        SESSION_DIR) SESSION_DIR="${value/#\~/$HOME}" ;;
        ATTACHMENT_DIR) ATTACHMENT_DIR="${value/#\~/$HOME}"; ATTACHMENT_DIR_CONFIGURED=1 ;;
        MODEL_TEST_PROMPT) [ -n "$value" ] && MODEL_TEST_PROMPT="$value" ;;
        STARTUP_NOTICE) STARTUP_NOTICE="$value" ;;
        MAX_ATTACHMENT_BYTES) MAX_ATTACHMENT_BYTES="$value" ;;
        MODEL_CACHE_FILE) MODEL_CACHE_FILE="${value/#\~/$HOME}" ;;
        MODEL_FILTER_GENERATE_CONTENT) MODEL_FILTER_GENERATE_CONTENT="$value" ;;
        MODEL_FILTER_REQUIRE_TOKENS) MODEL_FILTER_REQUIRE_TOKENS="$value" ;;
        MODEL_FILTER_HIDE_PREVIEW) MODEL_FILTER_HIDE_PREVIEW="$value" ;;
        MODEL_MIN_INPUT_TOKENS) MODEL_MIN_INPUT_TOKENS="$value" ;;
        MODEL_MIN_OUTPUT_TOKENS) MODEL_MIN_OUTPUT_TOKENS="$value" ;;
        MODEL_SORT_ORDER) MODEL_SORT_ORDER="$value" ;;
      esac
    done < "$CONFIG_FILE"
  fi
  CONTEXT_TURNS="$(positive_int_or_default "$CONTEXT_TURNS" 12)"
  MAX_ATTACHMENT_BYTES="$(positive_int_or_default "$MAX_ATTACHMENT_BYTES" 1048576)"
  MODEL_MIN_INPUT_TOKENS="$(positive_int_or_default "$MODEL_MIN_INPUT_TOKENS" 0)"
  MODEL_MIN_OUTPUT_TOKENS="$(positive_int_or_default "$MODEL_MIN_OUTPUT_TOKENS" 0)"
  [ "$ATTACHMENT_DIR_CONFIGURED" -eq 0 ] && ATTACHMENT_DIR="$SESSION_DIR/attachments"
  mkdir -p "$CONFIG_DIR" "$CACHE_DIR" "$SESSION_DIR" "$ATTACHMENT_DIR"
}

set_config_value() {
  local key="$1" value="$2" tmp
  mkdir -p "$CONFIG_DIR"
  tmp="$(mktemp "${CONFIG_FILE}.tmp.XXXXXX")"
  if [ -f "$CONFIG_FILE" ]; then
    awk -v k="$key" -v v="$value" 'BEGIN{done=0} $0 ~ "^" k "=" {print k "=" v; done=1; next} {print} END{if(!done) print k "=" v}' "$CONFIG_FILE" > "$tmp"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp"
  fi
  mv "$tmp" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

unset_config_value() {
  local key="$1" tmp
  [ -f "$CONFIG_FILE" ] || return 0
  tmp="$(mktemp "${CONFIG_FILE}.tmp.XXXXXX")"
  awk -v k="$key" '$0 !~ "^" k "=" { print }' "$CONFIG_FILE" > "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

require_api_key() {
  if [ -z "$GEMINI_API_KEY" ]; then
    printf 'ERROR: GEMINI_API_KEY not set.\n\n' >&2
    printf 'Use: export GEMINI_API_KEY=your_key\n' >&2
    printf 'Or:  %s --set-api-key\n' "$PROGRAM" >&2
    return 1
  fi
}

# ==========================================================
# Help/version/credits
# ==========================================================

version() { printf '%s %s version %s\n' "$PROGRAM" "$EDITION" "$VERSION"; }

credits() {
  cat <<'CREDITS_EOF'
gemini-cli (bash-only)
Project: gemini-terminal-tools
GitHub: https://github.com/remfan1994/gemini-terminal-tools

I strongly encourage everyone to get cruetly-free VEGETARIAN food and remember the 'bloodguilt' curse from the Bible.  -Project Lead, remfan1994
CREDITS_EOF
}

help_menu() {
  cat <<HELP_EOF
$PROGRAM ($EDITION) - dependency-light terminal Gemini chat client

USAGE
    $PROGRAM [session]
    $PROGRAM --resume SESSION
    $PROGRAM --models
    $PROGRAM --update-models
