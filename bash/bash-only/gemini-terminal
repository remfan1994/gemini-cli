# MAINTAINER COMMENTARY: def fetch_models
# Network model discovery. This should be called only when the user asks to update/load models,
# not merely because they opened a screen.
# ------------------------------------------------------------
def fetch_models(cfg: Config) -> Tuple[List[ModelInfo], Optional[str]]:
    if not cfg.api_key:
        return [], "No Gemini API key loaded. Press F3 to paste an API key."

    models: List[ModelInfo] = []
    page_token = ""

    while True:
        query = {"key": cfg.api_key}
        if page_token:
            query["pageToken"] = page_token
        url = "https://generativelanguage.googleapis.com/v1beta/models?" + urllib.parse.urlencode(query)

        try:
            with urllib.request.urlopen(url, timeout=60) as response:
                body = response.read().decode("utf-8", errors="replace")
        except urllib.error.HTTPError as exc:
            body = exc.read().decode("utf-8", errors="replace")
            return [], f"Gemini model-list HTTP error {exc.code}: {body[:1000]}"
        except urllib.error.URLError as exc:
            return [], f"Gemini model-list network error: {exc}"
        except Exception as exc:
            return [], f"Gemini model-list request error: {exc}"

        try:
            parsed = json.loads(body)
        except Exception as exc:
            return [], f"Gemini model-list parse error: {exc}; raw response: {body[:1000]}"

        for raw in parsed.get("models", []):
            methods = list(raw.get("supportedGenerationMethods", []))
            if "generateContent" not in methods:
                continue
            api_name = raw.get("name", "")
            model_id = normalize_model_id(api_name)
            if not model_id:
                continue
            models.append(
                ModelInfo(
                    model_id=model_id,
                    api_name=api_name,
                    display_name=raw.get("displayName", model_id),
                    description=raw.get("description", ""),
                    input_token_limit=raw.get("inputTokenLimit"),
                    output_token_limit=raw.get("outputTokenLimit"),
                    methods=methods,
                )
            )

        page_token = parsed.get("nextPageToken", "")
        if not page_token:
            break

    unique: dict[str, ModelInfo] = {}
    for model in models:
        if model.model_id not in unique:
            unique[model.model_id] = model
    return list(unique.values()), None


