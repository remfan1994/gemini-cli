# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def main
# Program bootstrap. Keep this thin: parse args, prepare config/dirs, run simple non-interactive
# commands, then hand control to curses.
# ------------------------------------------------------------
def main() -> int:
    args = parse_args()
    if args.version:
        print(f"{PROGRAM} version {VERSION}")
        return 0

    cfg = load_config()
    cfg.session_dir.mkdir(parents=True, exist_ok=True)
    cfg.effective_attachment_dir.mkdir(parents=True, exist_ok=True)

    if args.list:
        list_sessions(cfg.session_dir)
        return 0
    if args.models:
        return print_models(cfg)
    if args.update_models:
        return update_models_command(cfg)
    if args.doctor:
        return print_doctor(cfg)
    if args.test_model:
        return print_model_test(cfg, args.test_model)
    if args.resume and args.session_name:
        print("error: use either a session name or --resume, not both", file=sys.stderr)
        return 2

    if args.resume:
        session_name = sanitize_session_name(args.resume)
        session_path = cfg.session_dir / f"{session_name}.log"
        if not session_path.exists():
            print(f"error: session not found: {session_name}", file=sys.stderr)
            return 1
    elif args.session_name:
        session_name = sanitize_session_name(args.session_name)
        session_path = cfg.session_dir / f"{session_name}.log"
    else:
        session_name = default_session_name()
        session_path = cfg.session_dir / f"{session_name}.log"

    app = GeminiCursesApp(cfg, session_name, session_path)
    try:
        curses.wrapper(app.run)
    except KeyboardInterrupt:
        return 0
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
