    # MAINTAINER COMMENTARY: def rename_session
    # Maintainer note for rename_session: this routine is part of the long-term public behavior
    # of the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def rename_session(self, old_name: str, new_name: str) -> None:
        new_name = sanitize_session_name(new_name)
        old_path = self.cfg.session_dir / f"{old_name}.log"
        new_path = self.cfg.session_dir / f"{new_name}.log"
        if new_path.exists() and new_path != old_path:
            self.show_message("RENAME SESSION", [f"Target already exists: {new_name}"])
            return
        if old_path.exists():
            old_path.rename(new_path)
        # Rename attachment prefixes for consistency.
        for path in self.attachment_dir.glob(f"{old_name}-*"):
            path.rename(self.attachment_dir / (new_name + path.name[len(old_name):]))
        if old_name == self.session_name:
            self.session_name = new_name
            self.session_path = new_path
        self.status = f"renamed session: {old_name} -> {new_name}"

