        if error:
            models, error = fetch_models(cfg)
            if error:
                print(f"ERROR: {error}", file=sys.stderr)
                return 1
            save_model_cache(cfg, models)

    visible = filter_model_list(cfg, models)
    print(f"# {model_filter_summary(cfg, len(models), len(visible))}", file=sys.stderr)
    for model in visible:
        print(
            f"{model.model_id}\t{model.display_name or model.model_id}\t"
            f"input:{model.input_token_limit or '?'}\toutput:{model.output_token_limit or '?'}\t"
            f"methods:{','.join(model.methods or [])}"
        )
    return 0


