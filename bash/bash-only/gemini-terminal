                    selected = y - 4
                    ch = 10
                else:
                    continue
            if ch in (27, ord("q"), ord("Q")):
                self.status = "editor menu closed"
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1); continue
            if ch == curses.KEY_DOWN:
                selected = min(len(items) - 1, selected + 1); continue
            if ch not in (10, 13, curses.KEY_ENTER):
                continue

            _name, _label, value = items[selected]
            if value == "__quit__":
                self.status = "editor menu closed"
                return
            if value == "__custom__":
                entered = self.text_input_modal("CUSTOM EDITOR", "Enter editor command or executable path.", initial=custom_editor)
                if entered:
                    custom_editor = entered
                    self.cfg.editor = entered
                    self.status = f"editor selected: {entered}"
                continue
            if value == "__browse__":
                chosen = self.browse_for_editor()
                if chosen:
                    custom_editor = chosen
                    self.cfg.editor = chosen
                    self.status = f"editor selected: {chosen}"
                continue
            if value == "__save__":
                if custom_editor:
                    set_config_value(self.cfg, "EDITOR", custom_editor)
                    self.cfg.editor = custom_editor
                    self.status = f"editor saved: {custom_editor}"
                continue
            if value == "__open__":
                selected_editor = custom_editor
            else:
                selected_editor = value
                custom_editor = value
                self.cfg.editor = value
                self.status = f"editor selected: {value}"

            old_editor = self.cfg.editor
            self.cfg.editor = selected_editor
            edited = self.run_external_editor(self.current_input())
            self.cfg.editor = old_editor if value == "__open__" else self.cfg.editor
            if edited is not None:
                self.input_lines = edited.rstrip("\n").splitlines() or [""]
                self.cursor_row = len(self.input_lines) - 1
                self.cursor_col = len(self.input_lines[-1])
                self.status = "input loaded from external editor"
            return

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def open_external_editor_for_input
