    # ------------------------------------------------------------
    def move_right(self) -> None:
        line = self.input_lines[self.cursor_row]
        if self.cursor_col < len(line): self.cursor_col += 1
        elif self.cursor_row < len(self.input_lines) - 1: self.cursor_row += 1; self.cursor_col = 0

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def move_up
    # Maintainer note for move_up: this routine is part of the long-term public behavior of the
    # program. When changing it, check callers, documentation, config compatibility, session-log
    # compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def move_up(self) -> None:
        if self.cursor_row > 0:
            self.cursor_row -= 1; self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def move_down
    # Maintainer note for move_down: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def move_down(self) -> None:
        if self.cursor_row < len(self.input_lines) - 1:
            self.cursor_row += 1; self.cursor_col = min(self.cursor_col, len(self.input_lines[self.cursor_row]))

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def clear_input
    # Maintainer note for clear_input: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def clear_input(self) -> None:
        self.input_lines = [""]; self.cursor_row = 0; self.cursor_col = 0; self.input_scroll = 0

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def current_input
    # Maintainer note for current_input: this routine is part of the long-term public behavior
    # of the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def current_input(self) -> str:
        return "\n".join(self.input_lines).strip("\n")

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def send_current_message
    # Message send path. This is where UI text becomes session log entries, memory context,
    # Gemini request parts, and visible transcript output.
    # ------------------------------------------------------------
    def send_current_message(self) -> None:
        message = self.current_input()
        if not message.strip() and not self.pending_attachments:
            self.status = "empty message ignored"
            self.clear_input()
            return
        if not message.strip() and self.pending_attachments:
            message = "Please review the attached file(s)."

        user_time = now_time()
        attachment_note = ""
        if self.pending_attachments:
            attachment_note = "\n[Pending attachments sent: " + ", ".join(p.path.name for p in self.pending_attachments) + "]"
        self.transcript.append(TranscriptItem(self.username, message + attachment_note, user_time))
        append_log(self.session_path, self.username, message + attachment_note, user_time)
        self.context_buffer.append("User: " + message + attachment_note)
        self.trim_context_buffer()
        self.clear_input()
        self.transcript_scroll = 0
        self.status = "Generating response..."
        self.draw()

        context = self.build_context()
        prompt_text = (context + "\n" if context else "") + "User: " + message
        attachments_to_send = list(self.pending_attachments)
        raw_output = call_gemini(self.cfg, prompt_text, self.session_name, self.attachment_dir, attachments_to_send)
        self.pending_attachments = []

        gemini_time = now_time()
        append_log(self.session_path, "Gemini", raw_output, gemini_time)
        cleaned_output = extract_code_attachments(raw_output, self.attachment_dir, self.session_name)
        self.context_buffer.append("Assistant: " + cleaned_output)
        self.trim_context_buffer()
        self.save_context_snapshot()
        self.transcript.append(TranscriptItem("Gemini", cleaned_output, gemini_time))
        self.status = "response complete"

