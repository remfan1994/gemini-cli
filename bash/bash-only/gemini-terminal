    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def detected_editors
    # Maintainer note for detected_editors: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def detected_editors(self) -> List[Tuple[str, str]]:
        """Return common editors that are actually runnable from PATH.

        The project goal is a friendly terminal client, so F8 should not assume
        the user remembers the exact path to their editor. This helper finds
        common editors with shutil.which(), which answers the practical
        question: can this command be launched from this terminal session?
        """
        names = ["vim", "vi", "nano", "pico", "micro", "emacs", "mg", "ed"]
        found: List[Tuple[str, str]] = []
        seen = set()
        for name in names:
            path = shutil.which(name)
            if path and path not in seen:
                found.append((name, path))
                seen.add(path)
        return found

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def browse_for_editor
    # Maintainer note for browse_for_editor: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def browse_for_editor(self) -> Optional[str]:
        """Browse common executable directories for an editor command.

        This is intentionally similar to an old "Run... Browse" dialog: the
        user can select an executable file without typing its full path.
        """
        for start in [Path("/usr/bin"), Path("/bin"), Path("/usr/local/bin"), Path.home()]:
            if start.exists():
                chosen = self.file_browser("BROWSE FOR EDITOR EXECUTABLE", start)
                if chosen is not None:
                    return str(chosen)
        return None

