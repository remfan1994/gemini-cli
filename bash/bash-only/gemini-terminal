# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def doctor_report
# Diagnostics gather environmental facts without sending chat prompts. This helps distinguish
# app bugs from DNS, API-key, terminal-size, or filesystem problems.
# ------------------------------------------------------------
def doctor_report(cfg: Config) -> List[DoctorResult]:
    """Return diagnostics as structured rows.

    The report never prints API-key values. It does not call generateContent.
    """
    rows: List[DoctorResult] = []

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def add
    # Maintainer note for add: this routine is part of the long-term public behavior of the
    # program. When changing it, check callers, documentation, config compatibility, session-log
    # compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def add(status: str, label: str, detail: str) -> None:
        rows.append(DoctorResult(status, label, detail))

    add("OK", "program", f"{PROGRAM} {VERSION}")
    add("OK", "python", platform.python_version())
    add("OK", "platform", platform.platform())
    add("OK", "curses", "module imported")

    term = os.environ.get("TERM", "")
    add("OK" if term else "WARN", "TERM", term or "TERM is not set")
    size = shutil.get_terminal_size(fallback=(0, 0))
    add("OK" if size.columns >= 40 and size.lines >= 12 else "WARN", "terminal-size", f"{size.columns}x{size.lines}")
    add("OK" if cfg.api_key else "WARN", "api-key", "loaded from environment/config" if cfg.api_key else "not loaded; F3 or GEMINI_API_KEY required")

    ok, detail = check_writable_directory(cfg.session_dir)
    add("OK" if ok else "FAIL", "session-dir", detail)
    ok, detail = check_writable_directory(cfg.effective_attachment_dir)
    add("OK" if ok else "FAIL", "attachment-dir", detail)
    ok, detail = check_writable_directory(cfg.model_cache_file.parent)
    add("OK" if ok else "FAIL", "model-cache-dir", detail)

    if cfg.config_file.exists():
        add("OK" if os.access(cfg.config_file, os.R_OK) else "FAIL", "config-file", f"readable: {cfg.config_file}")
    else:
        add("WARN", "config-file", f"not found yet: {cfg.config_file}")

    ok, detail = model_cache_summary(cfg)
    add("OK" if ok else "WARN", "model-cache", detail)

    ok, detail = resolve_command(cfg.effective_editor)
    add("OK" if ok else "WARN", "editor", f"{cfg.effective_editor} -> {detail}")

    ok, detail = check_dns()
    add("OK" if ok else "WARN", "dns", detail)
    add("WARN", "model-endpoint", "not contacted by --doctor; use --update-models to refresh cache")
    return rows


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def doctor_lines
# Maintainer note for doctor_lines: this routine is part of the long-term public behavior of the
# program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def doctor_lines(cfg: Config) -> List[str]:
    lines = [
        "gemini-ncurses-python diagnostics",
        "",
        "OK = ready, WARN = check recommended, FAIL = likely broken",
        "",
    ]
    for row in doctor_report(cfg):
        lines.append(f"[{row.status:<4}] {row.label:<18} {row.detail}")
    lines.append("")
    lines.append("This report never prints API-key values.")
    return lines


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def print_doctor
# Maintainer note for print_doctor: this routine is part of the long-term public behavior of the
# program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def print_doctor(cfg: Config) -> int:
    rows = doctor_report(cfg)
    for line in doctor_lines(cfg):
        print(line)
    return 1 if any(row.status == "FAIL" for row in rows) else 0


