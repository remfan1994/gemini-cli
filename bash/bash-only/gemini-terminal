EXT_MAP = {
    "bash": ".sh", "sh": ".sh", "shell": ".sh", "python": ".py", "py": ".py",
    "json": ".json", "yaml": ".yml", "yml": ".yml", "javascript": ".js", "js": ".js",
    "html": ".html", "css": ".css", "sql": ".sql", "c": ".c", "cpp": ".cpp",
    "c++": ".cpp", "text": ".txt",
}
FENCE_RE = re.compile(r"```([A-Za-z0-9_+.#-]*)[ \t]*\n(.*?)```", re.DOTALL)


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def safe_attachment_tag
# Maintainer note for safe_attachment_tag: this routine is part of the long-term public behavior
# of the program. When changing it, check callers, documentation, config compatibility, session-
# log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def safe_attachment_tag(lang: str) -> str:
    lang = lang.strip().lower() or "text"
    lang = lang.replace("+", "p").replace("#", "sharp")
    lang = re.sub(r"[^A-Za-z0-9._-]+", "_", lang)
    return lang or "text"


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def next_attachment_number
# Maintainer note for next_attachment_number: this routine is part of the long-term public
# behavior of the program. When changing it, check callers, documentation, config compatibility,
# session-log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def next_attachment_number(attachment_dir: Path, session_name: str, lang: str, ext: str) -> int:
    pattern = re.compile(rf"^{re.escape(session_name)}-{re.escape(lang)}-(\d{{2,}}){re.escape(ext)}$")
    highest = 0
    for path in attachment_dir.glob(f"{session_name}-{lang}-*{ext}"):
        match = pattern.match(path.name)
        if match:
            highest = max(highest, int(match.group(1)))
    return highest + 1


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def extract_code_attachments
# Converts fenced code blocks into files. This keeps the transcript readable while preserving
# useful artifacts for editors and shells.
# ------------------------------------------------------------
def extract_code_attachments(text: str, attachment_dir: Path, session_name: str) -> str:
    attachment_dir.mkdir(parents=True, exist_ok=True)

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def replacement
    # Maintainer note for replacement: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def replacement(match: re.Match[str]) -> str:
        raw_lang = match.group(1).strip().lower() or "text"
        lang = safe_attachment_tag(raw_lang)
        content = match.group(2)
        ext = EXT_MAP.get(raw_lang, EXT_MAP.get(lang, ".txt"))
        number = next_attachment_number(attachment_dir, session_name, lang, ext)
        filename = f"{session_name}-{lang}-{number:02d}{ext}"
        path = attachment_dir / filename
        path.write_text(content, encoding="utf-8")
        return f"\n[attachment saved]\nfile: {filename}\nlocation: {attachment_dir}\n"

    return FENCE_RE.sub(replacement, text)


