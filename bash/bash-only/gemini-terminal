    def open_memory_menu(self) -> None:
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            choices = ["v view memory", "e edit memory in external editor", "c clear memory", "r rebuild from log", "q cancel"]
            self.safe_addstr(0, 0, "MEMORY MENU", width, self.reverse_attr())
            self.safe_addstr(1, 0, f"Context entries: {len(self.context_buffer)} | CONTEXT_TURNS={self.cfg.context_turns}", width)
            for idx, item in enumerate(choices):
                self.safe_addstr(3 + idx, 0, item, width)
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch, current_action="memory"):
                return
            if ch in (ord("q"), ord("Q"), 27): return
            if ch in (ord("v"), ord("V")):
                self.show_message("CURRENT MEMORY", self.context_buffer or ["Memory is empty."])
            elif ch in (ord("e"), ord("E")):
                edited = self.run_external_editor("\n".join(self.context_buffer))
                if edited is not None:
                    self.context_buffer = [line for line in edited.splitlines() if line.strip()]
                    self.trim_context_buffer()
                    self.save_context_snapshot()
                    self.status = "memory edited and snapshot saved"
                    return
            elif ch in (ord("c"), ord("C")):
                if self.ask_yes_no("CLEAR MEMORY", "Clear current memory context? Logs are not deleted.", default=False):
                    self.context_buffer = []
                    self.save_context_snapshot()
                    self.status = "memory cleared"
                    return
            elif ch in (ord("r"), ord("R")):
                self.context_buffer = []
                entries = load_log_entries(self.session_path)
                snapshot = latest_context_snapshot(entries)
                if snapshot:
                    self.context_buffer = snapshot
                else:
                    max_entries = self.cfg.context_turns * 2
                    for entry in entries[-max_entries:]:
                        if is_snapshot_entry(entry) or entry.speaker == "system": continue
                        self.context_buffer.append(("Assistant: " if entry.speaker == "Gemini" else "User: ") + entry.text)
                self.trim_context_buffer()
                self.status = "memory rebuilt from log"
                return

