    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def input_segments(self, width: int) -> Tuple[List[InputSegment], int, int]:
        marker_width = 2
        available = max(1, width - marker_width)
        segments: List[InputSegment] = []
        cursor_visual_index = 0
        cursor_x = marker_width

        for logical_row, line in enumerate(self.input_lines):
            cursor_segment = self.cursor_col // available if logical_row == self.cursor_row else 0
            segment_count = max(1, (len(line) + available - 1) // available)
            if logical_row == self.cursor_row:
                segment_count = max(segment_count, cursor_segment + 1)

            for segment in range(segment_count):
                start = segment * available
                marker = "> " if logical_row == 0 and segment == 0 else "  "
                chunk = line[start : start + available]
                segments.append(InputSegment(marker + chunk, logical_row, start, available))
                if logical_row == self.cursor_row and segment == cursor_segment:
                    cursor_visual_index = len(segments) - 1
                    cursor_x = marker_width + (self.cursor_col % available)

        return segments or [InputSegment("> ", 0, 0, max(1, width - 2))], cursor_visual_index, cursor_x

