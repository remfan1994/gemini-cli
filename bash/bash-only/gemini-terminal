    # MAINTAINER COMMENTARY: def open_help
    # F1 command surface. This is not just documentation; it is a launch pad for the app
    # features.
    # ------------------------------------------------------------
    def open_help(self) -> None:
        # F1 is now an actionable command menu, not only a static help page.
        # Function keys work while this menu is open, Enter launches the
        # highlighted command, and mouse clicks launch rows directly.
        selected = 0
        top_index = 0
        items = self.command_items()
        while True:
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 7)
            self.safe_addstr(0, 0, "F1 HELP / COMMAND MENU", width, self.reverse_attr())
            self.safe_addstr(1, 0, "Enter/click=launch | F2-F10 work here | Ctrl+G=send | Esc/q=return", width, self.dim_attr())
            self.safe_addstr(2, 0, "_" * width, width, self.dim_attr())

            if selected < top_index:
                top_index = selected
            elif selected >= top_index + visible_h:
                top_index = selected - visible_h + 1

            for row in range(visible_h):
                idx = top_index + row
                if idx >= len(items):
                    break
                key, desc, action = items[idx]
                attr = self.reverse_attr() if idx == selected else 0
                self.safe_addstr(3 + row, 0, f"{key:<8} {desc}", width, attr)

            footer = "Mousewheel/PgUp/PgDn=scroll | Enter/click=launch | q/Esc=return"
            self.safe_addstr(height - 2, 0, "_" * width, width, self.dim_attr())
            self.safe_addstr(height - 1, 0, footer, width, self.reverse_attr())
            self.stdscr.refresh()

            ch = self.stdscr.getch()
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - MOUSE_SCROLL_LINES)
                    continue
                if delta < 0:
                    selected = min(len(items) - 1, selected + MOUSE_SCROLL_LINES)
                    continue
                if self.mouse_button1(state) and 3 <= y < 3 + visible_h:
                    idx = top_index + (y - 3)
                    if 0 <= idx < len(items):
                        selected = idx
                        self.run_command(items[selected][2])
                        return
                continue

            if ch in (27, ord("q"), ord("Q")):
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN:
                selected = min(len(items) - 1, selected + 1)
            elif ch == curses.KEY_PPAGE:
                selected = max(0, selected - visible_h)
            elif ch == curses.KEY_NPAGE:
                selected = min(len(items) - 1, selected + visible_h)
            elif ch == curses.KEY_HOME:
                selected = 0
            elif ch == curses.KEY_END:
                selected = len(items) - 1
            elif ch in (10, 13, curses.KEY_ENTER):
                self.run_command(items[selected][2])
                return
            elif ch in (ord("d"), ord("D")):
                self.run_command("doctor")
                return
            elif ch == curses.KEY_F1:
                continue
            elif ch == curses.KEY_F2:
                self.run_command("models"); return
            elif ch == curses.KEY_F3:
                self.run_command("api_key"); return
            elif ch == curses.KEY_F4:
                self.run_command("sessions"); return
            elif ch == curses.KEY_F5:
                self.run_command("options"); return
            elif ch == curses.KEY_F6:
                self.run_command("memory"); return
            elif ch == curses.KEY_F7:
                self.run_command("files"); return
            elif ch == curses.KEY_F8:
                self.run_command("editor"); return
            elif ch == curses.KEY_F9:
                self.run_command("credits"); return
            elif ch in (curses.KEY_F10, 17):
                self.run_command("quit"); return
            elif ch == 7:
                self.run_command("send"); return

