    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def handle_key
    # Maintainer note for handle_key: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def handle_key(self, ch: int) -> None:
        if ch == curses.KEY_MOUSE:
            self.handle_mouse()
            return

        action = self.action_for_function_key(ch)
        if action:
            self.dispatch_command_action(action)
            return

        if ch == 7:  # Ctrl+G sends. F5 is Options, not send.
            self.send_current_message()
            return

        if ch == 17:  # Ctrl+Q
            self.should_quit = True
            return
        if ch in (10, 13, curses.KEY_ENTER): self.insert_newline()
        elif ch in (curses.KEY_BACKSPACE, 127, 8): self.backspace()
        elif ch == curses.KEY_DC: self.delete_forward()
        elif ch == curses.KEY_LEFT: self.move_left()
        elif ch == curses.KEY_RIGHT: self.move_right()
        elif ch == curses.KEY_UP: self.move_up()
        elif ch == curses.KEY_DOWN: self.move_down()
        elif ch == curses.KEY_HOME: self.cursor_col = 0
        elif ch == curses.KEY_END: self.cursor_col = len(self.input_lines[self.cursor_row])
        elif ch == curses.KEY_PPAGE: self.transcript_scroll += 10
        elif ch == curses.KEY_NPAGE: self.transcript_scroll = max(0, self.transcript_scroll - 10)
        elif ch == 21: self.clear_input()
        elif ch == 12: pass
        elif ch == 9: self.insert_text("    ")
        elif 32 <= ch <= 126: self.insert_text(chr(ch))

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def run
    # Maintainer note for run: this routine is part of the long-term public behavior of the
    # program. When changing it, check callers, documentation, config compatibility, session-log
    # compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def run(self, stdscr: curses.window) -> None:
        self.stdscr = stdscr
        curses.noecho(); curses.cbreak(); stdscr.keypad(True)
        mouse_mask = curses.ALL_MOUSE_EVENTS | getattr(curses, "REPORT_MOUSE_POSITION", 0)
        try: curses.mousemask(mouse_mask)
        except curses.error: pass
        self.load_session_into_ui()
        if not self.cfg.api_key: self.status = "No API key loaded. Press F3 to paste one."
        elif not self.cfg.model: self.status = "No MODEL configured. Press F2 to choose/test one."
        while not self.should_quit:
            self.draw()
            try: ch = stdscr.getch()
            except KeyboardInterrupt: break
            self.handle_key(ch)


