    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def file_picker(self, start_dir: Path, title: str) -> Optional[Path]:
        current = start_dir.expanduser().resolve()
        selected = 0
        top_index = 0
        while True:
            try:
                entries = [current.parent] + sorted(current.iterdir(), key=lambda p: (not p.is_dir(), p.name.lower()))
            except OSError as exc:
                self.show_message(title, [f"Cannot read directory: {exc}"])
                return None
            selected = min(selected, len(entries) - 1)
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 5)
            self.safe_addstr(0, 0, title, width, self.reverse_attr())
            self.safe_addstr(1, 0, f"Directory: {current}", width)
            self.safe_addstr(2, 0, "Enter=open/select | Esc/q=cancel | wheel=scroll", width, self.dim_attr())
            if selected < top_index: top_index = selected
            elif selected >= top_index + visible_h: top_index = selected - visible_h + 1
            for row in range(visible_h):
                idx = top_index + row
                if idx >= len(entries): break
                p = entries[idx]
                label = "../" if idx == 0 else (p.name + ("/" if p.is_dir() else ""))
                attr = self.reverse_attr() if idx == selected else 0
                self.safe_addstr(3 + row, 0, label, width, attr)
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch, current_action="files"):
                return None
            if ch == curses.KEY_MOUSE:
                try: _mid, _x, y, _z, state = curses.getmouse()
                except curses.error: continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0: selected = max(0, selected - MOUSE_SCROLL_LINES)
                elif delta < 0: selected = min(len(entries) - 1, selected + MOUSE_SCROLL_LINES)
                elif self.mouse_button1(state) and 3 <= y < 3 + visible_h:
                    idx = top_index + (y - 3)
                    if 0 <= idx < len(entries): selected = idx
                continue
            if ch in (27, ord("q"), ord("Q")): return None
            if ch == curses.KEY_UP: selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN: selected = min(len(entries) - 1, selected + 1)
            elif ch in (10, 13, curses.KEY_ENTER):
                chosen = entries[selected]
                if chosen.is_dir():
                    current = chosen.resolve(); selected = 0; top_index = 0
                else:
                    return chosen

