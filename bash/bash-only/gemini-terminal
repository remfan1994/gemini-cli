# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def build_gemini_parts
# Builds REST request parts. Keep text/media separation clear so maintainers can adapt when
# Gemini changes MIME or file handling rules.
# ------------------------------------------------------------
def build_gemini_parts(prompt_text: str, attachments: List[PendingAttachment]) -> List[dict]:
    parts: List[dict] = [{"text": prompt_text}]

    for item in attachments:
        path = item.path
        mime_type = item.mime_type
        try:
            size = path.stat().st_size
        except OSError:
            parts.append({"text": f"\n[Attachment unavailable: {path}]"})
            continue

        if size > MAX_INLINE_ATTACHMENT_BYTES:
            parts.append({"text": f"\n[Attachment skipped because it is larger than {MAX_INLINE_ATTACHMENT_BYTES} bytes: {path.name}]"})
            continue

        if mime_type.startswith("text/") or mime_type in {"application/json", "application/xml", "application/x-yaml"}:
            try:
                content = path.read_text(encoding="utf-8", errors="replace")
            except OSError as exc:
                content = f"[Could not read attachment: {exc}]"
            parts.append({"text": f"\n\n[Attached text file: {path.name}]\n{content}"})
        else:
            try:
                data = base64.b64encode(path.read_bytes()).decode("ascii")
            except OSError as exc:
                parts.append({"text": f"\n[Could not read binary attachment {path.name}: {exc}]"})
                continue
            parts.append({"inline_data": {"mime_type": mime_type, "data": data}})

    return parts


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def save_inline_response_parts
# Saves generated inline data from Gemini. Models may or may not return media; this code must be
# defensive and never assume text-only output forever.
# ------------------------------------------------------------
def save_inline_response_parts(parsed: dict, attachment_dir: Path, session_name: str) -> str:
    notices: List[str] = []
    attachment_dir.mkdir(parents=True, exist_ok=True)
    candidates = parsed.get("candidates", [])
    for c_index, candidate in enumerate(candidates, start=1):
        parts = candidate.get("content", {}).get("parts", [])
        for p_index, part in enumerate(parts, start=1):
            inline = part.get("inline_data") or part.get("inlineData")
            if not inline:
                continue
            mime_type = inline.get("mime_type") or inline.get("mimeType") or "application/octet-stream"
            data = inline.get("data", "")
            if not data:
                continue
            ext = mime_extension(mime_type)
            filename = f"{session_name}-response-{c_index:02d}-{p_index:02d}{ext}"
            path = attachment_dir / filename
            try:
                path.write_bytes(base64.b64decode(data))
                notices.append(f"[response attachment saved]\nfile: {filename}\nlocation: {attachment_dir}")
            except Exception as exc:
                notices.append(f"[response attachment save failed: {exc}]")
    return "\n".join(notices)


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def parse_generated_text_and_files
# Maintainer note for parse_generated_text_and_files: this routine is part of the long-term
# public behavior of the program. When changing it, check callers, documentation, config
# compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def parse_generated_text_and_files(body: str, attachment_dir: Path, session_name: str) -> str:
    parsed = json.loads(body)
    text_chunks: List[str] = []
    for candidate in parsed.get("candidates", []):
        for part in candidate.get("content", {}).get("parts", []):
            if "text" in part:
                text_chunks.append(part.get("text", ""))
    text = "\n".join(chunk for chunk in text_chunks if chunk)
    notices = save_inline_response_parts(parsed, attachment_dir, session_name)
    if notices:
        text = text + ("\n\n" if text else "") + notices
    return text


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def generate_with_model
# Single Gemini generation request. All request-part construction funnels through this area so
# attachments, text prompts, and future media behavior stay centralized.
# ------------------------------------------------------------
def generate_with_model(
    cfg: Config,
    model_id: str,
    prompt_text: str,
    session_name: str,
    attachment_dir: Path,
    attachments: Optional[List[PendingAttachment]] = None,
    timeout: int = 120,
) -> Tuple[bool, str]:
    if not cfg.api_key:
        return False, "No Gemini API key loaded. Press F3 to paste an API key."

    payload = {"contents": [{"parts": build_gemini_parts(prompt_text, attachments or [])}]}
    data = json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        model_endpoint(cfg, model_id),
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )

    try:
        with urllib.request.urlopen(request, timeout=timeout) as response:
            body = response.read().decode("utf-8", errors="replace")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        return False, f"Gemini HTTP error {exc.code}: {body[:1000]}"
    except urllib.error.URLError as exc:
        return False, f"Gemini network error: {exc}"
    except Exception as exc:
        return False, f"Gemini request error: {exc}"

    try:
        text = parse_generated_text_and_files(body, attachment_dir, session_name)
    except Exception as exc:
        return False, f"Gemini response parse error: {exc}; raw response: {body[:1000]}"

    if not text.strip():
        return False, "Gemini returned an empty text response"
    return True, text


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def call_gemini
# Maintainer note for call_gemini: this routine is part of the long-term public behavior of the
# program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def call_gemini(cfg: Config, prompt_text: str, session_name: str, attachment_dir: Path, attachments: List[PendingAttachment]) -> str:
    ok, text = generate_with_model(cfg, cfg.effective_model, prompt_text, session_name, attachment_dir, attachments, timeout=120)
    if ok:
        return text
    return f"({text})"


