    # MAINTAINER COMMENTARY: def action_for_function_key
    # Maintainer note for action_for_function_key: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def action_for_function_key(self, ch: int) -> Optional[str]:
        mapping = {
            curses.KEY_F1: "help",
            curses.KEY_F2: "models",
            curses.KEY_F3: "api-key",
            curses.KEY_F4: "sessions",
            curses.KEY_F5: "options",
            curses.KEY_F6: "memory",
            curses.KEY_F7: "files",
            curses.KEY_F8: "editor",
            curses.KEY_F9: "credits",
            curses.KEY_F10: "quit",
        }
        return mapping.get(ch)

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def dispatch_command_action
    # Maintainer note for dispatch_command_action: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def dispatch_command_action(self, action: str) -> None:
        if action == "help":
            self.open_help()
        elif action == "doctor":
            self.open_doctor()
        elif action == "models":
            self.open_model_selector()
        elif action == "api-key":
            self.open_api_key_input()
        elif action == "sessions":
            self.open_session_browser()
        elif action == "options":
            self.open_options_menu()
        elif action == "memory":
            self.open_memory_menu()
        elif action == "files":
            self.open_file_menu()
        elif action == "editor":
            self.open_external_editor_for_input()
        elif action == "credits":
            self.open_credits()
        elif action == "quit":
            self.should_quit = True

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def handle_global_hotkey
    # Global function-key routing. This is critical for usability: users should be able to jump
    # from any feature screen to any other feature screen without first escaping back to the
    # main chat.
    # ------------------------------------------------------------
    def handle_global_hotkey(self, ch: int, current_action: Optional[str] = None) -> bool:
        """Allow F-key navigation from feature screens.

        A user looking at F1/F2/F5/etc. screens should be able to jump
        directly to another screen by pressing that function key. The only
        exception is pressing the function key for the screen already open;
        that is ignored to avoid recursive redraw loops.
        """
        action = self.action_for_function_key(ch)
        if not action:
            return False
        if current_action is not None and action == current_action:
            return False
        self.dispatch_command_action(action)
        return True

