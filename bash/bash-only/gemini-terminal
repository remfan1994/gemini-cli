                    idx = top_index + (y - 4)
                    if 0 <= idx < len(names):
                        selected = idx
                continue
            if ch in (27, ord("q"), ord("Q")):
                return
            if ch in (10, 13, curses.KEY_ENTER):
                name = names[selected]
                self.reset_to_session(name, self.cfg.session_dir / f"{name}.log")
                return
            if ch in (ord("r"), ord("R")):
                old = names[selected]
                new = self.text_input_modal("RENAME SESSION", f"Rename session '{old}' to:", old)
                if new:
                    self.rename_session(old, new)
                continue
            if ch in (ord("n"), ord("N")):
                new = self.text_input_modal("RENAME CURRENT SESSION", "New name for current session:", self.session_name)
                if new:
                    self.rename_session(self.session_name, new)
                continue
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN:
                selected = min(len(names) - 1, selected + 1)
            elif ch == curses.KEY_PPAGE:
                selected = max(0, selected - visible_h)
            elif ch == curses.KEY_NPAGE:
                selected = min(len(names) - 1, selected + visible_h)

