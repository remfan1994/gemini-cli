    # MAINTAINER COMMENTARY: def draw
    # Maintainer note for draw: this routine is part of the long-term public behavior of the
    # program. When changing it, check callers, documentation, config compatibility, session-log
    # compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def draw(self) -> None:
        self.stdscr.erase()
        height, width = self.stdscr.getmaxyx()
        min_height = self.INPUT_HEIGHT + 6
        if height < min_height or width < 40:
            self.layout = {}
            self.safe_addstr(0, 0, "terminal too small", width, self.reverse_attr())
            self.stdscr.refresh()
            return

        header_h = 2
        status_h = 1
        input_label_h = 1
        transcript_h = height - header_h - input_label_h - self.INPUT_HEIGHT - status_h
        transcript_y = header_h
        input_label_y = transcript_y + transcript_h
        input_y = input_label_y + input_label_h
        status_y = height - 1
        self.layout = {
            "width": width,
            "height": height,
            "transcript_y": transcript_y,
            "transcript_h": transcript_h,
            "input_label_y": input_label_y,
            "command_y": input_label_y,
            "input_y": input_y,
            "input_h": self.INPUT_HEIGHT,
            "status_y": status_y,
        }
        self.draw_header(width)
        self.draw_transcript(transcript_y, transcript_h, width)
        self.draw_input(input_label_y, input_y, width)
        self.draw_status(status_y, width)
        self.stdscr.refresh()

