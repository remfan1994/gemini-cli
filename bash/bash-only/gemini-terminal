# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def wrap_for_width
# Maintainer note for wrap_for_width: this routine is part of the long-term public behavior of
# the program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def wrap_for_width(text: str, width: int) -> List[str]:
    width = max(1, width)
    result: List[str] = []
    for paragraph in text.splitlines() or [""]:
        if paragraph == "":
            result.append("")
        else:
            result.extend(
                textwrap.wrap(
                    paragraph,
                    width=width,
                    replace_whitespace=False,
                    drop_whitespace=False,
                    break_long_words=True,
                    break_on_hyphens=False,
                )
            )
    return result or [""]


