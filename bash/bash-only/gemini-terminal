    # MAINTAINER COMMENTARY: def open_model_list_selector
    # Maintainer note for open_model_list_selector: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def open_model_list_selector(self, models: List[ModelInfo], source_label: str = "model list") -> None:
        if not models:
            self.show_message("MODEL SELECTOR", ["No models available."])
            return

        raw_models = list(models)
        selected = 0
        top_index = 0

        while True:
            visible_models = filter_model_list(self.cfg, raw_models)
            current = normalize_model_id(self.cfg.effective_model)

            if not visible_models:
                self.stdscr.erase()
                height, width = self.stdscr.getmaxyx()
                self.safe_addstr(0, 0, "MODEL SELECTOR", width, self.reverse_attr())
                self.safe_addstr(1, 0, f"Source: {source_label}", width, self.dim_attr())
                self.safe_addstr(2, 0, model_filter_summary(self.cfg, len(raw_models), 0), width, self.dim_attr())
                self.safe_addstr(4, 0, "No models match the active metadata filters.", width)
                self.safe_addstr(6, 0, "f=filters | Esc/q=back | F-keys jump screens", width, self.dim_attr())
                self.stdscr.refresh()
                ch = self.stdscr.getch()
                if self.handle_global_hotkey(ch, current_action="models"):
                    return
                if ch in (27, ord("q"), ord("Q")):
                    self.status = "model selector closed"
                    return
                if ch in (ord("f"), ord("F")):
                    self.open_model_filter_menu()
                continue

            selected = max(0, min(selected, len(visible_models) - 1))
            self.stdscr.erase()
            height, width = self.stdscr.getmaxyx()
            visible_h = max(1, height - 8)
            self.safe_addstr(0, 0, "MODEL SELECTOR", width, self.reverse_attr())
            self.safe_addstr(1, 0, f"Source: {source_label}", width, self.dim_attr())
            self.safe_addstr(2, 0, model_filter_summary(self.cfg, len(raw_models), len(visible_models)), width, self.dim_attr())
            self.safe_addstr(3, 0, "Enter=activate | t=test | i=info | s=save | f=filters | Esc/q=back", width, self.dim_attr())
            self.safe_addstr(4, 0, "_" * width, width, self.dim_attr())

            if selected < top_index:
                top_index = selected
            elif selected >= top_index + visible_h:
                top_index = selected - visible_h + 1
            top_index = max(0, min(top_index, max(0, len(visible_models) - visible_h)))

            for row in range(visible_h):
                model_index = top_index + row
                if model_index >= len(visible_models):
                    break
                model = visible_models[model_index]
                limits = f"in:{model.input_token_limit or '?'} out:{model.output_token_limit or '?'}"
                current_marker = "* " if model.model_id == current else "  "
                badges = model_badges(model)
                line = f"{current_marker}{model.model_id} | {limits} | {badges} | {model.display_name}"
                attr = self.reverse_attr() if model_index == selected else 0
                self.safe_addstr(5 + row, 0, line, width, attr)

            self.safe_addstr(height - 2, 0, "_" * width, width, self.dim_attr())
            self.safe_addstr(height - 1, 0, f"{selected + 1}/{len(visible_models)} filtered; {len(raw_models)} cached/live total", width, self.dim_attr())
            self.stdscr.refresh()
            ch = self.stdscr.getch()
            if self.handle_global_hotkey(ch, current_action="models"):
                return
            if ch == curses.KEY_MOUSE:
                try:
                    _mid, _x, y, _z, state = curses.getmouse()
                except curses.error:
                    continue
                delta = self.mouse_wheel_delta(state)
                if delta > 0:
                    selected = max(0, selected - MOUSE_SCROLL_LINES)
                    continue
                if delta < 0:
                    selected = min(len(visible_models) - 1, selected + MOUSE_SCROLL_LINES)
                    continue
                if self.mouse_button1(state) and 5 <= y < 5 + visible_h:
                    idx = top_index + (y - 5)
                    if 0 <= idx < len(visible_models):
                        selected = idx
                        if self.mouse_button1_double(state):
                            self.cfg.model = visible_models[selected].model_id
                            self.status = f"activated model: {self.cfg.model}"
                            return
                    continue
            if ch in (27, ord("q"), ord("Q")):
                self.status = "model selector closed"
                return
            if ch in (ord("f"), ord("F")):
                self.open_model_filter_menu()
                continue
            if ch in (ord("i"), ord("I")):
                self.show_model_info(visible_models[selected])
                continue
            if ch in (ord("t"), ord("T")):
                self.test_model_interactive(visible_models[selected])
                current = normalize_model_id(self.cfg.effective_model)
                continue
            if ch in (ord("s"), ord("S")):
                set_config_value(self.cfg, "MODEL", visible_models[selected].model_id)
                self.status = f"model saved: {visible_models[selected].model_id}"
                return
            if ch in (10, 13, curses.KEY_ENTER):
                self.cfg.model = visible_models[selected].model_id
                self.status = f"activated model: {self.cfg.model}"
                self.transcript.append(TranscriptItem("system", f"Model activated: {self.cfg.model}"))
                return
            if ch == curses.KEY_UP:
                selected = max(0, selected - 1)
            elif ch == curses.KEY_DOWN:
                selected = min(len(visible_models) - 1, selected + 1)
            elif ch == curses.KEY_PPAGE:
                selected = max(0, selected - visible_h)
            elif ch == curses.KEY_NPAGE:
                selected = min(len(visible_models) - 1, selected + visible_h)
            elif ch == curses.KEY_HOME:
                selected = 0
            elif ch == curses.KEY_END:
                selected = len(visible_models) - 1

