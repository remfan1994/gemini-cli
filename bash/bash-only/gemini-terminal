    # ------------------------------------------------------------
    def draw_command_bar(self, y: int, width: int) -> None:
        # This compact command strip sits between transcript and input. It is
        # intentionally clipped to the available terminal width; only visible
        # labels are clickable. F1 opens the full command menu for all actions.
        self.command_click_targets = []
        self.safe_addstr(y, 0, "_" * width, width, self.dim_attr())
        x = 0
        for idx, (label, action) in enumerate(self.command_bar_items()):
            text = label if idx == 0 else " | " + label
            if x + len(text) >= width:
                if x + 4 < width:
                    self.safe_addstr(y, x, " ...", width - x, self.dim_attr())
                break
            self.safe_addstr(y, x, text, width - x, self.dim_attr())
            label_start = x + (3 if idx else 0)
            label_end = label_start + len(label)
            self.command_click_targets.append((label_start, label_end, action))
            x += len(text)

