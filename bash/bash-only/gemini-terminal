    # MAINTAINER COMMENTARY: def draw_input
    # Maintainer note for draw_input: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def draw_input(self, label_y: int, input_y: int, width: int) -> None:
        self.draw_command_bar(label_y, width)

        segments, cursor_visual_index, cursor_x = self.input_segments(width)
        self.last_input_segments = segments
        if cursor_visual_index < self.input_scroll:
            self.input_scroll = cursor_visual_index
        elif cursor_visual_index >= self.input_scroll + self.INPUT_HEIGHT:
            self.input_scroll = cursor_visual_index - self.INPUT_HEIGHT + 1
        self.input_scroll = max(0, min(self.input_scroll, max(0, len(segments) - self.INPUT_HEIGHT)))

        if self.current_input() == "":
            placeholder = "> " + self.cfg.input_placeholder
            self.safe_addstr(input_y, 0, placeholder, width, self.dim_attr())
            for offset in range(1, self.INPUT_HEIGHT):
                self.safe_addstr(input_y + offset, 0, "", width)
            try:
                curses.curs_set(1)
                self.stdscr.move(input_y, 2)
            except curses.error:
                pass
            return

        visible = segments[self.input_scroll : self.input_scroll + self.INPUT_HEIGHT]
        for offset in range(self.INPUT_HEIGHT):
            text = visible[offset].display if offset < len(visible) else ""
            self.safe_addstr(input_y + offset, 0, text, width)

        cursor_screen_y = input_y + cursor_visual_index - self.input_scroll
        try:
            curses.curs_set(1)
            self.stdscr.move(cursor_screen_y, min(cursor_x, width - 2))
        except curses.error:
            pass

