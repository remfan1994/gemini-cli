# MAINTAINER COMMENTARY: def filter_model_list
# Maintainer note for filter_model_list: this routine is part of the long-term public behavior
# of the program. When changing it, check callers, documentation, config compatibility, session-
# log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def filter_model_list(cfg: Config, models: List[ModelInfo]) -> List[ModelInfo]:
    filtered = list(models)
    if cfg.model_filter_generate_content:
        filtered = [model for model in filtered if model_supports_generate_content(model)]
    if cfg.model_filter_require_tokens:
        filtered = [model for model in filtered if model_has_required_token_limits(model)]
    if cfg.model_filter_hide_preview:
        filtered = [model for model in filtered if not model_looks_preview(model)]
    if cfg.model_min_input_tokens > 0:
        filtered = [model for model in filtered if model_token_value(model.input_token_limit) >= cfg.model_min_input_tokens]
    if cfg.model_min_output_tokens > 0:
        filtered = [model for model in filtered if model_token_value(model.output_token_limit) >= cfg.model_min_output_tokens]
    return sort_model_list(cfg, filtered)


