# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def resolve_command
# Maintainer note for resolve_command: this routine is part of the long-term public behavior of
# the program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def resolve_command(command_line: str) -> Tuple[bool, str]:
    """Resolve the executable portion of an editor/command string."""
    if not command_line.strip():
        return False, "empty command"
    try:
        parts = shlex.split(command_line)
    except ValueError as exc:
        return False, f"could not parse command: {exc}"
    if not parts:
        return False, "empty command"
    exe = parts[0]
    if "/" in exe:
        path = Path(exe).expanduser()
        if path.exists() and os.access(path, os.X_OK):
            return True, str(path)
        return False, f"not executable or not found: {path}"
    found = shutil.which(exe)
    if found:
        return True, found
    return False, f"not found in PATH: {exe}"


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def check_writable_directory
# Maintainer note for check_writable_directory: this routine is part of the long-term public
# behavior of the program. When changing it, check callers, documentation, config compatibility,
# session-log compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def check_writable_directory(path: Path) -> Tuple[bool, str]:
    """Check whether a directory can be created and written to."""
    try:
        path.mkdir(parents=True, exist_ok=True)
        probe = path / f".gemini-ncurses-python-doctor-write-test-{os.getpid()}"
        probe.write_text("ok", encoding="utf-8")
        probe.unlink(missing_ok=True)
        return True, str(path)
    except Exception as exc:
        return False, f"{path}: {exc}"


# ------------------------------------------------------------
# MAINTAINER COMMENTARY: def check_dns
# Maintainer note for check_dns: this routine is part of the long-term public behavior of the
# program. When changing it, check callers, documentation, config compatibility, session-log
# compatibility, and the parallel Bash/C implementation plans.
# ------------------------------------------------------------
def check_dns(hostname: str = "generativelanguage.googleapis.com") -> Tuple[bool, str]:
    """Check DNS resolution for the Gemini API host without a model request."""
    old_timeout = socket.getdefaulttimeout()
    try:
        socket.setdefaulttimeout(5)
        addresses = socket.getaddrinfo(hostname, 443)
        if not addresses:
            return False, "no addresses returned"
        sample = sorted({item[4][0] for item in addresses})[:3]
        return True, hostname if not sample else f"{hostname} -> {', '.join(sample)}"
    except Exception as exc:
        return False, str(exc)
    finally:
        socket.setdefaulttimeout(old_timeout)


