    # MAINTAINER COMMENTARY: def mouse_wheel_delta
    # Maintainer note for mouse_wheel_delta: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def mouse_wheel_delta(self, state: int) -> int:
        if state & getattr(curses, "BUTTON4_PRESSED", 0):
            return 1
        if state & getattr(curses, "BUTTON5_PRESSED", 0):
            return -1
        return 0

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def mouse_button1
    # Maintainer note for mouse_button1: this routine is part of the long-term public behavior
    # of the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def mouse_button1(self, state: int) -> bool:
        masks = [
            getattr(curses, "BUTTON1_PRESSED", 0),
            getattr(curses, "BUTTON1_CLICKED", 0),
            getattr(curses, "BUTTON1_DOUBLE_CLICKED", 0),
            getattr(curses, "BUTTON1_TRIPLE_CLICKED", 0),
        ]
        return any(state & mask for mask in masks)

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def mouse_button1_double
    # Maintainer note for mouse_button1_double: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def mouse_button1_double(self, state: int) -> bool:
        return bool(state & getattr(curses, "BUTTON1_DOUBLE_CLICKED", 0))

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def handle_mouse
    # Maintainer note for handle_mouse: this routine is part of the long-term public behavior of
    # the program. When changing it, check callers, documentation, config compatibility,
    # session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def handle_mouse(self) -> None:
        try:
            _mouse_id, x, y, _z, state = curses.getmouse()
        except curses.error:
            return
        delta = self.mouse_wheel_delta(state)
        if delta:
            if delta > 0:
                self.transcript_scroll += MOUSE_SCROLL_LINES
            else:
                self.transcript_scroll = max(0, self.transcript_scroll - MOUSE_SCROLL_LINES)
            self.status = "mousewheel: transcript scroll"
            return
        if not self.layout:
            return
        if self.mouse_button1(state):
            label_y = self.layout.get("input_label_y", -1)
            if y == label_y:
                for start, end, action in self.command_click_targets:
                    if start <= x < end:
                        self.dispatch_command_action(action)
                        return

            input_y = self.layout.get("input_y", -1)
            input_h = self.layout.get("input_h", 0)
            if input_y <= y < input_y + input_h:
                self.place_cursor_from_mouse(x, y - input_y)
                self.status = "mouse: input cursor placed"

    # ------------------------------------------------------------
    # MAINTAINER COMMENTARY: def place_cursor_from_mouse
    # Maintainer note for place_cursor_from_mouse: this routine is part of the long-term public
    # behavior of the program. When changing it, check callers, documentation, config
    # compatibility, session-log compatibility, and the parallel Bash/C implementation plans.
    # ------------------------------------------------------------
    def place_cursor_from_mouse(self, x: int, visible_row: int) -> None:
        index = self.input_scroll + visible_row
        if index < 0 or index >= len(self.last_input_segments):
            return
        segment = self.last_input_segments[index]
        line = self.input_lines[segment.logical_row]
        clicked_col = max(0, x - 2)
        logical_col = min(len(line), segment.start + clicked_col)
        self.cursor_row = segment.logical_row
        self.cursor_col = logical_col

