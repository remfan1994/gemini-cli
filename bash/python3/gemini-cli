run_model_test() { local model="$1" output status; printf 'Model: %s\nTest prompt: %s\n\n--- model response ---\n' "$model" "$MODEL_TEST_PROMPT"; output="$(call_gemini_model "$model" "$MODEL_TEST_PROMPT" 60)"; status=$?; printf '%s\n--- end response ---\n' "$output"; return "$status"; }

test_model_command() {
  local model="$1" status
  [ -n "$model" ] || { printf '%s\n' "ERROR: --test-model requires a model id." >&2; return 2; }
  run_model_test "$model"; status=$?
  if [ "$status" -eq 0 ] && [ "$SAVE" -eq 1 ]; then set_config_value "MODEL" "$(normalize_model_id "$model")"; printf 'saved MODEL=%s to %s\n' "$(normalize_model_id "$model")" "$CONFIG_FILE" >&2; fi
  return "$status"
}

