select_model_command() {
  local json table line index choice selected_line selected_model display input_limit output_limit badges answer test_status=0
  json="$(models_json_for_display)" || return 1
  table="$(printf '%s' "$json" | parse_models_table "$SHOW_ALL_MODELS")" || return 1
  [ -n "$table" ] || { printf '%s\n' "No models matched current filters."; return 1; }
  mapfile -t MODEL_LINES <<< "$table"
  printf '%s\n\n' "Available models:"
  index=1
  for line in "${MODEL_LINES[@]}"; do
    IFS=$'\t' read -r selected_model display input_limit output_limit badges <<< "$line"
    printf '%3d) %s - %s (input:%s output:%s badges:%s)\n' "$index" "$selected_model" "$display" "$input_limit" "$output_limit" "$badges"
    index=$((index + 1))
  done
  printf '\nSelect model number: '; IFS= read -r choice
  case "$choice" in ""|*[!0-9]*) printf '%s\n' "Invalid selection."; return 1 ;; esac
  [ "$choice" -ge 1 ] && [ "$choice" -le "${#MODEL_LINES[@]}" ] || { printf '%s\n' "Selection out of range."; return 1; }
  selected_line="${MODEL_LINES[$((choice - 1))]}"; IFS=$'\t' read -r selected_model display input_limit output_limit badges <<< "$selected_line"
  printf 'Selected model: %s\n' "$selected_model"
  printf 'Test selected model now? [Y/n] '; IFS= read -r answer
  case "$answer" in n|N|no|NO) ;; *) run_model_test "$selected_model"; test_status=$? ;; esac
  if [ "$SAVE" -eq 1 ]; then
    [ "$test_status" -eq 0 ] || { printf '%s\n' "Test failed; model not saved."; return 1; }
    set_config_value "MODEL" "$selected_model"; printf 'saved MODEL=%s to %s\n' "$selected_model" "$CONFIG_FILE"; return 0
  fi
  printf 'Save MODEL=%s to config? [y/N] ' "$selected_model"; IFS= read -r answer
  case "$answer" in y|Y|yes|YES) set_config_value "MODEL" "$selected_model"; printf 'saved MODEL=%s to %s\n' "$selected_model" "$CONFIG_FILE" ;; *) printf '%s\n' "Model not saved." ;; esac
}


# ==========================================================
# CONTEXT MEMORY BUFFER
# ----------------------------------------------------------
# CONTEXT_TURNS counts recent user/assistant exchanges.
# Internally, each exchange is stored as two entries:
#   User: ...
#   Assistant: ...
# ==========================================================

add_to_context() {
  CONTEXT_BUFFER+=("$1")
  trim_context_buffer
}

trim_context_buffer() {
  local max_entries=$((CONTEXT_TURNS * 2))
  while [ "${#CONTEXT_BUFFER[@]}" -gt "$max_entries" ]; do
    CONTEXT_BUFFER=("${CONTEXT_BUFFER[@]:1}")
  done
}

build_context() {
  local context="$SUMMARY"
  local msg
  for msg in "${CONTEXT_BUFFER[@]}"; do
    if [ -n "$context" ]; then
      context+=$'\n'
    fi
    context+="$msg"
  done
  printf '%s' "$context"
}

# ==========================================================
# ATTACHMENT EXTRACTION SYSTEM
# ==========================================================

extract_attachments() {
  python3 -c '
import os, re, sys
attachment_dir=sys.argv[1]; session_name=sys.argv[2]; text=sys.stdin.read()
ext_map={"bash":".sh","sh":".sh","shell":".sh","python":".py","py":".py","json":".json","yaml":".yml","yml":".yml","javascript":".js","js":".js","html":".html","css":".css","sql":".sql","c":".c","cpp":".cpp","c++":".cpp","text":".txt"}
pattern=re.compile(r"```([A-Za-z0-9_+.#-]*)[ \t]*\n(.*?)```", re.DOTALL)
def safe_tag(lang):
    lang=(lang or "text").strip().lower().replace("+","p").replace("#","sharp")
    return re.sub(r"[^A-Za-z0-9._-]+","_",lang) or "text"
def next_number(lang,ext):
    highest=0; regex=re.compile(r"^"+re.escape(session_name)+"-"+re.escape(lang)+r"-(\d{2,})"+re.escape(ext)+r"$")
    if os.path.isdir(attachment_dir):
        for name in os.listdir(attachment_dir):
            m=regex.match(name)
            if m: highest=max(highest,int(m.group(1)))
    return highest+1
def repl(m):
    raw=(m.group(1) or "text").strip().lower(); lang=safe_tag(raw); ext=ext_map.get(raw,ext_map.get(lang,".txt")); num=next_number(lang,ext)
    filename=f"{session_name}-{lang}-{num:02d}{ext}"; path=os.path.join(attachment_dir,filename); os.makedirs(attachment_dir,exist_ok=True)
    with open(path,"w",encoding="utf-8") as fh: fh.write(m.group(2))
    return f"\n[attachment saved]\nfile: {filename}\nlocation: {attachment_dir}\n"
print(pattern.sub(repl,text))
' "$ATTACHMENT_DIR" "$SESSION_NAME"
}

