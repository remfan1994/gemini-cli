Model filters:
  MODEL_FILTER_GENERATE_CONTENT=$MODEL_FILTER_GENERATE_CONTENT
  MODEL_FILTER_REQUIRE_TOKENS=$MODEL_FILTER_REQUIRE_TOKENS
  MODEL_FILTER_HIDE_PREVIEW=$MODEL_FILTER_HIDE_PREVIEW
  MODEL_MIN_INPUT_TOKENS=$MODEL_MIN_INPUT_TOKENS
  MODEL_MIN_OUTPUT_TOKENS=$MODEL_MIN_OUTPUT_TOKENS
  MODEL_SORT_ORDER=$MODEL_SORT_ORDER

API key:
  environment/config loaded: $([ -n "$GEMINI_API_KEY" ] && printf yes || printf no)
EOF
}

