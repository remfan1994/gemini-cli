require_api_key() {
  if [ -z "$GEMINI_API_KEY" ]; then
    printf '%s\n' "ERROR: GEMINI_API_KEY not set."
    printf '%s\n' "Set it with: export GEMINI_API_KEY=your_key"
    printf '%s\n' "or save it with: $PROGRAM --set-api-key"
    return 1
  fi
  return 0
}

set_api_key_command() {
  local answer key
  printf '%s\n' "This will save GEMINI_API_KEY in plaintext:"
  printf '  %s\n\n' "$CONFIG_FILE"
  printf 'Continue? [y/N] '
  IFS= read -r answer
  case "$answer" in y|Y|yes|YES) ;; *) printf '%s\n' "Cancelled."; return 1 ;; esac
  printf 'Paste Gemini API key: '
  IFS= read -r -s key
  printf '%s\n' ""
  [ -n "$key" ] || { printf '%s\n' "No key entered."; return 1; }
  set_config_value "GEMINI_API_KEY" "$key"
  printf 'saved GEMINI_API_KEY to %s\n' "$CONFIG_FILE"
}

forget_api_key_command() { remove_config_key "GEMINI_API_KEY"; printf 'removed GEMINI_API_KEY from config if present\n'; }

