# ==========================================================
# SESSION MANAGEMENT
# ==========================================================

resolve_session_path() { printf '%s/%s.log\n' "$SESSION_DIR" "$1"; }

list_sessions() { local path; for path in "$SESSION_DIR"/*.log; do [ -e "$path" ] || continue; basename "$path" .log; done; }

rename_session_command() {
  local old_name new_name old_path new_path
  old_name="$(sanitize_session_name "$1")"; new_name="$(sanitize_session_name "$2")"
  old_path="$(resolve_session_path "$old_name")"; new_path="$(resolve_session_path "$new_name")"
  [ -f "$old_path" ] || { printf 'ERROR: session not found: %s\n' "$old_name" >&2; return 1; }
  [ ! -e "$new_path" ] || { printf 'ERROR: destination already exists: %s\n' "$new_name" >&2; return 1; }
  mv "$old_path" "$new_path"
  printf 'renamed session: %s -> %s\n' "$old_name" "$new_name"
}

# ==========================================================
# MEMORY SNAPSHOTS / RESUME CONTEXT
# ==========================================================

load_context_from_path() {
  local path="$1"
  python3 - "$path" "$CONTEXT_TURNS" <<'PY'
import re, sys
path = sys.argv[1]
try: context_turns = int(sys.argv[2])
except Exception: context_turns = 12
max_entries = max(1, context_turns) * 2
entry_re = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] ([^:]+): (.*)$")
entries=[]; current_speaker=None; current_lines=[]
try: fh=open(path,"r",encoding="utf-8",errors="replace")
except FileNotFoundError: sys.exit(0)
with fh:
    for raw_line in fh:
        line=raw_line.rstrip("\n"); m=entry_re.match(line)
        if m:
            if current_speaker is not None: entries.append((current_speaker,"\n".join(current_lines)))
            current_speaker=m.group(2); current_lines=[m.group(3)]
        elif current_speaker is not None:
            current_lines.append(line)
if current_speaker is not None: entries.append((current_speaker,"\n".join(current_lines)))
snapshot=None
for speaker,text in reversed(entries):
    if speaker.lower() != "system": continue
    lines=text.splitlines()
    if not lines or lines[0].strip() != "CONTEXT_BEGIN": continue
    items=[]
    for line in lines[1:]:
        if line.strip() == "CONTEXT_END": break
        if line.startswith("User: ") or line.startswith("Assistant: "): items.append(line)
    snapshot=items[-max_entries:]
    break
if snapshot is None:
    fallback=[]
    for speaker,text in entries:
        if speaker.lower() == "system": continue
        label="Assistant" if speaker == "Gemini" else "User"
        fallback.append(f"{label}: {text}")
    snapshot=fallback[-max_entries:]
for entry in snapshot:
    sys.stdout.buffer.write(entry.encode("utf-8",errors="replace") + b"\0")
PY
}

load_context_from_session() { load_context_from_path "$SESSION"; }

rebuild_context_from_session() {
  CONTEXT_BUFFER=()
  [ -f "$SESSION" ] || return 0
  while IFS= read -r -d '' entry; do CONTEXT_BUFFER+=("$entry"); done < <(load_context_from_session)
}

write_context_snapshot_to_path() {
  local path="$1" ts="$2" item
  printf '[%s] system: CONTEXT_BEGIN\n' "$ts" >> "$path"
  for item in "${CONTEXT_BUFFER[@]}"; do printf '%s\n' "$item" >> "$path"; done
  printf '[%s] system: CONTEXT_END\n' "$ts" >> "$path"
}

write_context_snapshot() { write_context_snapshot_to_path "$SESSION" "$1"; }

show_memory_command() {
  local name path
  name="$(sanitize_session_name "$1")"; path="$(resolve_session_path "$name")"
  [ -f "$path" ] || { printf 'ERROR: session not found: %s\n' "$name" >&2; return 1; }
  while IFS= read -r -d '' entry; do printf '%s\n' "$entry"; done < <(load_context_from_path "$path")
}

edit_memory_command() {
  local name path tmp editor
  name="$(sanitize_session_name "$1")"; path="$(resolve_session_path "$name")"
  [ -f "$path" ] || { printf 'ERROR: session not found: %s\n' "$name" >&2; return 1; }
  tmp="$(mktemp)"
  while IFS= read -r -d '' entry; do printf '%s\n' "$entry" >> "$tmp"; done < <(load_context_from_path "$path")
  editor="$(editor_command)"; $editor "$tmp"
  mapfile -t CONTEXT_BUFFER < "$tmp"; rm -f "$tmp"
  write_context_snapshot_to_path "$path" "$(timestamp)"
  printf 'saved edited memory snapshot for session: %s\n' "$name"
}

clear_memory_command() {
  local name path
  name="$(sanitize_session_name "$1")"; path="$(resolve_session_path "$name")"
  [ -f "$path" ] || { printf 'ERROR: session not found: %s\n' "$name" >&2; return 1; }
  CONTEXT_BUFFER=(); write_context_snapshot_to_path "$path" "$(timestamp)"
  printf 'cleared memory snapshot for session: %s\n' "$name"
}

# ==========================================================
# MODEL CACHE / FILTERING
# ==========================================================

fetch_models_live_json() {
  local url response curl_status
  require_api_key || return 1
  url="https://generativelanguage.googleapis.com/v1beta/models?$(models_query)"
  response="$(curl -sS --max-time 60 "$url" 2>&1)"; curl_status=$?
  [ "$curl_status" -eq 0 ] || { printf '%s\n' "curl error while fetching models: $response" >&2; return 1; }
  printf '%s' "$response"
}

update_models_cache() {
  local json
  json="$(fetch_models_live_json)" || return 1
  printf '%s' "$json" > "$MODEL_CACHE_FILE"
  chmod 600 "$MODEL_CACHE_FILE" 2>/dev/null || true
  printf 'updated model cache: %s\n' "$MODEL_CACHE_FILE" >&2
}

models_json_for_display() {
  if [ -f "$MODEL_CACHE_FILE" ]; then cat "$MODEL_CACHE_FILE"; else update_models_cache >/dev/null || return 1; cat "$MODEL_CACHE_FILE"; fi
}

parse_models_table() {
  local show_all="$1"
  python3 - "$show_all" "$MODEL_FILTER_GENERATE_CONTENT" "$MODEL_FILTER_REQUIRE_TOKENS" "$MODEL_FILTER_HIDE_PREVIEW" "$MODEL_MIN_INPUT_TOKENS" "$MODEL_MIN_OUTPUT_TOKENS" "$MODEL_SORT_ORDER" <<'PY'
import json, sys
show_all=sys.argv[1]=="1"
truth=lambda v: v.lower() in ("1","yes","true","on","y")
filter_generate=truth(sys.argv[2]); require_tokens=truth(sys.argv[3]); hide_preview=truth(sys.argv[4])
try: min_in=int(sys.argv[5])
except Exception: min_in=0
try: min_out=int(sys.argv[6])
except Exception: min_out=0
sort_order=sys.argv[7]
raw=sys.stdin.read()
try: data=json.loads(raw)
except Exception as exc:
    print(f"ERROR: could not parse model list JSON: {exc}", file=sys.stderr); sys.exit(1)
if "error" in data:
    err=data["error"]; print(f"ERROR: Gemini API error {err.get('code','')}: {err.get('message','')}", file=sys.stderr); sys.exit(1)
rows=[]
for item in data.get("models",[]):
    methods=item.get("supportedGenerationMethods",[]) or []
    name=item.get("name",""); model_id=name.split("/",1)[1] if name.startswith("models/") else name
    if not model_id: continue
    display=item.get("displayName",model_id); desc=item.get("description","") or ""
    input_limit=int(item.get("inputTokenLimit") or 0); output_limit=int(item.get("outputTokenLimit") or 0)
    hay=" ".join([model_id,display,desc]).lower(); preview=any(w in hay for w in ["preview","experimental"," exp ","-exp","_exp"])
    if not show_all:
        if filter_generate and "generateContent" not in methods: continue
        if require_tokens and (input_limit<=0 or output_limit<=0): continue
        if hide_preview and preview: continue
        if input_limit < min_in: continue
        if output_limit < min_out: continue
    badges=[]
    if "generateContent" in methods: badges.append("gen")
    if preview: badges.append("preview")
    if input_limit<=0 or output_limit<=0: badges.append("no-token-meta")
    rows.append((model_id,display,input_limit,output_limit,",".join(badges) or "-"))
if sort_order=="input_desc": rows.sort(key=lambda r:(r[2],r[0]), reverse=True)
elif sort_order=="output_desc": rows.sort(key=lambda r:(r[3],r[0]), reverse=True)
elif sort_order=="display": rows.sort(key=lambda r:(r[1].lower(),r[0]))
else: rows.sort(key=lambda r:r[0])
for r in rows: print("\t".join(map(str,r)))
PY
}

print_models() { local json; json="$(models_json_for_display)" || return 1; printf '%s' "$json" | parse_models_table "$SHOW_ALL_MODELS"; }

# ==========================================================
# GEMINI GENERATION / ATTACHMENT PAYLOADS
# ==========================================================

make_generate_payload() {
  python3 - "$MAX_ATTACHMENT_BYTES" "$@" <<'PY'
import base64, json, mimetypes, os, sys
from pathlib import Path
max_bytes=int(sys.argv[1]); files=sys.argv[2:]; text=sys.stdin.read(); parts=[{"text":text}]
text_exts={".txt",".md",".markdown",".sh",".bash",".py",".json",".yml",".yaml",".html",".css",".js",".c",".cpp",".h",".sql",".log"}
for file_name in files:
    path=Path(os.path.expanduser(os.path.expandvars(file_name)))
    if not path.exists() or not path.is_file(): print(f"attachment not found: {file_name}", file=sys.stderr); sys.exit(2)
    size=path.stat().st_size
    if size > max_bytes: print(f"attachment too large: {path} ({size} bytes > {max_bytes})", file=sys.stderr); sys.exit(2)
    mime=mimetypes.guess_type(str(path))[0] or "application/octet-stream"
    if mime.startswith("text/") or path.suffix.lower() in text_exts:
        content=path.read_text(encoding="utf-8",errors="replace")
        parts.append({"text":f"\n\n[Attached file: {path.name}]\n{content}"})
    else:
        data=base64.b64encode(path.read_bytes()).decode("ascii")
        parts.append({"inlineData":{"mimeType":mime,"data":data}})
print(json.dumps({"contents":[{"parts":parts}]}))
PY
}

parse_generate_response() {
  python3 - "$ATTACHMENT_DIR" "$SESSION_NAME" <<'PY'
import base64, json, mimetypes, os, re, sys
attachment_dir=sys.argv[1]; session_name=sys.argv[2] or "model-test"; raw=sys.stdin.read()
try: data=json.loads(raw)
except Exception as exc: print(f"invalid JSON response: {exc}; raw response: {raw[:1000]}"); sys.exit(1)
if "error" in data:
    err=data["error"]; print(f"Gemini API error {err.get('code','')}: {err.get('message','')}"); sys.exit(1)
os.makedirs(attachment_dir, exist_ok=True); texts=[]
def next_number(kind,ext):
    highest=0; regex=re.compile(r"^"+re.escape(session_name)+r"-"+re.escape(kind)+r"-(\d{2,})"+re.escape(ext)+r"$")
    for name in os.listdir(attachment_dir):
        m=regex.match(name)
        if m: highest=max(highest,int(m.group(1)))
    return highest+1
def save_inline(part):
    inline=part.get("inlineData") or part.get("inline_data")
    if not inline: return None
    mime=inline.get("mimeType") or inline.get("mime_type") or "application/octet-stream"; data=inline.get("data") or ""
    ext=mimetypes.guess_extension(mime) or ".bin"; kind=mime.split("/",1)[0].replace("+","p").replace("#","sharp")
    filename=f"{session_name}-{kind}-{next_number(kind,ext):02d}{ext}"; path=os.path.join(attachment_dir,filename)
    with open(path,"wb") as fh: fh.write(base64.b64decode(data))
    return f"\n[attachment saved]\nfile: {filename}\nlocation: {attachment_dir}\n"
for cand in data.get("candidates",[]):
    for part in cand.get("content",{}).get("parts",[]):
        if "text" in part: texts.append(part["text"])
        notice=save_inline(part)
        if notice: texts.append(notice)
        file_data=part.get("fileData") or part.get("file_data")
        if file_data:
            uri=file_data.get("fileUri") or file_data.get("file_uri") or ""
            texts.append(f"\n[fileData returned]\nuri: {uri}\n")
output="\n".join(t for t in texts if t is not None)
if not output.strip(): print("Gemini returned an empty text response"); sys.exit(1)
print(output)
PY
}

call_gemini_model() {
  local model="$1" prompt="$2" timeout="${3:-120}"; shift 3 || true
  local attachments=("$@") clean_model quoted_model url response curl_status output parse_status
  require_api_key || return 1
  clean_model="$(normalize_model_id "$model")"; quoted_model="$(quote_url_component "$clean_model")"
  url="https://generativelanguage.googleapis.com/v1beta/models/$quoted_model:generateContent?$(api_key_query)"
  response="$(printf '%s' "$prompt" | make_generate_payload "${attachments[@]}" | curl -sS --max-time "$timeout" -H "Content-Type: application/json" -d @- "$url" 2>&1)"
  curl_status=$?
  [ "$curl_status" -eq 0 ] || { printf '%s\n' "curl error: $response"; return 1; }
  output="$(printf '%s' "$response" | parse_generate_response)"; parse_status=$?
  printf '%s\n' "$output"; return "$parse_status"
}

