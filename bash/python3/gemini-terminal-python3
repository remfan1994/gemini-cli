# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function load_context_from_path
# Rebuilds memory from logs. This is what lets Bash resumed sessions behave
# like conversations instead of just appending to a file.
# ----------------------------------------------------------
load_context_from_path() {
  local path="$1"
  python3 - "$path" "$CONTEXT_TURNS" <<'PY'
import re, sys
path = sys.argv[1]
try: context_turns = int(sys.argv[2])
except Exception: context_turns = 12
max_entries = max(1, context_turns) * 2
entry_re = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] ([^:]+): (.*)$")
entries=[]; current_speaker=None; current_lines=[]
try: fh=open(path,"r",encoding="utf-8",errors="replace")
except FileNotFoundError: sys.exit(0)
with fh:
    for raw_line in fh:
        line=raw_line.rstrip("\n"); m=entry_re.match(line)
        if m:
            if current_speaker is not None: entries.append((current_speaker,"\n".join(current_lines)))
            current_speaker=m.group(2); current_lines=[m.group(3)]
        elif current_speaker is not None:
            current_lines.append(line)
if current_speaker is not None: entries.append((current_speaker,"\n".join(current_lines)))
snapshot=None
for speaker,text in reversed(entries):
    if speaker.lower() != "system": continue
    lines=text.splitlines()
    if not lines or lines[0].strip() != "CONTEXT_BEGIN": continue
    items=[]
    for line in lines[1:]:
        if line.strip() == "CONTEXT_END": break
        if line.startswith("User: ") or line.startswith("Assistant: "): items.append(line)
    snapshot=items[-max_entries:]
    break
if snapshot is None:
    fallback=[]
    for speaker,text in entries:
        if speaker.lower() == "system": continue
        label="Assistant" if speaker == "Gemini" else "User"
        fallback.append(f"{label}: {text}")
    snapshot=fallback[-max_entries:]
for entry in snapshot:
    sys.stdout.buffer.write(entry.encode("utf-8",errors="replace") + b"\0")
PY
}

