# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function resolve_session_path
# resolve_session_path is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
resolve_session_path() { printf '%s/%s.log\n' "$SESSION_DIR" "$1"; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function list_sessions
# list_sessions is a named maintenance unit. Keep behavior stable, check
# call sites before changing it, and update man pages/help/comments when
# behavior changes.
# ----------------------------------------------------------
list_sessions() { local path; for path in "$SESSION_DIR"/*.log; do [ -e "$path" ] || continue; basename "$path" .log; done; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function rename_session_command
# rename_session_command is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
rename_session_command() {
  local old_name new_name old_path new_path
  old_name="$(sanitize_session_name "$1")"; new_name="$(sanitize_session_name "$2")"
  old_path="$(resolve_session_path "$old_name")"; new_path="$(resolve_session_path "$new_name")"
  [ -f "$old_path" ] || { printf 'ERROR: session not found: %s\n' "$old_name" >&2; return 1; }
  [ ! -e "$new_path" ] || { printf 'ERROR: destination already exists: %s\n' "$new_name" >&2; return 1; }
  mv "$old_path" "$new_path"
