# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function make_generate_payload
# Builds valid Gemini JSON from arbitrary text and attachments. Do not
# replace with manual string interpolation unless you also handle quotes,
# backslashes, and newlines.
# ----------------------------------------------------------
make_generate_payload() {
  python3 - "$MAX_ATTACHMENT_BYTES" "$@" <<'PY'
import base64, json, mimetypes, os, sys
from pathlib import Path
max_bytes=int(sys.argv[1]); files=sys.argv[2:]; text=sys.stdin.read(); parts=[{"text":text}]
text_exts={".txt",".md",".markdown",".sh",".bash",".py",".json",".yml",".yaml",".html",".css",".js",".c",".cpp",".h",".sql",".log"}
for file_name in files:
    path=Path(os.path.expanduser(os.path.expandvars(file_name)))
    if not path.exists() or not path.is_file(): print(f"attachment not found: {file_name}", file=sys.stderr); sys.exit(2)
    size=path.stat().st_size
    if size > max_bytes: print(f"attachment too large: {path} ({size} bytes > {max_bytes})", file=sys.stderr); sys.exit(2)
    mime=mimetypes.guess_type(str(path))[0] or "application/octet-stream"
    if mime.startswith("text/") or path.suffix.lower() in text_exts:
        content=path.read_text(encoding="utf-8",errors="replace")
        parts.append({"text":f"\n\n[Attached file: {path.name}]\n{content}"})
    else:
        data=base64.b64encode(path.read_bytes()).decode("ascii")
        parts.append({"inlineData":{"mimeType":mime,"data":data}})
print(json.dumps({"contents":[{"parts":parts}]}))
PY
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function parse_generate_response
# parse_generate_response is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
parse_generate_response() {
  python3 - "$ATTACHMENT_DIR" "$SESSION_NAME" <<'PY'
import base64, json, mimetypes, os, re, sys
attachment_dir=sys.argv[1]; session_name=sys.argv[2] or "model-test"; raw=sys.stdin.read()
try: data=json.loads(raw)
except Exception as exc: print(f"invalid JSON response: {exc}; raw response: {raw[:1000]}"); sys.exit(1)
if "error" in data:
    err=data["error"]; print(f"Gemini API error {err.get('code','')}: {err.get('message','')}"); sys.exit(1)
os.makedirs(attachment_dir, exist_ok=True); texts=[]
def next_number(kind,ext):
    highest=0; regex=re.compile(r"^"+re.escape(session_name)+r"-"+re.escape(kind)+r"-(\d{2,})"+re.escape(ext)+r"$")
    for name in os.listdir(attachment_dir):
        m=regex.match(name)
        if m: highest=max(highest,int(m.group(1)))
    return highest+1
def save_inline(part):
    inline=part.get("inlineData") or part.get("inline_data")
    if not inline: return None
    mime=inline.get("mimeType") or inline.get("mime_type") or "application/octet-stream"; data=inline.get("data") or ""
    ext=mimetypes.guess_extension(mime) or ".bin"; kind=mime.split("/",1)[0].replace("+","p").replace("#","sharp")
    filename=f"{session_name}-{kind}-{next_number(kind,ext):02d}{ext}"; path=os.path.join(attachment_dir,filename)
    with open(path,"wb") as fh: fh.write(base64.b64decode(data))
    return f"\n[attachment saved]\nfile: {filename}\nlocation: {attachment_dir}\n"
for cand in data.get("candidates",[]):
    for part in cand.get("content",{}).get("parts",[]):
        if "text" in part: texts.append(part["text"])
        notice=save_inline(part)
        if notice: texts.append(notice)
        file_data=part.get("fileData") or part.get("file_data")
        if file_data:
            uri=file_data.get("fileUri") or file_data.get("file_uri") or ""
            texts.append(f"\n[fileData returned]\nuri: {uri}\n")
output="\n".join(t for t in texts if t is not None)
if not output.strip(): print("Gemini returned an empty text response"); sys.exit(1)
print(output)
PY
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function call_gemini_model
# Single generation transport function. Keeping curl/API behavior
# centralized makes quota, timeout, and error changes easier.
# ----------------------------------------------------------
call_gemini_model() {
  local model="$1" prompt="$2" timeout="${3:-120}"; shift 3 || true
  local attachments=("$@") clean_model quoted_model url response curl_status output parse_status
  require_api_key || return 1
  clean_model="$(normalize_model_id "$model")"; quoted_model="$(quote_url_component "$clean_model")"
  url="https://generativelanguage.googleapis.com/v1beta/models/$quoted_model:generateContent?$(api_key_query)"
  response="$(printf '%s' "$prompt" | make_generate_payload "${attachments[@]}" | curl -sS --max-time "$timeout" -H "Content-Type: application/json" -d @- "$url" 2>&1)"
  curl_status=$?
  [ "$curl_status" -eq 0 ] || { printf '%s\n' "curl error: $response"; return 1; }
  output="$(printf '%s' "$response" | parse_generate_response)"; parse_status=$?
  printf '%s\n' "$output"; return "$parse_status"
}

