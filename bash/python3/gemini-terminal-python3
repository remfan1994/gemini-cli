# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function timestamp
# Central timestamp helper used in prompts, logs, and visible status output.
# Keep the format stable because log parsers depend on it.
# ----------------------------------------------------------
timestamp() { date +"%H:%M:%S"; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function trim
# Whitespace normalizer for config parsing. The config format is simple on
# purpose so all project editions can share it.
# ----------------------------------------------------------
trim() { printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function expand_path
# Uses Python 3 because path expansion needs to be predictable across
# shells. This is one of the places where the python3 edition deliberately
# buys reliability.
# ----------------------------------------------------------
expand_path() {
  python3 -c 'import os, sys; print(os.path.abspath(os.path.expandvars(os.path.expanduser(sys.argv[1]))))' "$1"
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function normalize_model_id
# Allows both models/name and name forms. Google may return names with a
# models/ prefix while users often configure the shorter form.
# ----------------------------------------------------------
normalize_model_id() {
  case "$1" in
    models/*) printf '%s\n' "${1#models/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function quote_url_component
# quote_url_component is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
quote_url_component() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function api_key_query
# api_key_query is a named maintenance unit. Keep behavior stable, check
# call sites before changing it, and update man pages/help/comments when
# behavior changes.
# ----------------------------------------------------------
api_key_query() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.urlencode({"key": sys.argv[1]}))' "$GEMINI_API_KEY"
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function models_query
# models_query is a named maintenance unit. Keep behavior stable, check call
# sites before changing it, and update man pages/help/comments when behavior
# changes.
# ----------------------------------------------------------
models_query() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.urlencode({"key": sys.argv[1], "pageSize": "100"}))' "$GEMINI_API_KEY"
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function effective_model
# effective_model is a named maintenance unit. Keep behavior stable, check
# call sites before changing it, and update man pages/help/comments when
# behavior changes.
# ----------------------------------------------------------
effective_model() {
  if [ -n "$MODEL" ]; then normalize_model_id "$MODEL"; else printf '%s\n' "$FALLBACK_MODEL"; fi
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function model_label
# model_label is a named maintenance unit. Keep behavior stable, check call
# sites before changing it, and update man pages/help/comments when behavior
# changes.
# ----------------------------------------------------------
model_label() {
  if [ -n "$MODEL" ]; then
    printf '%s\n' "$(normalize_model_id "$MODEL")"
  else
    printf '%s (fallback; no MODEL configured)\n' "$FALLBACK_MODEL"
  fi
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function sanitize_session_name
# sanitize_session_name is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
sanitize_session_name() {
  python3 -c '
import re, sys
name = sys.argv[1].strip()
name = re.sub(r"[^A-Za-z0-9._-]+", "_", name).strip("._-")
print(name or "session")
' "$1"
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function positive_int_or_default
# positive_int_or_default is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
positive_int_or_default() {
  local value="$1" fallback="$2"
  case "$value" in
    ""|*[!0-9]*) printf '%s\n' "$fallback" ;;
    *) if [ "$value" -lt 0 ]; then printf '%s\n' "$fallback"; else printf '%s\n' "$value"; fi ;;
  esac
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function truthy
# truthy is a named maintenance unit. Keep behavior stable, check call sites
# before changing it, and update man pages/help/comments when behavior
# changes.
# ----------------------------------------------------------
truthy() {
  case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
    1|yes|y|true|on) return 0 ;;
    *) return 1 ;;
  esac
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function clear_screen
# clear_screen is a named maintenance unit. Keep behavior stable, check call
# sites before changing it, and update man pages/help/comments when behavior
# changes.
# ----------------------------------------------------------
clear_screen() { if [ -t 1 ]; then printf '\033[H\033[J'; fi; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function editor_command
# editor_command is a named maintenance unit. Keep behavior stable, check
# call sites before changing it, and update man pages/help/comments when
# behavior changes.
# ----------------------------------------------------------
editor_command() {
  if [ -n "$EDITOR_CMD" ]; then printf '%s\n' "$EDITOR_CMD"
  elif [ -n "${VISUAL:-}" ]; then printf '%s\n' "$VISUAL"
  elif [ -n "${EDITOR:-}" ]; then printf '%s\n' "$EDITOR"
  elif command -v nano >/dev/null 2>&1; then printf '%s\n' "nano"
  else printf '%s\n' "vi"; fi
}

# ==========================================================
# CONFIG FILE SUPPORT
# ==========================================================

if [ -f "$CONFIG_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="$(trim "$line")"
    case "$line" in ""|\#*) continue ;; esac
    case "$line" in *=*) key="$(trim "${line%%=*}")"; value="$(trim "${line#*=}")" ;; *) continue ;; esac

    case "$key" in
      MODEL) MODEL="$(normalize_model_id "$value")" ;;
      CONTEXT_TURNS) CONTEXT_TURNS="$value"; CONTEXT_TURNS_EXPLICIT=1 ;;
      HISTORY_LIMIT) if [ "$CONTEXT_TURNS_EXPLICIT" -eq 0 ]; then CONTEXT_TURNS="$value"; fi ;;
      GEMINI_API_KEY) GEMINI_API_KEY="${GEMINI_API_KEY:-$value}" ;;
      SESSION_DIR) SESSION_DIR="$(expand_path "$value")" ;;
      ATTACHMENT_DIR) ATTACHMENT_DIR="$(expand_path "$value")"; ATTACHMENT_DIR_CONFIGURED=1 ;;
      MODEL_TEST_PROMPT) [ -n "$value" ] && MODEL_TEST_PROMPT="$value" ;;
      STARTUP_NOTICE) STARTUP_NOTICE="$value" ;;
      MODEL_FILTER_GENERATE_CONTENT) MODEL_FILTER_GENERATE_CONTENT="$value" ;;
      MODEL_FILTER_REQUIRE_TOKENS) MODEL_FILTER_REQUIRE_TOKENS="$value" ;;
      MODEL_FILTER_HIDE_PREVIEW) MODEL_FILTER_HIDE_PREVIEW="$value" ;;
      MODEL_MIN_INPUT_TOKENS) MODEL_MIN_INPUT_TOKENS="$value" ;;
      MODEL_MIN_OUTPUT_TOKENS) MODEL_MIN_OUTPUT_TOKENS="$value" ;;
      MODEL_SORT_ORDER) MODEL_SORT_ORDER="$value" ;;
      MAX_ATTACHMENT_BYTES) MAX_ATTACHMENT_BYTES="$value" ;;
      EDITOR) EDITOR_CMD="$value" ;;
    esac
  done < "$CONFIG_FILE"
fi

CONTEXT_TURNS="$(positive_int_or_default "$CONTEXT_TURNS" 12)"
MODEL_MIN_INPUT_TOKENS="$(positive_int_or_default "$MODEL_MIN_INPUT_TOKENS" 0)"
MODEL_MIN_OUTPUT_TOKENS="$(positive_int_or_default "$MODEL_MIN_OUTPUT_TOKENS" 0)"
MAX_ATTACHMENT_BYTES="$(positive_int_or_default "$MAX_ATTACHMENT_BYTES" 1048576)"

if [ "$ATTACHMENT_DIR_CONFIGURED" -eq 0 ]; then ATTACHMENT_DIR="$SESSION_DIR/attachments"; fi

mkdir -p "$CONFIG_DIR" "$SESSION_DIR" "$ATTACHMENT_DIR"

