# ==========================================================
# DIAGNOSTICS / DOCTOR
# ----------------------------------------------------------
# The Python-helper Bash edition has enough moving parts that a quick doctor
# command is useful for users and bug reporters. It checks tools, config,
# storage paths, model cache state, editor availability, API-key presence, and
# network reachability. It does not send a generation prompt to Gemini.
# ==========================================================

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function doctor_status
# doctor_status is a named maintenance unit. Keep behavior stable, check
# call sites before changing it, and update man pages/help/comments when
# behavior changes.
# ----------------------------------------------------------
doctor_status() { printf '[%-4s] %s: %s\n' "$1" "$2" "$3"; }

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function check_writable_dir
# check_writable_dir is a named maintenance unit. Keep behavior stable,
# check call sites before changing it, and update man pages/help/comments
# when behavior changes.
# ----------------------------------------------------------
check_writable_dir() {
  local path="$1" test_file
  mkdir -p "$path" 2>/dev/null || { printf 'not creatable: %s' "$path"; return 1; }
  test_file="$path/.gemini-cli-write-test-$$"
  if printf '%s' ok > "$test_file" 2>/dev/null; then rm -f "$test_file"; printf 'writable: %s' "$path"; return 0; fi
  printf 'not writable: %s' "$path"; return 1
}

# ----------------------------------------------------------
# MAINTAINER COMMENTARY: function doctor_command
# Diagnostic command. It should report environment state without sending
# generation prompts or leaking API keys.
# ----------------------------------------------------------
doctor_command() {
  local status detail editor_first
  printf '%s\n\n' "gemini-cli diagnostics"
  doctor_status OK program "$PROGRAM version $VERSION"
  doctor_status OK bash "$BASH_VERSION"
  for cmd in bash curl python3 sed awk grep tr mktemp; do
    if command -v "$cmd" >/dev/null 2>&1; then doctor_status OK "command $cmd" "$(command -v "$cmd")"; else doctor_status FAIL "command $cmd" "not found"; fi
  done
  [ -f "$CONFIG_FILE" ] && doctor_status OK "config file" "$CONFIG_FILE present" || doctor_status WARN "config file" "not found: $CONFIG_FILE"
  [ -n "$GEMINI_API_KEY" ] && doctor_status OK "API key" "loaded" || doctor_status WARN "API key" "not loaded"
  detail="$(check_writable_dir "$SESSION_DIR")"; status=$?; doctor_status $([ "$status" -eq 0 ] && printf OK || printf FAIL) "session dir" "$detail"
  detail="$(check_writable_dir "$ATTACHMENT_DIR")"; status=$?; doctor_status $([ "$status" -eq 0 ] && printf OK || printf FAIL) "attachment dir" "$detail"
  detail="$(check_writable_dir "$(dirname "$MODEL_CACHE_FILE")")"; status=$?; doctor_status $([ "$status" -eq 0 ] && printf OK || printf FAIL) "model cache dir" "$detail"
  [ -f "$MODEL_CACHE_FILE" ] && doctor_status OK "model cache" "$MODEL_CACHE_FILE present" || doctor_status WARN "model cache" "missing; run --update-models"
  editor_first="${EDITOR_CMD:-${VISUAL:-${EDITOR:-vi}}}"; editor_first="${editor_first%% *}"
  command -v "$editor_first" >/dev/null 2>&1 && doctor_status OK editor "$(command -v "$editor_first")" || doctor_status WARN editor "$editor_first not found"
  python3 - <<'PYDOC' 2>/dev/null
import socket
host='generativelanguage.googleapis.com'
try:
    infos=socket.getaddrinfo(host,443,type=socket.SOCK_STREAM)
    addrs=sorted({i[4][0] for i in infos})[:3]
    print('[OK  ] DNS: %s resolves to %s' % (host, ', '.join(addrs)))
except Exception as exc:
    print('[WARN] DNS: lookup failed for %s: %s' % (host, exc))
PYDOC
  if [ -n "$GEMINI_API_KEY" ]; then
    curl -sS --max-time 20 "https://generativelanguage.googleapis.com/v1beta/models?$(models_query)" >/dev/null 2>&1 && doctor_status OK "models endpoint" reachable || doctor_status WARN "models endpoint" "not reachable or API key invalid"
  else
    doctor_status WARN "models endpoint" "skipped: no API key"
  fi
}

