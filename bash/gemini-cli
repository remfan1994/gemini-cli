#!/usr/bin/env bash

# ==========================================================
# gemini-cli
# ----------------------------------------------------------
# Bash-based terminal Gemini AI interface.
#
# VERSION
#   2.5
#
# DESIGN ROLE
#   This Bash edition is the lightweight, line-oriented
#   version of the project. It is meant to stay simple,
#   scriptable, readable, and usable in constrained shells.
#
# FEATURES
#   - Persistent chat sessions
#   - Named/resumable conversations
#   - Timestamped logs
#   - Rolling conversation context
#   - Resume-time memory rebuild from session logs
#   - Memory snapshots saved into session logs
#   - Temporary Project Lead startup notice for new blank sessions
#   - Config file support
#   - Built-in help/version system
#   - Automatic attachment extraction
#   - Configurable storage directories
#   - Model listing
#   - User-operated model testing
#   - Numbered model selection
#   - API-key setup helper
#
# PROJECT LEAD STARTUP NOTICE
#   New blank sessions display a temporary transcript-style
#   message from remfan1994. It is removed from the visible
#   terminal when the first user message is sent. It is not
#   written to logs, not stored in memory, and not sent to
#   Gemini.
#
# MEMORY / CONTEXT TERMINOLOGY
#   CONTEXT_TURNS is the preferred config key.
#
#   It means recent user/assistant exchanges sent back to
#   Gemini so the model can follow the conversation. It does
#   not mean shell command history or complete log length.
#
#   HISTORY_LIMIT is still accepted as a legacy alias so old
#   configs do not break.
#
# MODEL MANAGEMENT
#   Google model names can change over time. This script does
#   not try to permanently know the best model.
#
#   Users can:
#     - list models:
#         gemini-cli --models
#
#     - test one selected model:
#         gemini-cli --test-model MODEL_ID
#
#     - choose from a numbered list:
#         gemini-cli --select-model
#
#   The raw Google model-list command is:
#
#     curl "https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_API_KEY"
#
# MODEL TESTING
#   Autoscan has been removed from the Bash version.
#
#   The tool now tests only a user-selected model. This avoids
#   probing every model in Google's list.
#
# API KEY MANAGEMENT
#   Preferred:
#     export GEMINI_API_KEY=your_key
#
#   Convenient:
#     gemini-cli --set-api-key
#
#   Config file:
#     ~/.config/gemini-cli/config
#
# SECURITY NOTE
#   Saving an API key in the config file stores it in plaintext.
#   The script attempts to chmod the config file to 0600.
#
# INPUT MODEL
#   This Bash version keeps the Ctrl+D send workflow.
#   Type/paste input, then press Ctrl+D to submit it.
#
# ==========================================================

set -o pipefail

PROGRAM="gemini-cli"
VERSION="2.5"

CONFIG_DIR="$HOME/.config/gemini-cli"
CONFIG_FILE="$CONFIG_DIR/config"

SESSION_DIR="$HOME/.gpt"
ATTACHMENT_DIR=""
ATTACHMENT_DIR_CONFIGURED=0

FALLBACK_MODEL="gemini-2.5-flash"
MODEL=""
CONTEXT_TURNS=12
CONTEXT_TURNS_EXPLICIT=0
MODEL_TEST_PROMPT="Please reply with a short sentence confirming this model is available for text generation."
STARTUP_NOTICE=1
PROJECT_LEAD_NAME="remfan1994"
PROJECT_LEAD_NOTICE="I strongly encourage everyone to get cruetly-free VEGETARIAN food and remember the 'bloodguilt' curse from the Bible.  -Project Lead, remfan1994"

USER_NAME="$(whoami)"
CONTEXT_BUFFER=()
SUMMARY=""


# ==========================================================
# SMALL UTILITY FUNCTIONS
# ==========================================================

timestamp() {
  date +"%H:%M:%S"
}

trim() {
  printf '%s' "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

expand_path() {
  python3 -c 'import os, sys; print(os.path.abspath(os.path.expandvars(os.path.expanduser(sys.argv[1]))))' "$1"
}

normalize_model_id() {
  case "$1" in
    models/*)
      printf '%s\n' "${1#models/}"
      ;;
    *)
      printf '%s\n' "$1"
      ;;
  esac
}

quote_url_component() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

api_key_query() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.urlencode({"key": sys.argv[1]}))' "$GEMINI_API_KEY"
}

models_query() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.urlencode({"key": sys.argv[1], "pageSize": "100"}))' "$GEMINI_API_KEY"
}

effective_model() {
  if [ -n "$MODEL" ]; then
    normalize_model_id "$MODEL"
  else
    printf '%s\n' "$FALLBACK_MODEL"
  fi
}

model_label() {
  if [ -n "$MODEL" ]; then
    printf '%s\n' "$(normalize_model_id "$MODEL")"
  else
    printf '%s (fallback; no MODEL configured)\n' "$FALLBACK_MODEL"
  fi
}

sanitize_session_name() {
  python3 -c '
import re
import sys
name = sys.argv[1].strip()
name = re.sub(r"[^A-Za-z0-9._-]+", "_", name)
name = name.strip("._-")
print(name or "session")
' "$1"
}

positive_int_or_default() {
  local value="$1"
  local fallback="$2"

  case "$value" in
    ""|*[!0-9]*)
      printf '%s\n' "$fallback"
      ;;
    *)
      if [ "$value" -lt 1 ]; then
        printf '%s\n' "$fallback"
      else
        printf '%s\n' "$value"
      fi
      ;;
  esac
}

truthy() {
  case "$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')" in
    1|yes|y|true|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

clear_screen() {
  if [ -t 1 ]; then
    printf '\033[H\033[J'
  fi
}


# ==========================================================
# CONFIG FILE SUPPORT
# ----------------------------------------------------------
# Supported keys:
#
#   MODEL
#   CONTEXT_TURNS
#   HISTORY_LIMIT        legacy alias for CONTEXT_TURNS
#   GEMINI_API_KEY
#   SESSION_DIR
#   ATTACHMENT_DIR
#   MODEL_TEST_PROMPT
#   STARTUP_NOTICE
#
# Format:
#   KEY=VALUE
#
# Environment variable GEMINI_API_KEY overrides config file
# GEMINI_API_KEY.
# ==========================================================

if [ -f "$CONFIG_FILE" ]; then
  while IFS= read -r line || [ -n "$line" ]; do
    line="$(trim "$line")"

    case "$line" in
      ""|\#*)
        continue
        ;;
    esac

    case "$line" in
      *=*)
        key="$(trim "${line%%=*}")"
        value="$(trim "${line#*=}")"
        ;;
      *)
        continue
        ;;
    esac

    case "$key" in
      MODEL)
        MODEL="$(normalize_model_id "$value")"
        ;;

      CONTEXT_TURNS)
        CONTEXT_TURNS="$value"
        CONTEXT_TURNS_EXPLICIT=1
        ;;

      HISTORY_LIMIT)
        # Legacy compatibility. CONTEXT_TURNS is clearer because
        # this setting controls conversation context, not shell
        # history or log size.
        if [ "$CONTEXT_TURNS_EXPLICIT" -eq 0 ]; then
          CONTEXT_TURNS="$value"
        fi
        ;;

      GEMINI_API_KEY)
        GEMINI_API_KEY="${GEMINI_API_KEY:-$value}"
        ;;

      SESSION_DIR)
        SESSION_DIR="$(expand_path "$value")"
        ;;

      ATTACHMENT_DIR)
        ATTACHMENT_DIR="$(expand_path "$value")"
        ATTACHMENT_DIR_CONFIGURED=1
        ;;

      MODEL_TEST_PROMPT)
        if [ -n "$value" ]; then
          MODEL_TEST_PROMPT="$value"
        fi
        ;;

      STARTUP_NOTICE)
        STARTUP_NOTICE="$value"
        ;;
    esac
  done < "$CONFIG_FILE"
fi

CONTEXT_TURNS="$(positive_int_or_default "$CONTEXT_TURNS" 12)"

if [ "$ATTACHMENT_DIR_CONFIGURED" -eq 0 ]; then
  ATTACHMENT_DIR="$SESSION_DIR/attachments"
fi

mkdir -p "$CONFIG_DIR"
mkdir -p "$SESSION_DIR"
mkdir -p "$ATTACHMENT_DIR"


# ==========================================================
# CONFIG WRITING
# ----------------------------------------------------------
# Used by:
#   --set-api-key
#   --test-model --save
#   --select-model
#
# This preserves unrelated config lines where possible and
# replaces or appends the requested KEY=VALUE pair.
# ==========================================================

set_config_value() {
  local key="$1"
  local value="$2"
  local tmp

  mkdir -p "$CONFIG_DIR"
  tmp="$(mktemp "${CONFIG_FILE}.tmp.XXXXXX")"

  if [ -f "$CONFIG_FILE" ]; then
    awk -v k="$key" -v v="$value" '
      BEGIN { done = 0 }
      $0 ~ "^" k "=" {
        print k "=" v
        done = 1
        next
      }
      { print }
      END {
        if (!done) {
          print k "=" v
        }
      }
    ' "$CONFIG_FILE" > "$tmp"
  else
    printf '%s=%s\n' "$key" "$value" > "$tmp"
  fi

  mv "$tmp" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}

remove_config_key() {
  local key="$1"
  local tmp

  [ -f "$CONFIG_FILE" ] || return 0
  tmp="$(mktemp "${CONFIG_FILE}.tmp.XXXXXX")"

  awk -v k="$key" '$0 !~ "^" k "=" { print }' "$CONFIG_FILE" > "$tmp"
  mv "$tmp" "$CONFIG_FILE"
  chmod 600 "$CONFIG_FILE" 2>/dev/null || true
}


# ==========================================================
# API KEY REQUIREMENT
# ==========================================================

require_api_key() {
  if [ -z "$GEMINI_API_KEY" ]; then
    printf '%s\n' "ERROR: GEMINI_API_KEY not set."
    printf '%s\n' ""
    printf '%s\n' "Set it with:"
    printf '%s\n' "  export GEMINI_API_KEY=your_key"
    printf '%s\n' ""
    printf '%s\n' "or save it with:"
    printf '%s\n' "  $PROGRAM --set-api-key"
    printf '%s\n' ""
    printf '%s\n' "or put it in:"
    printf '%s\n' "  $CONFIG_FILE"
    return 1
  fi

  return 0
}


