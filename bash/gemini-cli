# ==========================================================
# SESSION MANAGEMENT
# ==========================================================

resolve_session_path() {
  printf '%s/%s.log\n' "$SESSION_DIR" "$1"
}

list_sessions() {
  local path

  for path in "$SESSION_DIR"/*.log; do
    [ -e "$path" ] || continue
    basename "$path" .log
  done
}


# ==========================================================
# RESUME MEMORY REBUILD
# ----------------------------------------------------------
# Bash now has parity with the ncurses edition here.
#
# If a session log already exists, the script parses recent
# entries from the log and rebuilds CONTEXT_BUFFER. This means
# follow-up questions after --resume can refer to earlier
# messages in the same session.
#
# CONTEXT_TURNS counts user/assistant exchanges. Since the log
# contains separate speaker entries, we load up to
# CONTEXT_TURNS * 2 entries.
# ==========================================================

load_context_from_session() {
  python3 - "$SESSION" "$CONTEXT_TURNS" <<'PY'
import re
import sys

path = sys.argv[1]
try:
    context_turns = int(sys.argv[2])
except Exception:
    context_turns = 12

max_entries = max(1, context_turns) * 2
entry_re = re.compile(r"^\[(\d{2}:\d{2}:\d{2})\] ([^:]+): (.*)$")
entries = []
current_speaker = None
current_lines = []

try:
    fh = open(path, "r", encoding="utf-8", errors="replace")
except FileNotFoundError:
    sys.exit(0)

with fh:
    for raw_line in fh:
        line = raw_line.rstrip("\n")
        match = entry_re.match(line)
        if match:
            if current_speaker is not None:
                entries.append((current_speaker, "\n".join(current_lines)))
            current_speaker = match.group(2)
            current_lines = [match.group(3)]
        else:
            if current_speaker is not None:
                current_lines.append(line)

if current_speaker is not None:
    entries.append((current_speaker, "\n".join(current_lines)))

for speaker, text in entries[-max_entries:]:
    label = "Assistant" if speaker == "Gemini" else "User"
    entry = f"{label}: {text}"
    sys.stdout.buffer.write(entry.encode("utf-8", errors="replace") + b"\0")
PY
}

rebuild_context_from_session() {
  CONTEXT_BUFFER=()

  [ -f "$SESSION" ] || return 0

  while IFS= read -r -d '' entry; do
    CONTEXT_BUFFER+=("$entry")
  done < <(load_context_from_session)
}


# ==========================================================
# MODEL LISTING
# ----------------------------------------------------------
# Fetches the live Gemini model list and parses only models
# that report generateContent support.
# ==========================================================

fetch_models_json() {
  local url
  local response
  local curl_status

  require_api_key || return 1

  url="https://generativelanguage.googleapis.com/v1beta/models?$(models_query)"

  response="$(curl -sS --max-time 60 "$url" 2>&1)"
  curl_status=$?

  if [ "$curl_status" -ne 0 ]; then
    printf '%s\n' "curl error while fetching models: $response"
    return 1
  fi

  printf '%s' "$response"
}

parse_models_table() {
  python3 -c '
import json
import sys

raw = sys.stdin.read()

try:
    data = json.loads(raw)
except Exception as exc:
    print(f"ERROR: could not parse model list JSON: {exc}", file=sys.stderr)
    sys.exit(1)

if "error" in data:
    err = data["error"]
    code = err.get("code", "")
    msg = err.get("message", "")
    print(f"ERROR: Gemini API error {code}: {msg}", file=sys.stderr)
    sys.exit(1)

for item in data.get("models", []):
    methods = item.get("supportedGenerationMethods", []) or []
    if "generateContent" not in methods:
        continue

    name = item.get("name", "")
    if name.startswith("models/"):
        model_id = name.split("/", 1)[1]
    else:
        model_id = name

    if not model_id:
        continue

    display = item.get("displayName", model_id)
    input_limit = item.get("inputTokenLimit", "")
    output_limit = item.get("outputTokenLimit", "")

    print(f"{model_id}\t{display}\t{input_limit}\t{output_limit}")
'
}

parse_model_ids() {
  python3 -c '
import json
import sys

raw = sys.stdin.read()

try:
    data = json.loads(raw)
except Exception as exc:
    print(f"ERROR: could not parse model list JSON: {exc}", file=sys.stderr)
    sys.exit(1)

if "error" in data:
    err = data["error"]
    code = err.get("code", "")
    msg = err.get("message", "")
    print(f"ERROR: Gemini API error {code}: {msg}", file=sys.stderr)
    sys.exit(1)

for item in data.get("models", []):
    methods = item.get("supportedGenerationMethods", []) or []
    if "generateContent" not in methods:
        continue

    name = item.get("name", "")
    if name.startswith("models/"):
        model_id = name.split("/", 1)[1]
    else:
        model_id = name

    if model_id:
        print(model_id)
'
}

print_models() {
  local json

  json="$(fetch_models_json)" || return 1
  printf '%s' "$json" | parse_models_table
}


# ==========================================================
# JSON PAYLOAD AND RESPONSE PARSING
# ----------------------------------------------------------
# Python is used here to avoid fragile shell JSON escaping.
# This fixes prompts containing quotes, slashes, backslashes,
# directory paths, and newlines.
# ==========================================================

make_generate_payload() {
  python3 -c '
import json
import sys

text = sys.stdin.read()
payload = {
    "contents": [
        {
            "parts": [
                {
                    "text": text
                }
            ]
        }
    ]
}

print(json.dumps(payload))
'
}

parse_generate_text() {
  python3 -c '
import json
import sys

raw = sys.stdin.read()

try:
    data = json.loads(raw)
except Exception as exc:
    print(f"invalid JSON response: {exc}; raw response: {raw[:1000]}")
    sys.exit(1)

if "error" in data:
    err = data["error"]
    code = err.get("code", "")
    msg = err.get("message", "")
    print(f"Gemini API error {code}: {msg}")
    sys.exit(1)

try:
    text = data["candidates"][0]["content"]["parts"][0]["text"]
except Exception as exc:
    print(f"unexpected response structure: {exc}; raw response: {raw[:1000]}")
    sys.exit(1)

if not text.strip():
    print("Gemini returned an empty text response")
    sys.exit(1)

print(text)
'
}

call_gemini_model() {
  local model="$1"
  local prompt="$2"
  local timeout="${3:-120}"
  local clean_model
  local quoted_model
  local url
  local response
  local curl_status
  local output
  local parse_status

  require_api_key || return 1

  clean_model="$(normalize_model_id "$model")"
  quoted_model="$(quote_url_component "$clean_model")"
  url="https://generativelanguage.googleapis.com/v1beta/models/$quoted_model:generateContent?$(api_key_query)"

  response="$(
    printf '%s' "$prompt" \
      | make_generate_payload \
      | curl -sS --max-time "$timeout" \
          -H "Content-Type: application/json" \
          -d @- \
          "$url" 2>&1
  )"

  curl_status=$?

  if [ "$curl_status" -ne 0 ]; then
    printf '%s\n' "curl error: $response"
    return 1
  fi

  output="$(printf '%s' "$response" | parse_generate_text)"
  parse_status=$?

  printf '%s\n' "$output"
  return "$parse_status"
}


# ==========================================================
# MODEL AUTOSCAN
# ----------------------------------------------------------
# This avoids guessing future Google model names.
#
# Autoscan:
#   1. Fetches the live model list.
#   2. Filters to generateContent models.
#   3. Tests each with AUTOSCAN_PROMPT.
#   4. Validates that the response contains AUTOSCAN_EXPECTED.
#   5. Prints the first model that passes.
# ==========================================================

autoscan_response_valid() {
  python3 -c '
import sys
expected = sys.argv[1].strip().lower() or "austin"
text = sys.stdin.read().lower()
sys.exit(0 if expected in text else 1)
' "$AUTOSCAN_EXPECTED"
}

autoscan_model() {
  local json
  local ids_text
  local model
  local total
  local i
  local output
  local status
  local last_error=""
  local snippet

  json="$(fetch_models_json)" || return 1
  ids_text="$(printf '%s' "$json" | parse_model_ids)" || return 1

  if [ -z "$ids_text" ]; then
    printf '%s\n' "No generateContent-compatible models were returned by the API."
    return 1
  fi

  mapfile -t MODEL_IDS <<< "$ids_text"
  total="${#MODEL_IDS[@]}"
  i=0

  for model in "${MODEL_IDS[@]}"; do
    i=$((i + 1))
    printf 'testing %s/%s: %s\n' "$i" "$total" "$model" >&2

    output="$(call_gemini_model "$model" "$AUTOSCAN_PROMPT" 45)"
    status=$?

    if [ "$status" -eq 0 ] && printf '%s' "$output" | autoscan_response_valid; then
      printf '%s\n' "$model"
      return 0
    fi

    if [ "$status" -eq 0 ]; then
      snippet="$(printf '%s' "$output" | tr '\n' ' ' | cut -c 1-200)"
      last_error="response did not contain expected substring '$AUTOSCAN_EXPECTED'; response: $snippet"
    else
      last_error="$output"
    fi
  done

  printf '%s\n' "No tested model answered the autoscan challenge correctly. Last error: $last_error"
  return 1
}

autoscan_command() {
  local selected
  local status

  selected="$(autoscan_model)"
  status=$?

  if [ "$status" -ne 0 ]; then
    printf '%s\n' "$selected" >&2
    return 1
  fi

  printf '%s\n' "$selected"

  if [ "$SAVE" -eq 1 ]; then
    set_config_value "MODEL" "$selected"
    printf 'saved MODEL=%s to %s\n' "$selected" "$CONFIG_FILE" >&2
  else
    printf '%s\n' "" >&2
    printf '%s\n' "To save this model:" >&2
    printf '  %s --autoscan-model --save\n' "$PROGRAM" >&2
  fi
}


# ==========================================================
# NUMBERED MODEL SELECTION
# ----------------------------------------------------------
# This is the Bash version of model selection. It stays
# line-oriented: print a numbered list, read a number, save
# if requested or confirmed.
# ==========================================================

select_model_command() {
  local json
  local table
  local line
  local index
  local choice
  local selected_line
  local selected_model
  local display
  local input_limit
  local output_limit
  local answer

  json="$(fetch_models_json)" || return 1
  table="$(printf '%s' "$json" | parse_models_table)" || return 1

  if [ -z "$table" ]; then
    printf '%s\n' "No generateContent-compatible models were returned by the API."
    return 1
  fi

  mapfile -t MODEL_LINES <<< "$table"

  printf '%s\n' "Available generateContent models:"
  printf '%s\n' ""

  index=1
  for line in "${MODEL_LINES[@]}"; do
    IFS=$'\t' read -r selected_model display input_limit output_limit <<< "$line"

    if [ -n "$input_limit" ] || [ -n "$output_limit" ]; then
      printf '%3d) %s - %s (input:%s output:%s)\n' \
        "$index" "$selected_model" "$display" "${input_limit:-?}" "${output_limit:-?}"
    else
      printf '%3d) %s - %s\n' "$index" "$selected_model" "$display"
    fi

    index=$((index + 1))
  done

  printf '%s\n' ""
  printf 'Select model number: '
  IFS= read -r choice

  case "$choice" in
    ""|*[!0-9]*)
      printf '%s\n' "Invalid selection."
      return 1
      ;;
  esac

  if [ "$choice" -lt 1 ] || [ "$choice" -gt "${#MODEL_LINES[@]}" ]; then
    printf '%s\n' "Selection out of range."
    return 1
  fi

  selected_line="${MODEL_LINES[$((choice - 1))]}"
  IFS=$'\t' read -r selected_model display input_limit output_limit <<< "$selected_line"

  printf 'Selected model: %s\n' "$selected_model"

  if [ "$SAVE" -eq 1 ]; then
    set_config_value "MODEL" "$selected_model"
    printf 'saved MODEL=%s to %s\n' "$selected_model" "$CONFIG_FILE"
    return 0
  fi

  printf 'Save MODEL=%s to config? [y/N] ' "$selected_model"
  IFS= read -r answer

  case "$answer" in
    y|Y|yes|YES)
      set_config_value "MODEL" "$selected_model"
      printf 'saved MODEL=%s to %s\n' "$selected_model" "$CONFIG_FILE"
      ;;
    *)
      printf '%s\n' "Model not saved. To save without prompting:"
      printf '  %s --select-model --save\n' "$PROGRAM"
      ;;
  esac
}


# ==========================================================
# API KEY SETUP
# ----------------------------------------------------------
# This stores GEMINI_API_KEY in the config file.
# It is convenient, but less secure than using an environment
# variable.
# ==========================================================

set_api_key_command() {
  local answer
  local key

  printf '%s\n' "This will save GEMINI_API_KEY in plaintext:"
  printf '  %s\n' "$CONFIG_FILE"
  printf '%s\n' ""
  printf '%s\n' "The file will be chmod 0600 where possible."
  printf '%s\n' ""
  printf 'Continue? [y/N] '
  IFS= read -r answer

  case "$answer" in
    y|Y|yes|YES)
      ;;
    *)
      printf '%s\n' "Cancelled."
      return 1
      ;;
  esac

  printf 'Paste Gemini API key: '
  IFS= read -r -s key
  printf '%s\n' ""

  if [ -z "$key" ]; then
    printf '%s\n' "No key entered."
    return 1
  fi

  set_config_value "GEMINI_API_KEY" "$key"
  printf 'saved GEMINI_API_KEY to %s\n' "$CONFIG_FILE"
}


# ==========================================================
# CONTEXT MEMORY SYSTEM
# ----------------------------------------------------------
# Lightweight rolling conversation context.
#
# CONTEXT_TURNS counts recent user/assistant exchanges.
# Internally, each exchange is two entries:
#   User: ...
#   Assistant: ...
#
# Therefore the actual entry buffer limit is:
#   CONTEXT_TURNS * 2
# ==========================================================

add_to_context() {
  CONTEXT_BUFFER+=("$1")
  trim_context_buffer
}

trim_context_buffer() {
  local max_entries=$((CONTEXT_TURNS * 2))

  while [ "${#CONTEXT_BUFFER[@]}" -gt "$max_entries" ]; do
    CONTEXT_BUFFER=("${CONTEXT_BUFFER[@]:1}")
  done
}

build_context() {
  local context="$SUMMARY"
  local msg

  for msg in "${CONTEXT_BUFFER[@]}"; do
    if [ -n "$context" ]; then
      context+=$'\n'
    fi
    context+="$msg"
  done

  printf '%s' "$context"
}


# ==========================================================
# ATTACHMENT EXTRACTION SYSTEM
# ----------------------------------------------------------
# Fenced markdown code blocks are removed from terminal
# output and saved into ATTACHMENT_DIR.
#
# The raw full Gemini response remains in the session log.
# ==========================================================

extract_attachments() {
  python3 -c '
import os
import re
import sys

attachment_dir = sys.argv[1]
session_name = sys.argv[2]
text = sys.stdin.read()

ext_map = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "py": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "c": ".c",
    "cpp": ".cpp",
    "c++": ".cpp",
    "text": ".txt",
}

pattern = re.compile(r"```([A-Za-z0-9_+.#-]*)[ \t]*\n(.*?)```", re.DOTALL)

def safe_tag(lang):
    lang = (lang or "text").strip().lower()
    lang = lang.replace("+", "p").replace("#", "sharp")
    lang = re.sub(r"[^A-Za-z0-9._-]+", "_", lang)
    return lang or "text"

def next_number(lang, ext):
    highest = 0
    regex = re.compile(
        r"^" + re.escape(session_name) + "-" + re.escape(lang) + r"-(\d{2,})" + re.escape(ext) + r"$"
    )

    if os.path.isdir(attachment_dir):
        for name in os.listdir(attachment_dir):
            match = regex.match(name)
            if match:
                highest = max(highest, int(match.group(1)))

    return highest + 1

def replacement(match):
    raw_lang = (match.group(1) or "text").strip().lower()
    lang = safe_tag(raw_lang)
    content = match.group(2)
    ext = ext_map.get(raw_lang, ext_map.get(lang, ".txt"))
    number = next_number(lang, ext)

    filename = f"{session_name}-{lang}-{number:02d}{ext}"
    path = os.path.join(attachment_dir, filename)

    os.makedirs(attachment_dir, exist_ok=True)

    with open(path, "w", encoding="utf-8") as fh:
        fh.write(content)

    return (
        "\n"
        "[attachment saved]\n"
        f"file: {filename}\n"
        f"location: {attachment_dir}\n"
    )

print(pattern.sub(replacement, text))
' "$ATTACHMENT_DIR" "$SESSION_NAME"
}


# ==========================================================
# ARGUMENT PARSING
# ==========================================================

ACTION="chat"
SAVE=0
SESSION_NAME=""
RESUME=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help|help)
      ACTION="help"
      ;;

    --version)
      ACTION="version"
      ;;

    --list)
      ACTION="list"
      ;;

    --models)
      ACTION="models"
      ;;

    --autoscan-model)
      ACTION="autoscan"
      ;;

    --select-model)
      ACTION="select"
      ;;

    --set-api-key)
      ACTION="set-api-key"
      ;;

    --save)
      SAVE=1
      ;;

    --resume)
      RESUME=1
      shift

      if [ -z "${1:-}" ]; then
        printf '%s\n' "ERROR: --resume requires a session name." >&2
        exit 2
      fi

      SESSION_NAME="$1"
      ;;

    --)
      shift
      break
      ;;

    -*)
      printf 'ERROR: unknown option: %s\n' "$1" >&2
      exit 2
      ;;

    *)
      if [ "$ACTION" = "chat" ] && [ -z "$SESSION_NAME" ]; then
        SESSION_NAME="$1"
      else
        printf 'ERROR: unexpected argument: %s\n' "$1" >&2
        exit 2
      fi
      ;;
  esac

  shift
done

case "$ACTION" in
  help)
    help_menu
    exit 0
    ;;

  version)
    version
    exit 0
    ;;

  list)
    list_sessions
    exit 0
    ;;

  models)
    print_models
    exit $?
    ;;

  autoscan)
    autoscan_command
    exit $?
    ;;

  select)
    select_model_command
    exit $?
    ;;

  set-api-key)
    set_api_key_command
    exit $?
    ;;
esac

if [ "$SAVE" -eq 1 ]; then
  printf '%s\n' "ERROR: --save is only valid with --autoscan-model or --select-model." >&2
  exit 2
fi


# ==========================================================
# CHAT SESSION SETUP
# ==========================================================

require_api_key || exit 1

if [ -z "$SESSION_NAME" ]; then
  SESSION_NAME="session-$(date +%Y-%m-%d-%H-%M-%S)"
else
  SESSION_NAME="$(sanitize_session_name "$SESSION_NAME")"
fi

SESSION="$(resolve_session_path "$SESSION_NAME")"

if [ "$RESUME" -eq 1 ] && [ ! -f "$SESSION" ]; then
  printf 'ERROR: session not found: %s\n' "$SESSION_NAME" >&2
  exit 1
fi

# Rebuild recent conversation context from any existing session log. This
# applies to --resume and also to named sessions that already exist.
rebuild_context_from_session

ACTIVE_MODEL="$(effective_model)"

printf '%s\n' "$PROGRAM"
printf 'session: %s\n' "$SESSION"
printf 'model: %s\n' "$(model_label)"
printf 'context turns: %s\n' "$CONTEXT_TURNS"

if [ -f "$SESSION" ] && [ "${#CONTEXT_BUFFER[@]}" -gt 0 ]; then
  printf 'loaded context entries: %s\n' "${#CONTEXT_BUFFER[@]}"
fi

printf '%s\n' "Ctrl+D to send message, Ctrl+C to exit"
printf '%s\n' ""

if [ -z "$MODEL" ]; then
  printf '%s\n' "No MODEL configured. Using fallback model."
  printf '%s\n' "To find and save a working model:"
  printf '  %s --autoscan-model --save\n' "$PROGRAM"
  printf '%s\n' ""
fi


# ==========================================================
# MAIN CHAT LOOP
# ==========================================================

while true; do
  TS="$(timestamp)"

  printf '[%s] %s> ' "$TS" "$USER_NAME"

  buffer="$(cat)"

  [ -z "$buffer" ] && continue

  printf '[%s] %s: %s\n' "$TS" "$USER_NAME" "$buffer" >> "$SESSION"

  add_to_context "User: $buffer"

  printf '%s\n' ""
  printf '%s\n' "________________________________________"
  printf '%s\n' "END INPUT"
  printf '%s\n' "________________________________________"
  printf '[%s] Generating response...\n' "$(timestamp)"
  printf '%s\n' "________________________________________"
  printf '%s\n' "BEGIN OUTPUT"
  printf '%s\n' "________________________________________"
  printf '%s\n' ""

  prompt_text="$(build_context)"

  output="$(call_gemini_model "$ACTIVE_MODEL" "$prompt_text" 120)"
  output_status=$?

  if [ "$output_status" -ne 0 ]; then
    output="(response error: $output)"
  fi

  [ -z "$output" ] && output="(empty response or API error)"

  printf '[%s] Gemini: %s\n' "$(timestamp)" "$output" >> "$SESSION"

  cleaned_output="$(printf '%s' "$output" | extract_attachments)"

  add_to_context "Assistant: $cleaned_output"

  printf '%s\n\n' "$cleaned_output"
done
