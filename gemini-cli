#!/usr/bin/env bash

# ==========================================================
# gemini-cli
# ----------------------------------------------------------
# Terminal-based Gemini AI interface
#
# FEATURES
#   - Persistent chat sessions
#   - Named/resumable conversations
#   - Timestamped logs
#   - Lightweight rolling memory
#   - Config file support
#   - Attachment extraction system
#
# ATTACHMENT SYSTEM
#   Code blocks returned by Gemini are automatically:
#     - extracted from terminal output
#     - saved into ~/.gpt/attachments/
#     - replaced with attachment notices
#
# DESIGN GOALS
#   - minimal dependencies
#   - shell-friendly
#   - readable logs
#   - artifact-oriented workflow
# ==========================================================


# ==========================================================
# DIRECTORY SETUP
# ==========================================================

CONFIG_DIR="$HOME/.config/gemini-cli"
CONFIG_FILE="$CONFIG_DIR/config"

SESSION_DIR="$HOME/.gpt"
ATTACHMENT_DIR="$SESSION_DIR/attachments"

mkdir -p "$CONFIG_DIR"
mkdir -p "$SESSION_DIR"
mkdir -p "$ATTACHMENT_DIR"


# ==========================================================
# DEFAULT SETTINGS
# ==========================================================

MODEL="gemini-2.5-flash"
HISTORY_LIMIT=12


# ==========================================================
# CONFIG FILE LOADING
# ==========================================================

if [ -f "$CONFIG_FILE" ]; then
  while IFS='=' read -r key value; do
    case "$key" in
      MODEL)
        MODEL="$value"
        ;;
      HISTORY_LIMIT)
        HISTORY_LIMIT="$value"
        ;;
      GEMINI_API_KEY)
        GEMINI_API_KEY="${GEMINI_API_KEY:-$value}"
        ;;
    esac
  done < "$CONFIG_FILE"
fi


# ==========================================================
# API KEY VALIDATION
# ==========================================================

if [ -z "$GEMINI_API_KEY" ]; then
  echo "ERROR: GEMINI_API_KEY not set"
  echo ""
  echo "Set it either:"
  echo "  export GEMINI_API_KEY=your_key"
  echo ""
  echo "or inside:"
  echo "  ~/.config/gemini-cli/config"
  exit 1
fi


# ==========================================================
# API ENDPOINT
# ==========================================================

URL="https://generativelanguage.googleapis.com/v1beta/models/$MODEL:generateContent?key=$GEMINI_API_KEY"


# ==========================================================
# RUNTIME VARIABLES
# ==========================================================

USER_NAME="$(whoami)"
HISTORY=()
SUMMARY=""


# ==========================================================
# UTILITIES
# ==========================================================

timestamp() {
  date +"%H:%M:%S"
}

resolve_session_path() {
  echo "$SESSION_DIR/$1.log"
}

list_sessions() {
  ls -1 "$SESSION_DIR"/*.log 2>/dev/null \
    | sed 's#.*/##; s/\.log$##'
  exit 0
}

version() {
  echo "gemini-cli version 2.0"
  exit 0
}


# ==========================================================
# SESSION ARGUMENT PARSING
# ==========================================================

case "$1" in

  --version)
    version
    ;;

  --list)
    list_sessions
    ;;

  --resume)
    SESSION="$(resolve_session_path "$2")"
    SESSION_NAME="$2"
    ;;

  "")
    SESSION_NAME="session-$(date +%Y-%m-%d-%H-%M-%S)"
    SESSION="$SESSION_DIR/$SESSION_NAME.log"
    ;;

  *)
    SESSION_NAME="$1"
    SESSION="$(resolve_session_path "$1")"
    ;;
esac


# ==========================================================
# STARTUP BANNER
# ==========================================================

echo "gemini-cli"
echo "session: $SESSION"
echo "model: $MODEL"
echo ""


# ==========================================================
# MEMORY MANAGEMENT
# ==========================================================

add_to_history() {
  HISTORY+=("$1")

  if [ "${#HISTORY[@]}" -gt "$HISTORY_LIMIT" ]; then
    HISTORY=("${HISTORY[@]: -6}")
  fi
}

build_context() {
  context="$SUMMARY\n"

  for msg in "${HISTORY[@]}"; do
    context="$context$msg\n"
  done

  printf "%s" "$context"
}


# ==========================================================
# ATTACHMENT EXTRACTION
# ----------------------------------------------------------
# This function:
#   - scans Gemini output for fenced code blocks
#   - saves them into attachment files
#   - removes them from displayed terminal output
#
# Terminal output becomes cleaner while preserving
# artifacts as reusable files.
# ==========================================================

extract_attachments() {

python3 - "$ATTACHMENT_DIR" "$SESSION_NAME" <<'PYTHON'
import os
import re
import sys

attachment_dir = sys.argv[1]
session_name = sys.argv[2]

text = sys.stdin.read()

# ==========================================================
# LANGUAGE -> EXTENSION MAP
# ==========================================================

ext_map = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "text": ".txt"
}

counter = 1

pattern = re.compile(
    r"```([a-zA-Z0-9_-]*)\n(.*?)```",
    re.DOTALL
)

def replacement(match):
    global counter

    lang = match.group(1).strip().lower()
    content = match.group(2)

    if not lang:
        lang = "text"

    ext = ext_map.get(lang, ".txt")

    filename = (
        f"{session_name}-"
        f"{lang}-"
        f"{counter:02d}"
        f"{ext}"
    )

    path = os.path.join(attachment_dir, filename)

    with open(path, "w") as f:
        f.write(content)

    counter += 1

    return (
        f"\n"
        f"[attachment saved]\n"
        f"file: {filename}\n"
        f"location: {attachment_dir}\n"
    )

cleaned = pattern.sub(replacement, text)

print(cleaned)
PYTHON

}


# ==========================================================
# MAIN CHAT LOOP
# ==========================================================

while true; do

  TS="$(timestamp)"

  printf "[%s] %s> " "$TS" "$USER_NAME"

  buffer=$(cat)

  [ -z "$buffer" ] && continue


  # ========================================================
  # LOG USER INPUT
  # ========================================================

  printf "[%s] %s: %s\n" \
    "$TS" \
    "$USER_NAME" \
    "$buffer" >> "$SESSION"

  add_to_history "User: $buffer"


  # ========================================================
  # VISUAL OUTPUT SEPARATORS
  # ========================================================

  printf "\n________________________________________\n"
  printf "END INPUT\n"
  printf "________________________________________\n"

  printf "[%s] Generating response...\n" "$(timestamp)"

  printf "________________________________________\n"
  printf "BEGIN OUTPUT\n"
  printf "________________________________________\n\n"


  # ========================================================
  # CONTEXT BUILDING
  # ========================================================

  context=$(build_context)


  # ========================================================
  # GEMINI API REQUEST
  # ========================================================

  response=$(curl -s "$URL" \
    -H "Content-Type: application/json" \
    -d "{\"contents\":[{\"parts\":[{\"text\":\"$context\nUser: $buffer\"}]}]}")


  # ========================================================
  # RESPONSE PARSING
  # ========================================================

  output=$(printf '%s' "$response" | python3 -c '
import sys, json

d = json.load(sys.stdin)

print(
  d["candidates"][0]
   ["content"]["parts"][0]["text"]
)
')


  # ========================================================
  # FALLBACK SAFETY
  # ========================================================

  [ -z "$output" ] && \
    output="(empty response or API error)"


  # ========================================================
  # STORE FULL RAW OUTPUT IN SESSION LOG
  # --------------------------------------------------------
  # IMPORTANT:
  #   Session logs preserve the original complete response,
  #   INCLUDING code blocks.
  #
  # Terminal display is the only thing cleaned.
  # ========================================================

  printf "[%s] Gemini: %s\n" \
    "$(timestamp)" \
    "$output" >> "$SESSION"


  # ========================================================
  # ATTACHMENT EXTRACTION PIPELINE
  # ========================================================

  cleaned_output=$(printf '%s' "$output" | extract_attachments)


  # ========================================================
  # MEMORY UPDATE
  # ========================================================

  add_to_history "Assistant: $cleaned_output"


  # ========================================================
  # DISPLAY CLEANED OUTPUT
  # ========================================================

  printf "%s\n\n" "$cleaned_output"

done
