#!/usr/bin/env bash

# ==========================================================
# gemini-cli
# ----------------------------------------------------------
# Terminal-based Gemini AI workspace
#
# FEATURES
#   - Persistent chat sessions
#   - Named/resumable conversations
#   - Timestamped logs
#   - Lightweight rolling memory
#   - Config file support
#   - Built-in help/version system
#   - Automatic attachment extraction
#   - Configurable storage directories
#
# ATTACHMENT SYSTEM
#   Markdown fenced code blocks returned by Gemini are:
#
#     - removed from terminal output
#     - saved as reusable files
#     - replaced with attachment notices
#
# DESIGN GOALS
#   - minimal dependencies
#   - shell-friendly
#   - readable logs
#   - artifact-oriented workflow
#   - publishable architecture
# ==========================================================


# ==========================================================
# CONFIGURATION LOCATIONS
# ----------------------------------------------------------
# CONFIG_DIR
#   Stores gemini-cli configuration files
#
# CONFIG_FILE
#   Main runtime configuration file
# ==========================================================

CONFIG_DIR="$HOME/.config/gemini-cli"
CONFIG_FILE="$CONFIG_DIR/config"


# ==========================================================
# DEFAULT STORAGE LOCATIONS
# ----------------------------------------------------------
# These defaults may be overridden inside the config file.
#
# SESSION_DIR
#   Stores persistent conversation logs
#
# ATTACHMENT_DIR
#   Stores extracted code artifacts
# ==========================================================

SESSION_DIR="$HOME/.gpt"
ATTACHMENT_DIR="$SESSION_DIR/attachments"


# ==========================================================
# DEFAULT SETTINGS
# ----------------------------------------------------------
# These values are fallback defaults and may be overridden
# by configuration file values.
# ==========================================================

MODEL="gemini-2.5-flash"

# Number of recent conversational entries retained
# in the rolling context window.
HISTORY_LIMIT=12


# ==========================================================
# CONFIG FILE LOADING
# ----------------------------------------------------------
# Supported configuration keys:
#
#   MODEL
#   HISTORY_LIMIT
#   GEMINI_API_KEY
#   SESSION_DIR
#   ATTACHMENT_DIR
#
# Format:
#   KEY=VALUE
#
# Example:
#
#   MODEL=gemini-2.5-flash
#   HISTORY_LIMIT=20
#   SESSION_DIR=/home/user/history
# ==========================================================

if [ -f "$CONFIG_FILE" ]; then

  while IFS='=' read -r key value; do

    case "$key" in

      MODEL)
        MODEL="$value"
        ;;

      HISTORY_LIMIT)
        HISTORY_LIMIT="$value"
        ;;

      GEMINI_API_KEY)
        GEMINI_API_KEY="${GEMINI_API_KEY:-$value}"
        ;;

      SESSION_DIR)
        SESSION_DIR="$value"
        ;;

      ATTACHMENT_DIR)
        ATTACHMENT_DIR="$value"
        ;;

    esac

  done < "$CONFIG_FILE"

fi


# ==========================================================
# ENSURE STORAGE DIRECTORIES EXIST
# ----------------------------------------------------------
# IMPORTANT:
#   This occurs AFTER config parsing so user-overridden
#   paths are respected.
# ==========================================================

mkdir -p "$CONFIG_DIR"
mkdir -p "$SESSION_DIR"
mkdir -p "$ATTACHMENT_DIR"


# ==========================================================
# API KEY VALIDATION
# ----------------------------------------------------------
# API key priority:
#
#   1. environment variable
#   2. config file
#
# Environment variables are preferred because they avoid
# storing secrets in plaintext configuration files.
# ==========================================================

if [ -z "$GEMINI_API_KEY" ]; then

  echo "ERROR: GEMINI_API_KEY not set"
  echo ""
  echo "Set via:"
  echo "  export GEMINI_API_KEY=your_key"
  echo ""
  echo "or inside:"
  echo "  ~/.config/gemini-cli/config"

  exit 1

fi


# ==========================================================
# GEMINI API ENDPOINT
# ----------------------------------------------------------
# Construct endpoint dynamically from selected model.
#
# This allows model changes without script modification.
# ==========================================================

URL="https://generativelanguage.googleapis.com/v1beta/models/$MODEL:generateContent?key=$GEMINI_API_KEY"


# ==========================================================
# RUNTIME VARIABLES
# ----------------------------------------------------------
# USER_NAME
#   Used for terminal display and logging
#
# HISTORY
#   Rolling conversational context window
#
# SUMMARY
#   Placeholder for future summarization system
# ==========================================================

USER_NAME="$(whoami)"

HISTORY=()
SUMMARY=""


# ==========================================================
# TIMESTAMP UTILITY
# ----------------------------------------------------------
# Standardized timestamp format for:
#
#   - prompts
#   - logs
#   - status messages
# ==========================================================

timestamp() {
  date +"%H:%M:%S"
}


# ==========================================================
# SESSION UTILITIES
# ----------------------------------------------------------
# Session files are stored as:
#
#   SESSION_DIR/<name>.log
#
# These helper functions centralize session operations.
# ==========================================================

resolve_session_path() {
  echo "$SESSION_DIR/$1.log"
}

list_sessions() {

  ls -1 "$SESSION_DIR"/*.log 2>/dev/null \
    | sed 's#.*/##; s/\.log$##'

  exit 0
}


# ==========================================================
# VERSION DISPLAY
# ----------------------------------------------------------
# Simple machine-readable version output.
#
# This becomes important for:
#   - debugging
#   - issue reporting
#   - release tracking
# ==========================================================

version() {

  echo "gemini-cli version 2.2"

  exit 0
}


# ==========================================================
# BUILT-IN HELP SYSTEM
# ----------------------------------------------------------
# Self-documenting command-line usage reference.
#
# Supported aliases:
#
#   -h
#   --help
#   help
#
# This avoids forcing users to open:
#   - README
#   - man page
#   - source code
#
# for basic operational reminders.
# ==========================================================

help_menu() {

cat <<EOF

gemini-cli - terminal Gemini interface

USAGE
    gemini-cli
        Start new timestamped session

    gemini-cli <name>
        Start/create named session

    gemini-cli --resume <name>
        Resume named session

    gemini-cli --list
        List saved sessions

    gemini-cli --version
        Show version information

    gemini-cli --help
    gemini-cli -h
        Show this help screen

CONFIG FILE
    ~/.config/gemini-cli/config

SUPPORTED CONFIG KEYS
    MODEL
    HISTORY_LIMIT
    GEMINI_API_KEY
    SESSION_DIR
    ATTACHMENT_DIR

ATTACHMENT SYSTEM
    Markdown fenced code blocks returned by Gemini
    are automatically extracted into attachment files.

FILES
    Session logs:
        SESSION_DIR

    Attachments:
        ATTACHMENT_DIR

VERSION
    gemini-cli version 2.2

EOF

exit 0
}


# ==========================================================
# ARGUMENT PARSING
# ----------------------------------------------------------
# Supported modes:
#
#   gemini-cli
#   gemini-cli <name>
#   gemini-cli --resume <name>
#   gemini-cli --list
#   gemini-cli --version
#   gemini-cli --help
#
# CLI STRUCTURE PRINCIPLE
#   Keep argument behavior explicit and stable.
# ==========================================================

case "$1" in

  -h|--help|help)

    help_menu

    ;;

  --version)

    version

    ;;

  --list)

    list_sessions

    ;;

  --resume)

    SESSION_NAME="$2"
    SESSION="$(resolve_session_path "$2")"

    ;;

  "")

    SESSION_NAME="session-$(date +%Y-%m-%d-%H-%M-%S)"
    SESSION="$SESSION_DIR/$SESSION_NAME.log"

    ;;

  *)

    SESSION_NAME="$1"
    SESSION="$(resolve_session_path "$1")"

    ;;

esac


# ==========================================================
# STARTUP HEADER
# ----------------------------------------------------------
# Display current runtime information for visibility.
# ==========================================================

echo "gemini-cli"
echo "session: $SESSION"
echo "model: $MODEL"
echo ""


# ==========================================================
# MEMORY SYSTEM
# ----------------------------------------------------------
# Lightweight rolling conversational memory.
#
# Avoids:
#   - uncontrolled token growth
#   - replaying entire logs every request
#   - massive API payloads
# ==========================================================

add_to_history() {

  HISTORY+=("$1")

  if [ "${#HISTORY[@]}" -gt "$HISTORY_LIMIT" ]; then
    HISTORY=("${HISTORY[@]: -6}")
  fi
}

build_context() {

  context="$SUMMARY\n"

  for msg in "${HISTORY[@]}"; do
    context="$context$msg\n"
  done

  printf "%s" "$context"
}


# ==========================================================
# ATTACHMENT EXTRACTION SYSTEM
# ----------------------------------------------------------
# Detect fenced markdown code blocks and:
#
#   - save them into ATTACHMENT_DIR
#   - remove them from displayed terminal output
#   - replace them with attachment notices
#
# IMPORTANT DESIGN DECISION
#   Session logs preserve FULL raw Gemini output.
#
# Only terminal display is cleaned.
# ==========================================================

extract_attachments() {

python3 - "$ATTACHMENT_DIR" "$SESSION_NAME" <<'PYTHON'

import os
import re
import sys

attachment_dir = sys.argv[1]
session_name = sys.argv[2]

text = sys.stdin.read()


# ==========================================================
# LANGUAGE -> EXTENSION MAP
# ----------------------------------------------------------
# Determines attachment file extension based on markdown
# fence language identifier.
# ==========================================================

ext_map = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "text": ".txt"
}


# ==========================================================
# ATTACHMENT COUNTER
# ----------------------------------------------------------
# Generates filenames like:
#
#   mychat-python-01.py
#   mychat-bash-02.sh
# ==========================================================

counter = 1


# ==========================================================
# MARKDOWN CODE BLOCK DETECTION
# ----------------------------------------------------------
# Matches fenced markdown blocks:
#
#   ```python
#   print("hello")
#   ```
# ==========================================================

pattern = re.compile(
    r"```([a-zA-Z0-9_-]*)\n(.*?)```",
    re.DOTALL
)


# ==========================================================
# REPLACEMENT FUNCTION
# ----------------------------------------------------------
# Saves extracted code into attachment files and returns
# placeholder text for terminal display.
# ==========================================================

def replacement(match):

    global counter

    lang = match.group(1).strip().lower()
    content = match.group(2)

    if not lang:
        lang = "text"

    ext = ext_map.get(lang, ".txt")

    filename = (
        f"{session_name}-"
        f"{lang}-"
        f"{counter:02d}"
        f"{ext}"
    )

    path = os.path.join(attachment_dir, filename)

    with open(path, "w") as f:
        f.write(content)

    counter += 1

    return (
        f"\n"
        f"[attachment saved]\n"
        f"file: {filename}\n"
        f"location: {attachment_dir}\n"
    )


# ==========================================================
# PROCESS GEMINI OUTPUT
# ==========================================================

cleaned = pattern.sub(replacement, text)

print(cleaned)

PYTHON

}


# ==========================================================
# MAIN CHAT LOOP
# ----------------------------------------------------------
# Core runtime loop:
#
#   1. receive user input
#   2. log input
#   3. build conversational context
#   4. call Gemini API
#   5. extract attachments
#   6. display cleaned output
#   7. update rolling memory
# ==========================================================

while true; do

  TS="$(timestamp)"


  # ========================================================
  # USER INPUT
  # --------------------------------------------------------
  # Uses stdin-based multiline input.
  #
  # Input ends when stdin closes (Ctrl+D).
  # ========================================================

  printf "[%s] %s> " "$TS" "$USER_NAME"

  buffer=$(cat)

  [ -z "$buffer" ] && continue


  # ========================================================
  # LOG USER INPUT
  # ========================================================

  printf "[%s] %s: %s\n" \
    "$TS" \
    "$USER_NAME" \
    "$buffer" >> "$SESSION"

  add_to_history "User: $buffer"


  # ========================================================
  # VISUAL SEPARATORS
  # --------------------------------------------------------
  # Improves readability during long conversations.
  # ========================================================

  printf "\n________________________________________\n"
  printf "END INPUT\n"
  printf "________________________________________\n"

  printf "[%s] Generating response...\n" "$(timestamp)"

  printf "________________________________________\n"
  printf "BEGIN OUTPUT\n"
  printf "________________________________________\n\n"


  # ========================================================
  # BUILD CONTEXT
  # ========================================================

  context=$(build_context)


  # ========================================================
  # GEMINI API REQUEST
  # --------------------------------------------------------
  # Sends conversational context to Gemini REST API.
  #
  # Dependency strategy:
  #   Use curl directly to minimize stack complexity.
  # ========================================================

  response=$(curl -s "$URL" \
    -H "Content-Type: application/json" \
    -d "{\"contents\":[{\"parts\":[{\"text\":\"$context\nUser: $buffer\"}]}]}")


  # ========================================================
  # JSON RESPONSE PARSING
  # --------------------------------------------------------
  # Python is used instead of jq to:
  #
  #   - reduce dependency requirements
  #   - avoid shell JSON parsing fragility
  # ========================================================

  output=$(printf '%s' "$response" | python3 -c '

import sys
import json

d = json.load(sys.stdin)

print(
  d["candidates"][0]
   ["content"]["parts"][0]["text"]
)

')


  # ========================================================
  # SAFETY FALLBACK
  # --------------------------------------------------------
  # Prevent empty terminal output on malformed responses.
  # ========================================================

  [ -z "$output" ] && \
    output="(empty response or API error)"


  # ========================================================
  # STORE RAW RESPONSE
  # --------------------------------------------------------
  # Preserve original FULL Gemini output in session logs.
  #
  # Logs remain authoritative archival history.
  # ========================================================

  printf "[%s] Gemini: %s\n" \
    "$(timestamp)" \
    "$output" >> "$SESSION"


  # ========================================================
  # ATTACHMENT EXTRACTION PIPELINE
  # ========================================================

  cleaned_output=$(printf '%s' "$output" | extract_attachments)


  # ========================================================
  # MEMORY UPDATE
  # ========================================================

  add_to_history "Assistant: $cleaned_output"


  # ========================================================
  # DISPLAY CLEANED OUTPUT
  # ========================================================

  printf "%s\n\n" "$cleaned_output"

done
