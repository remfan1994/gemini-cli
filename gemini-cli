#!/usr/bin/env bash

# ==========================================================
# gemini-cli
# ----------------------------------------------------------
# Terminal-based Gemini AI interface
#
# FEATURES
#   - Persistent chat sessions
#   - Named/resumable conversations
#   - Timestamped logs
#   - Lightweight rolling memory
#   - Config file support
#   - Automatic attachment extraction
#   - Configurable storage directories
#
# ATTACHMENT SYSTEM
#   Code blocks returned by Gemini are:
#     - extracted from terminal output
#     - saved as reusable files
#     - replaced with attachment notices
#
# DESIGN GOALS
#   - minimal dependencies
#   - shell-friendly
#   - readable logs
#   - artifact-oriented workflow
# ==========================================================


# ==========================================================
# CONFIGURATION LOCATIONS
# ----------------------------------------------------------
# CONFIG_DIR
#   Holds gemini-cli configuration files
#
# CONFIG_FILE
#   Main configuration file
# ==========================================================

CONFIG_DIR="$HOME/.config/gemini-cli"
CONFIG_FILE="$CONFIG_DIR/config"


# ==========================================================
# DEFAULT STORAGE LOCATIONS
# ----------------------------------------------------------
# These defaults may be overridden in the config file.
#
# SESSION_DIR
#   Stores chat session logs
#
# ATTACHMENT_DIR
#   Stores extracted code blocks/files
# ==========================================================

SESSION_DIR="$HOME/.gpt"
ATTACHMENT_DIR="$SESSION_DIR/attachments"


# ==========================================================
# DEFAULT SETTINGS
# ----------------------------------------------------------
# These values are fallback defaults and may be overridden
# by config file values.
# ==========================================================

MODEL="gemini-2.5-flash"

# Number of recent messages retained in memory context
HISTORY_LIMIT=12


# ==========================================================
# CONFIG FILE LOADING
# ----------------------------------------------------------
# Supported configuration keys:
#
#   MODEL
#   HISTORY_LIMIT
#   GEMINI_API_KEY
#   SESSION_DIR
#   ATTACHMENT_DIR
#
# Format:
#   KEY=VALUE
# ==========================================================

if [ -f "$CONFIG_FILE" ]; then

  while IFS='=' read -r key value; do

    case "$key" in

      MODEL)
        MODEL="$value"
        ;;

      HISTORY_LIMIT)
        HISTORY_LIMIT="$value"
        ;;

      GEMINI_API_KEY)
        GEMINI_API_KEY="${GEMINI_API_KEY:-$value}"
        ;;

      SESSION_DIR)
        SESSION_DIR="$value"
        ;;

      ATTACHMENT_DIR)
        ATTACHMENT_DIR="$value"
        ;;

    esac

  done < "$CONFIG_FILE"

fi


# ==========================================================
# ENSURE DIRECTORIES EXIST
# ----------------------------------------------------------
# IMPORTANT:
#   This occurs AFTER config loading so overridden paths
#   are respected.
# ==========================================================

mkdir -p "$CONFIG_DIR"
mkdir -p "$SESSION_DIR"
mkdir -p "$ATTACHMENT_DIR"


# ==========================================================
# API KEY VALIDATION
# ----------------------------------------------------------
# API key priority:
#
#   1. environment variable
#   2. config file
#
# Environment variable is preferred for security.
# ==========================================================

if [ -z "$GEMINI_API_KEY" ]; then

  echo "ERROR: GEMINI_API_KEY not set"
  echo ""
  echo "Set via:"
  echo "  export GEMINI_API_KEY=your_key"
  echo ""
  echo "or in:"
  echo "  ~/.config/gemini-cli/config"

  exit 1

fi


# ==========================================================
# GEMINI API ENDPOINT
# ----------------------------------------------------------
# Construct endpoint dynamically from selected model.
# ==========================================================

URL="https://generativelanguage.googleapis.com/v1beta/models/$MODEL:generateContent?key=$GEMINI_API_KEY"


# ==========================================================
# RUNTIME VARIABLES
# ==========================================================

USER_NAME="$(whoami)"

HISTORY=()
SUMMARY=""


# ==========================================================
# TIMESTAMP UTILITY
# ==========================================================

timestamp() {
  date +"%H:%M:%S"
}


# ==========================================================
# SESSION UTILITIES
# ----------------------------------------------------------
# Sessions are stored as:
#
#   SESSION_DIR/<name>.log
# ==========================================================

resolve_session_path() {
  echo "$SESSION_DIR/$1.log"
}

list_sessions() {

  ls -1 "$SESSION_DIR"/*.log 2>/dev/null \
    | sed 's#.*/##; s/\.log$##'

  exit 0
}

version() {

  echo "gemini-cli version 2.1"

  exit 0
}


# ==========================================================
# ARGUMENT PARSING
# ----------------------------------------------------------
# Supported modes:
#
#   gemini-cli
#   gemini-cli <name>
#   gemini-cli --resume <name>
#   gemini-cli --list
#   gemini-cli --version
# ==========================================================

case "$1" in

  --version)
    version
    ;;

  --list)
    list_sessions
    ;;

  --resume)

    SESSION_NAME="$2"
    SESSION="$(resolve_session_path "$2")"

    ;;

  "")

    SESSION_NAME="session-$(date +%Y-%m-%d-%H-%M-%S)"
    SESSION="$SESSION_DIR/$SESSION_NAME.log"

    ;;

  *)

    SESSION_NAME="$1"
    SESSION="$(resolve_session_path "$1")"

    ;;

esac


# ==========================================================
# STARTUP HEADER
# ----------------------------------------------------------
# Display current runtime configuration.
# ==========================================================

echo "gemini-cli"
echo "session: $SESSION"
echo "model: $MODEL"
echo ""


# ==========================================================
# MEMORY SYSTEM
# ----------------------------------------------------------
# Lightweight rolling conversation context.
#
# Avoids:
#   - massive token growth
#   - replaying full logs every request
# ==========================================================

add_to_history() {

  HISTORY+=("$1")

  if [ "${#HISTORY[@]}" -gt "$HISTORY_LIMIT" ]; then
    HISTORY=("${HISTORY[@]: -6}")
  fi
}

build_context() {

  context="$SUMMARY\n"

  for msg in "${HISTORY[@]}"; do
    context="$context$msg\n"
  done

  printf "%s" "$context"
}


# ==========================================================
# ATTACHMENT EXTRACTION SYSTEM
# ----------------------------------------------------------
# Detect fenced markdown code blocks and:
#
#   - save them into ATTACHMENT_DIR
#   - replace terminal output with notices
#
# Session logs preserve the FULL original response.
# ==========================================================

extract_attachments() {

python3 - "$ATTACHMENT_DIR" "$SESSION_NAME" <<'PYTHON'

import os
import re
import sys

attachment_dir = sys.argv[1]
session_name = sys.argv[2]

text = sys.stdin.read()


# ==========================================================
# LANGUAGE -> EXTENSION MAP
# ==========================================================

ext_map = {
    "bash": ".sh",
    "sh": ".sh",
    "shell": ".sh",
    "python": ".py",
    "json": ".json",
    "yaml": ".yml",
    "yml": ".yml",
    "javascript": ".js",
    "js": ".js",
    "html": ".html",
    "css": ".css",
    "sql": ".sql",
    "text": ".txt"
}


# ==========================================================
# ATTACHMENT COUNTER
# ----------------------------------------------------------
# Used to generate:
#
#   chatname-python-01.py
#   chatname-bash-02.sh
# ==========================================================

counter = 1


# ==========================================================
# CODE BLOCK DETECTION
# ----------------------------------------------------------
# Matches fenced markdown blocks:
#
#   ```python
#   print("hello")
#   ```
# ==========================================================

pattern = re.compile(
    r"```([a-zA-Z0-9_-]*)\n(.*?)```",
    re.DOTALL
)


# ==========================================================
# REPLACEMENT FUNCTION
# ----------------------------------------------------------
# Saves attachment file and returns terminal placeholder.
# ==========================================================

def replacement(match):

    global counter

    lang = match.group(1).strip().lower()
    content = match.group(2)

    if not lang:
        lang = "text"

    ext = ext_map.get(lang, ".txt")

    filename = (
        f"{session_name}-"
        f"{lang}-"
        f"{counter:02d}"
        f"{ext}"
    )

    path = os.path.join(attachment_dir, filename)

    with open(path, "w") as f:
        f.write(content)

    counter += 1

    return (
        f"\n"
        f"[attachment saved]\n"
        f"file: {filename}\n"
        f"location: {attachment_dir}\n"
    )


# ==========================================================
# PROCESS OUTPUT
# ==========================================================

cleaned = pattern.sub(replacement, text)

print(cleaned)

PYTHON

}


# ==========================================================
# MAIN CHAT LOOP
# ==========================================================

while true; do

  TS="$(timestamp)"


  # ========================================================
  # USER INPUT
  # ========================================================

  printf "[%s] %s> " "$TS" "$USER_NAME"

  buffer=$(cat)

  [ -z "$buffer" ] && continue


  # ========================================================
  # LOG USER INPUT
  # ========================================================

  printf "[%s] %s: %s\n" \
    "$TS" \
    "$USER_NAME" \
    "$buffer" >> "$SESSION"

  add_to_history "User: $buffer"


  # ========================================================
  # VISUAL SEPARATORS
  # ========================================================

  printf "\n________________________________________\n"
  printf "END INPUT\n"
  printf "________________________________________\n"

  printf "[%s] Generating response...\n" "$(timestamp)"

  printf "________________________________________\n"
  printf "BEGIN OUTPUT\n"
  printf "________________________________________\n\n"


  # ========================================================
  # BUILD CONTEXT
  # ========================================================

  context=$(build_context)


  # ========================================================
  # GEMINI API REQUEST
  # ========================================================

  response=$(curl -s "$URL" \
    -H "Content-Type: application/json" \
    -d "{\"contents\":[{\"parts\":[{\"text\":\"$context\nUser: $buffer\"}]}]}")


  # ========================================================
  # JSON RESPONSE PARSING
  # --------------------------------------------------------
  # Python is used instead of jq to minimize dependencies.
  # ========================================================

  output=$(printf '%s' "$response" | python3 -c '

import sys
import json

d = json.load(sys.stdin)

print(
  d["candidates"][0]
   ["content"]["parts"][0]["text"]
)

')


  # ========================================================
  # SAFETY FALLBACK
  # ========================================================

  [ -z "$output" ] && \
    output="(empty response or API error)"


  # ========================================================
  # STORE RAW RESPONSE
  # --------------------------------------------------------
  # Preserve original unmodified Gemini output in session log.
  # ========================================================

  printf "[%s] Gemini: %s\n" \
    "$(timestamp)" \
    "$output" >> "$SESSION"


  # ========================================================
  # ATTACHMENT EXTRACTION PIPELINE
  # ========================================================

  cleaned_output=$(printf '%s' "$output" | extract_attachments)


  # ========================================================
  # MEMORY UPDATE
  # ========================================================

  add_to_history "Assistant: $cleaned_output"


  # ========================================================
  # DISPLAY CLEANED OUTPUT
  # ========================================================

  printf "%s\n\n" "$cleaned_output"

done
